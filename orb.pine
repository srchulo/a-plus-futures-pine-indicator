//@version=5
strategy("15m ORB Backtest - NY / London / Asian (ORB 1m, Entry TF) - SL=Breakout Candle", overlay=true, pyramiding=0,
     initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.0,
     process_orders_on_close=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
useAsia    = input.bool(false, "Asian Open On", group=groupSessions)
sessionTZ  = input.string("America/New_York", "Session Timezone", group=groupSessions)

// ORB windows by clock time + duration (minutes)
nyStartH   = input.int(9,  "NY Start Hour",   minval=0, maxval=23, group=groupSessions)
nyStartM   = input.int(30, "NY Start Minute", minval=0, maxval=59, group=groupSessions)
nyDurM     = input.int(15, "NY ORB Minutes",  minval=1, maxval=120, group=groupSessions)

ldnStartH  = input.int(3,  "London Start Hour",   minval=0, maxval=23, group=groupSessions)
ldnStartM  = input.int(0,  "London Start Minute", minval=0, maxval=59, group=groupSessions)
ldnDurM    = input.int(15, "London ORB Minutes",  minval=1, maxval=120, group=groupSessions)

asiaStartH = input.int(19, "Asian Start Hour",   minval=0, maxval=23, group=groupSessions)
asiaStartM = input.int(0,  "Asian Start Minute", minval=0, maxval=59, group=groupSessions)
asiaDurM   = input.int(15, "Asian ORB Minutes",  minval=1, maxval=120, group=groupSessions)

// Trade windows / session cutoffs
nyEndH     = input.int(16, "NY End Hour", minval=0, maxval=23, group=groupSessions)
nyEndM     = input.int(0,  "NY End Minute", minval=0, maxval=59, group=groupSessions)

ldnEndH    = input.int(6,  "London End Hour", minval=0, maxval=23, group=groupSessions)
ldnEndM    = input.int(0,  "London End Minute", minval=0, maxval=59, group=groupSessions)

asiaEndH   = input.int(23, "Asian End Hour", minval=0, maxval=23, group=groupSessions)
asiaEndM   = input.int(0,  "Asian End Minute", minval=0, maxval=59, group=groupSessions)

groupTrade = "Trade Logic"
tradeMode    = input.string("Fixed RR", "Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTrade)
rrMultiple   = input.float(2.0, "Fixed RR Multiple", minval=0.5, step=0.5, group=groupTrade)
noWickStrict = input.bool(false, "Strict: No wick back into ORB", group=groupTrade)

breakoutMode = input.string("Current Behavior", "Breakout Qualification Mode", options=["Current Behavior", "First Qualified Close Only", "Reset Inside Then Requalify", "One-Bar Grace Then Reset"], group=groupTrade)

// optional tiny buffer so stops/targets aren’t exactly on a level
useBufferTicks = input.bool(false, "Use Tick Buffer", group=groupTrade)
bufferTicks    = input.int(1, "Buffer (ticks)", minval=0, maxval=20, group=groupTrade)

groupDisp = "Displacement Filter"
useDisplacementFilter = input.bool(true, "Displacement Filter On", group=groupDisp)
minCloseBeyondPct     = input.float(0.15, "Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)
maxBreakoutWickPct    = input.float(0.20, "Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)

groupTimeExit = "Time Exit"
useTimeExit    = input.bool(true, "Time Exit On", group=groupTimeExit)
maxBarsInTrade = input.int(12, "Max Bars In Trade", minval=1, maxval=500, group=groupTimeExit)
timeExitMode   = input.string("Any", "Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExit)

groupEOD = "End Of Day Close"
useEodClose = input.bool(true, "EOD Close On", group=groupEOD)
eodHour     = input.int(15, "EOD Hour", minval=0, maxval=23, group=groupEOD)
eodMinute   = input.int(55, "EOD Minute", minval=0, maxval=59, group=groupEOD)

groupDisplay = "Display"
showORBLevels                = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels                   = input.bool(true, "Show Entry Labels", group=groupDisplay)
showActiveStop               = input.bool(true, "Show Active Stop", group=groupDisplay)
showActiveTarget             = input.bool(true, "Show Active Target", group=groupDisplay)
showORBOnlyDuringTradeWindow = input.bool(true, "Show ORB Only During Trade Window", group=groupDisplay)

// =========================
// Entry rules (evaluated on CURRENT CHART timeframe)
// =========================
bodyCloseLong(orbHigh) =>
    close > orbHigh and close > open and (not noWickStrict or low >= orbHigh)

bodyCloseShort(orbLow) =>
    close < orbLow and close < open and (not noWickStrict or high <= orbLow)

// Displacement / momentum filter
displacementLong(orbHigh) =>
    candleRange = high - low
    breakoutWick = high - close
    closeBeyond = close - orbHigh
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

displacementShort(orbLow) =>
    candleRange = high - low
    breakoutWick = close - low
    closeBeyond = orbLow - close
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

entryLongOk(orbHigh) =>
    bodyCloseLong(orbHigh) and (not useDisplacementFilter or displacementLong(orbHigh))

entryShortOk(orbLow) =>
    bodyCloseShort(orbLow) and (not useDisplacementFilter or displacementShort(orbLow))

closeInsideOrb(orbHigh, orbLow) =>
    close <= orbHigh and close >= orbLow

closeAboveOrb(orbHigh) =>
    close > orbHigh

closeBelowOrb(orbLow) =>
    close < orbLow

minuteOfDay(h, m) =>
    h * 60 + m

inWindow(curMin, startMin, endMin) =>
    startMin <= endMin ? (curMin >= startMin and curMin <= endMin) : (curMin >= startMin or curMin <= endMin)

tradeWindowActive(startH, startM, durM, endH, endM) =>
    int curH = hour(time, sessionTZ)
    int curM = minute(time, sessionTZ)
    int curMin = minuteOfDay(curH, curM)

    int orbEndMin = minuteOfDay(startH, startM) + durM
    int endMin    = minuteOfDay(endH, endM)

    orbEndMin := orbEndMin % 1440

    inWindow(curMin, orbEndMin, endMin)

// =========================
// ORB engine on 1m (range accuracy)
// =========================
orbLevels1m(startH, startM, durM) =>
    int y  = year(time, sessionTZ)
    int mo = month(time, sessionTZ)
    int d  = dayofmonth(time, sessionTZ)
    int h  = hour(time, sessionTZ)
    int m  = minute(time, sessionTZ)

    int dayId = y * 10000 + mo * 100 + d

    int curMin   = h * 60 + m
    int startMin = startH * 60 + startM
    int endMin   = startMin + durM

    bool inOrb = curMin >= startMin and curMin < endMin

    var float hi = na
    var float lo = na
    var bool  ready = false
    var int   lastDayId = na

    if na(lastDayId) or dayId != lastDayId
        hi := na
        lo := na
        ready := false
        lastDayId := dayId

    bool startBar = inOrb and not inOrb[1]
    bool ended    = not inOrb and inOrb[1]

    if startBar
        hi := high
        lo := low
        ready := false
    else if inOrb
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low  : math.min(lo, low)

    if ended
        ready := true

    float outHi = (inOrb or ready) ? hi : na
    float outLo = (inOrb or ready) ? lo : na

    [outHi, outLo, ready, dayId]

// Pull ORBs from 1m
[nyHigh, nyLow, nyReady, nyDayId] =
     request.security(syminfo.tickerid, "1", orbLevels1m(nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_off)

[ldnHigh, ldnLow, ldnReady, ldnDayId] =
     request.security(syminfo.tickerid, "1", orbLevels1m(ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_off)

[asiaHigh, asiaLow, asiaReady, asiaDayId] =
     request.security(syminfo.tickerid, "1", orbLevels1m(asiaStartH, asiaStartM, asiaDurM), barmerge.gaps_off, barmerge.lookahead_off)

// Session trade windows
nyTradeWindowActive   = useNY and nyReady and tradeWindowActive(nyStartH, nyStartM, nyDurM, nyEndH, nyEndM)
ldnTradeWindowActive  = useLondon and ldnReady and tradeWindowActive(ldnStartH, ldnStartM, ldnDurM, ldnEndH, ldnEndM)
asiaTradeWindowActive = useAsia and asiaReady and tradeWindowActive(asiaStartH, asiaStartM, asiaDurM, asiaEndH, asiaEndM)

// =========================
// One trade per session per day gating
// =========================
var int lastDay = na
var bool nyTraded = false
var bool ldnTraded = false
var bool asiaTraded = false

// Directional breakout state per session
var bool nyLongNeedsReset = false
var bool nyShortNeedsReset = false
var bool ldnLongNeedsReset = false
var bool ldnShortNeedsReset = false
var bool asiaLongNeedsReset = false
var bool asiaShortNeedsReset = false

var bool nyLongDead = false
var bool nyShortDead = false
var bool ldnLongDead = false
var bool ldnShortDead = false
var bool asiaLongDead = false
var bool asiaShortDead = false

var int nyLongOutsideCount = 0
var int nyShortOutsideCount = 0
var int ldnLongOutsideCount = 0
var int ldnShortOutsideCount = 0
var int asiaLongOutsideCount = 0
var int asiaShortOutsideCount = 0

curDay = year(time, sessionTZ) * 10000 + month(time, sessionTZ) * 100 + dayofmonth(time, sessionTZ)

if na(lastDay) or curDay != lastDay
    nyTraded := false
    ldnTraded := false
    asiaTraded := false

    nyLongNeedsReset := false
    nyShortNeedsReset := false
    ldnLongNeedsReset := false
    ldnShortNeedsReset := false
    asiaLongNeedsReset := false
    asiaShortNeedsReset := false

    nyLongDead := false
    nyShortDead := false
    ldnLongDead := false
    ldnShortDead := false
    asiaLongDead := false
    asiaShortDead := false

    nyLongOutsideCount := 0
    nyShortOutsideCount := 0
    ldnLongOutsideCount := 0
    ldnShortOutsideCount := 0
    asiaLongOutsideCount := 0
    asiaShortOutsideCount := 0

    lastDay := curDay

// =========================
// Breakout state management
// =========================
if strategy.position_size == 0
    // NY long side
    if nyTradeWindowActive and not nyTraded and not nyLongDead
        if closeInsideOrb(nyHigh, nyLow)
            nyLongNeedsReset := false
            nyLongOutsideCount := 0
        else if closeAboveOrb(nyHigh)
            if nyLongNeedsReset
                nyLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and nyLongOutsideCount > 1
                    nyLongDead := true

    // NY short side
    if nyTradeWindowActive and not nyTraded and not nyShortDead
        if closeInsideOrb(nyHigh, nyLow)
            nyShortNeedsReset := false
            nyShortOutsideCount := 0
        else if closeBelowOrb(nyLow)
            if nyShortNeedsReset
                nyShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and nyShortOutsideCount > 1
                    nyShortDead := true

    // London long side
    if ldnTradeWindowActive and not ldnTraded and not ldnLongDead
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnLongNeedsReset := false
            ldnLongOutsideCount := 0
        else if closeAboveOrb(ldnHigh)
            if ldnLongNeedsReset
                ldnLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and ldnLongOutsideCount > 1
                    ldnLongDead := true

    // London short side
    if ldnTradeWindowActive and not ldnTraded and not ldnShortDead
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnShortNeedsReset := false
            ldnShortOutsideCount := 0
        else if closeBelowOrb(ldnLow)
            if ldnShortNeedsReset
                ldnShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and ldnShortOutsideCount > 1
                    ldnShortDead := true

    // Asia long side
    if asiaTradeWindowActive and not asiaTraded and not asiaLongDead
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaLongNeedsReset := false
            asiaLongOutsideCount := 0
        else if closeAboveOrb(asiaHigh)
            if asiaLongNeedsReset
                asiaLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and asiaLongOutsideCount > 1
                    asiaLongDead := true

    // Asia short side
    if asiaTradeWindowActive and not asiaTraded and not asiaShortDead
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaShortNeedsReset := false
            asiaShortOutsideCount := 0
        else if closeBelowOrb(asiaLow)
            if asiaShortNeedsReset
                asiaShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and asiaShortOutsideCount > 1
                    asiaShortDead := true

// =========================
// Entry permission logic by mode
// =========================
canConsiderLong(ready, traded, dead, needsReset, orbHigh) => ready and not traded and strategy.position_size == 0 and (breakoutMode == "Current Behavior" ? closeAboveOrb(orbHigh) : breakoutMode == "First Qualified Close Only" ? closeAboveOrb(orbHigh) and not needsReset and not dead : breakoutMode == "Reset Inside Then Requalify" ? closeAboveOrb(orbHigh) and not needsReset and not dead : breakoutMode == "One-Bar Grace Then Reset" ? closeAboveOrb(orbHigh) and not dead : false)

canConsiderShort(ready, traded, dead, needsReset, orbLow) => ready and not traded and strategy.position_size == 0 and (breakoutMode == "Current Behavior" ? closeBelowOrb(orbLow) : breakoutMode == "First Qualified Close Only" ? closeBelowOrb(orbLow) and not needsReset and not dead : breakoutMode == "Reset Inside Then Requalify" ? closeBelowOrb(orbLow) and not needsReset and not dead : breakoutMode == "One-Bar Grace Then Reset" ? closeBelowOrb(orbLow) and not dead : false)

// =========================
// Entry Logic (FIRST / QUALIFIED CHART-TF candle outside ORB per mode)
// Stop = breakout candle low/high
// =========================
float tick = syminfo.mintick
float buf  = useBufferTicks ? bufferTicks * tick : 0.0

var string activeORB = ""
bool longSignal = false
bool shortSignal = false
float intendedStop = na

nyLongCandidate   = nyTradeWindowActive and canConsiderLong(nyReady, nyTraded, nyLongDead, nyLongNeedsReset, nyHigh)
nyShortCandidate  = nyTradeWindowActive and canConsiderShort(nyReady, nyTraded, nyShortDead, nyShortNeedsReset, nyLow)

ldnLongCandidate  = ldnTradeWindowActive and canConsiderLong(ldnReady, ldnTraded, ldnLongDead, ldnLongNeedsReset, ldnHigh)
ldnShortCandidate = ldnTradeWindowActive and canConsiderShort(ldnReady, ldnTraded, ldnShortDead, ldnShortNeedsReset, ldnLow)

asiaLongCandidate  = asiaTradeWindowActive and canConsiderLong(asiaReady, asiaTraded, asiaLongDead, asiaLongNeedsReset, asiaHigh)
asiaShortCandidate = asiaTradeWindowActive and canConsiderShort(asiaReady, asiaTraded, asiaShortDead, asiaShortNeedsReset, asiaLow)

nyLongSignal   = nyLongCandidate and entryLongOk(nyHigh)
nyShortSignal  = nyShortCandidate and entryShortOk(nyLow)

ldnLongSignal  = ldnLongCandidate and entryLongOk(ldnHigh)
ldnShortSignal = ldnShortCandidate and entryShortOk(ldnLow)

asiaLongSignal  = asiaLongCandidate and entryLongOk(asiaHigh)
asiaShortSignal = asiaShortCandidate and entryShortOk(asiaLow)

// Mark failed breakout attempts based on mode
if strategy.position_size == 0
    // NY long fail handling
    if nyLongCandidate and not entryLongOk(nyHigh)
        if breakoutMode == "First Qualified Close Only"
            nyLongDead := true
            nyLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0

    // NY short fail handling
    if nyShortCandidate and not entryShortOk(nyLow)
        if breakoutMode == "First Qualified Close Only"
            nyShortDead := true
            nyShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0

    // London long fail handling
    if ldnLongCandidate and not entryLongOk(ldnHigh)
        if breakoutMode == "First Qualified Close Only"
            ldnLongDead := true
            ldnLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0

    // London short fail handling
    if ldnShortCandidate and not entryShortOk(ldnLow)
        if breakoutMode == "First Qualified Close Only"
            ldnShortDead := true
            ldnShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0

    // Asia long fail handling
    if asiaLongCandidate and not entryLongOk(asiaHigh)
        if breakoutMode == "First Qualified Close Only"
            asiaLongDead := true
            asiaLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0

    // Asia short fail handling
    if asiaShortCandidate and not entryShortOk(asiaLow)
        if breakoutMode == "First Qualified Close Only"
            asiaShortDead := true
            asiaShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0

// Priority: NY > London > Asia if multiple trigger same bar
if nyLongSignal
    longSignal := true
    activeORB := "NY"
    intendedStop := low - buf
    nyTraded := true
    nyLongNeedsReset := false
    nyLongDead := true
else if nyShortSignal
    shortSignal := true
    activeORB := "NY"
    intendedStop := high + buf
    nyTraded := true
    nyShortNeedsReset := false
    nyShortDead := true
else if ldnLongSignal
    longSignal := true
    activeORB := "London"
    intendedStop := low - buf
    ldnTraded := true
    ldnLongNeedsReset := false
    ldnLongDead := true
else if ldnShortSignal
    shortSignal := true
    activeORB := "London"
    intendedStop := high + buf
    ldnTraded := true
    ldnShortNeedsReset := false
    ldnShortDead := true
else if asiaLongSignal
    longSignal := true
    activeORB := "Asia"
    intendedStop := low - buf
    asiaTraded := true
    asiaLongNeedsReset := false
    asiaLongDead := true
else if asiaShortSignal
    shortSignal := true
    activeORB := "Asia"
    intendedStop := high + buf
    asiaTraded := true
    asiaShortNeedsReset := false
    asiaShortDead := true

if longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up,
          textcolor=color.white, color=color.new(color.green, 0))

if shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down,
          textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Freeze entry/stop/risk on actual fill bar
// =========================
var float posStopRef = na
var float posEntry   = na
var float posRisk    = na
var float highestSinceEntry = na
var float lowestSinceEntry  = na
var int   entryBarIndex = na

if longSignal or shortSignal
    posStopRef := intendedStop

newLong  = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
flatNow  = strategy.position_size == 0 and strategy.position_size[1] != 0

if flatNow or strategy.position_size == 0
    posEntry := na
    posRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na

if newLong
    posEntry := strategy.position_avg_price
    posRisk  := posEntry - posStopRef
    highestSinceEntry := high
    entryBarIndex := bar_index

if newShort
    posEntry := strategy.position_avg_price
    posRisk  := posStopRef - posEntry
    lowestSinceEntry := low
    entryBarIndex := bar_index

if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)

if strategy.position_size < 0
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)

validLong  = strategy.position_size > 0 and not na(posEntry) and not na(posRisk) and posRisk > 0 and not na(posStopRef)
validShort = strategy.position_size < 0 and not na(posEntry) and not na(posRisk) and posRisk > 0 and not na(posStopRef)

// =========================
// Helper state for trail activation
// =========================
longRunupR  = validLong  ? math.floor((highestSinceEntry - posEntry) / posRisk) : na
shortRunupR = validShort ? math.floor((posEntry - lowestSinceEntry) / posRisk) : na

trailActiveLong  = validLong and tradeMode == "1R Step Trail" and longRunupR >= 1
trailActiveShort = validShort and tradeMode == "1R Step Trail" and shortRunupR >= 1

// =========================
// Time Exit Logic
// Fixed RR: normal time exit logic
// 1R Trail: time exit only BEFORE trail activates
// =========================
barsInTrade = not na(entryBarIndex) ? (bar_index - entryBarIndex) : na

longInProfit  = validLong and close > posEntry
shortInProfit = validShort and close < posEntry

timeExitEligibleLong = tradeMode == "Fixed RR" or (tradeMode == "1R Step Trail" and not trailActiveLong)
timeExitEligibleShort = tradeMode == "Fixed RR" or (tradeMode == "1R Step Trail" and not trailActiveShort)

timeExitLong = useTimeExit and validLong and timeExitEligibleLong and not na(barsInTrade) and barsInTrade >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and longInProfit))
timeExitShort = useTimeExit and validShort and timeExitEligibleShort and not na(barsInTrade) and barsInTrade >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and shortInProfit))

// =========================
// End-of-day close logic
// =========================
int curHour = hour(time, sessionTZ)
int curMinute = minute(time, sessionTZ)
int curMinuteOfDay = curHour * 60 + curMinute
int eodMinuteOfDay = eodHour * 60 + eodMinute

eodCloseNow = useEodClose and curMinuteOfDay >= eodMinuteOfDay

// =========================
// Visible active stop / target levels
// =========================
float activeLongStop   = na
float activeShortStop  = na
float activeLongTarget = na
float activeShortTarget = na

if validLong
    if tradeMode == "Fixed RR"
        activeLongStop   := posStopRef
        activeLongTarget := posEntry + posRisk * rrMultiple
    else
        activeLongStop := longRunupR < 1 ? posStopRef : posEntry + (longRunupR - 1) * posRisk

if validShort
    if tradeMode == "Fixed RR"
        activeShortStop   := posStopRef
        activeShortTarget := posEntry - posRisk * rrMultiple
    else
        activeShortStop := shortRunupR < 1 ? posStopRef : posEntry - (shortRunupR - 1) * posRisk

// =========================
// Exit Logic
// =========================
if validLong
    strategy.exit("Long Exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if validShort
    strategy.exit("Short Exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

// Time-based close
if timeExitLong
    strategy.close("Long", comment="Time Exit")

if timeExitShort
    strategy.close("Short", comment="Time Exit")

// EOD forced close
if eodCloseNow and strategy.position_size > 0
    strategy.close("Long", comment="EOD Close")

if eodCloseNow and strategy.position_size < 0
    strategy.close("Short", comment="EOD Close")

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and useNY and (not showORBOnlyDuringTradeWindow or nyTradeWindowActive) ? nyHigh : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useNY and (not showORBOnlyDuringTradeWindow or nyTradeWindowActive) ? nyLow  : na, "NY ORB Low",  color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and useLondon and (not showORBOnlyDuringTradeWindow or ldnTradeWindowActive) ? ldnHigh : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useLondon and (not showORBOnlyDuringTradeWindow or ldnTradeWindowActive) ? ldnLow  : na, "London ORB Low",  color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and useAsia and (not showORBOnlyDuringTradeWindow or asiaTradeWindowActive) ? asiaHigh : na, "Asia ORB High", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useAsia and (not showORBOnlyDuringTradeWindow or asiaTradeWindowActive) ? asiaLow  : na, "Asia ORB Low",  color=color.new(color.purple, 0), linewidth=2, style=plot.style_linebr)

// =========================
// Plot active stop / target
// =========================
plot(showActiveStop and validLong ? activeLongStop : na, "Long Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)
plot(showActiveStop and validShort ? activeShortStop : na, "Short Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)

plot(showActiveTarget and tradeMode == "Fixed RR" and validLong ? activeLongTarget : na, "Long Target", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(showActiveTarget and tradeMode == "Fixed RR" and validShort ? activeShortTarget : na, "Short Target", color=color.new(color.maroon, 0), linewidth=2, style=plot.style_linebr)