//@version=5
strategy("15m ORB Backtest - NY / London (5m-safe entries)", overlay=true, pyramiding=0,
     initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.0,
     process_orders_on_close=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
sessionTZ  = input.string("America/New_York", "Session Timezone", group=groupSessions)

// ORB windows by clock time + duration (minutes)
nyStartH   = input.int(9,  "NY Start Hour",   minval=0, maxval=23, group=groupSessions)
nyStartM   = input.int(30, "NY Start Minute", minval=0, maxval=59, group=groupSessions)
nyDurM     = input.int(15, "NY ORB Minutes",  minval=1, maxval=120, group=groupSessions)

ldnStartH  = input.int(3,  "London Start Hour",   minval=0, maxval=23, group=groupSessions)
ldnStartM  = input.int(0,  "London Start Minute", minval=0, maxval=59, group=groupSessions)
ldnDurM    = input.int(15, "London ORB Minutes",  minval=1, maxval=120, group=groupSessions)

groupTrade = "Trade Logic"
tradeMode    = input.string("Fixed RR", "Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTrade)
rrMultiple   = input.float(2.0, "Fixed RR Multiple", minval=0.5, step=0.5, group=groupTrade)
noWickStrict = input.bool(false, "Strict: No wick back into ORB", group=groupTrade)

groupDisplay = "Display"
showORBLevels = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels    = input.bool(true, "Show Entry Labels", group=groupDisplay)

// =========================
// ORB + LATCHED signal engine on 1m
// Returns sigState that persists after first breakout.
// =========================
orbAndLatchedSignal1m(startH, startM, durM) =>
    int y  = year(time, sessionTZ)
    int mo = month(time, sessionTZ)
    int d  = dayofmonth(time, sessionTZ)
    int h  = hour(time, sessionTZ)
    int m  = minute(time, sessionTZ)

    int dayId = y * 10000 + mo * 100 + d

    int curMin   = h * 60 + m
    int startMin = startH * 60 + startM
    int endMin   = startMin + durM

    bool inOrb = curMin >= startMin and curMin < endMin

    var float hi = na
    var float lo = na
    var bool  ready = false
    var int   lastDayId = na

    // LATCHED signal state: 0 none, +1 long triggered, -1 short triggered
    var int sigState = 0

    // Reset on new day
    if na(lastDayId) or dayId != lastDayId
        hi := na
        lo := na
        ready := false
        sigState := 0
        lastDayId := dayId

    bool startBar = inOrb and not inOrb[1]
    bool ended    = not inOrb and inOrb[1]

    if startBar
        hi := high
        lo := low
        ready := false
        sigState := 0
    else if inOrb
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low  : math.min(lo, low)

    if ended
        ready := true

    float outHi = (inOrb or ready) ? hi : na
    float outLo = (inOrb or ready) ? lo : na

    // Trigger only once, after ORB is ready
    if ready and sigState == 0
        bool longOk  = close > outHi and close > open and (not noWickStrict or low >= outHi)
        bool shortOk = close < outLo and close < open and (not noWickStrict or high <= outLo)

        if longOk
            sigState := 1
        else if shortOk
            sigState := -1

    [outHi, outLo, ready, dayId, sigState]

// Request NY + London from 1m
[nyHigh, nyLow, nyReady, nyDayId, nySigState] =
     request.security(syminfo.tickerid, "1", orbAndLatchedSignal1m(nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_off)

[ldnHigh, ldnLow, ldnReady, ldnDayId, ldnSigState] =
     request.security(syminfo.tickerid, "1", orbAndLatchedSignal1m(ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_off)

// Detect the moment the latched signal first appears on THIS timeframe
nyLongFlip  = nySigState == 1 and nz(nySigState[1]) != 1
nyShortFlip = nySigState == -1 and nz(nySigState[1]) != -1
ldnLongFlip  = ldnSigState == 1 and nz(ldnSigState[1]) != 1
ldnShortFlip = ldnSigState == -1 and nz(ldnSigState[1]) != -1

// =========================
// One trade per day gating
// =========================
var int lastDay = na
var bool nyTraded = false
var bool ldnTraded = false

if na(lastDay) or nyDayId != lastDay
    nyTraded := false
    ldnTraded := false
    lastDay := nyDayId

// =========================
// Entry Logic (NY priority, then London)
// =========================
var string activeORB = ""
bool longSignal = false
bool shortSignal = false
float entryStop = na

nyLongSignal  = useNY and nyReady and not nyTraded and strategy.position_size == 0 and nyLongFlip
nyShortSignal = useNY and nyReady and not nyTraded and strategy.position_size == 0 and nyShortFlip

ldnLongSignal  = useLondon and ldnReady and not ldnTraded and strategy.position_size == 0 and ldnLongFlip
ldnShortSignal = useLondon and ldnReady and not ldnTraded and strategy.position_size == 0 and ldnShortFlip

if nyLongSignal
    longSignal := true
    activeORB := "NY"
    entryStop := nyLow
    nyTraded := true
else if nyShortSignal
    shortSignal := true
    activeORB := "NY"
    entryStop := nyHigh
    nyTraded := true
else if ldnLongSignal
    longSignal := true
    activeORB := "London"
    entryStop := ldnLow
    ldnTraded := true
else if ldnShortSignal
    shortSignal := true
    activeORB := "London"
    entryStop := ldnHigh
    ldnTraded := true

if longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up,
          textcolor=color.white, color=color.new(color.green, 0))

if shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down,
          textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Exit tracking
// =========================
var float currentStopRef = na
var float currentRisk = na
var float highestSinceEntry = na
var float lowestSinceEntry = na

if longSignal or shortSignal
    currentStopRef := entryStop

if strategy.position_size == 0
    currentRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na

if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)
    currentRisk := na(currentRisk) ? (strategy.position_avg_price - currentStopRef) : currentRisk

if strategy.position_size < 0
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)
    currentRisk := na(currentRisk) ? (currentStopRef - strategy.position_avg_price) : currentRisk

validRiskLong  = strategy.position_size > 0 and not na(currentRisk) and currentRisk > 0
validRiskShort = strategy.position_size < 0 and not na(currentRisk) and currentRisk > 0

// =========================
// Exit Logic
// =========================
if validRiskLong
    float longEntry = strategy.position_avg_price
    float longStop  = na
    float longLimit = na

    if tradeMode == "Fixed RR"
        longStop  := currentStopRef
        longLimit := longEntry + currentRisk * rrMultiple
    else
        int longRunupR = math.floor((highestSinceEntry - longEntry) / currentRisk)
        longStop := longEntry + (longRunupR - 1) * currentRisk

    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longLimit)

if validRiskShort
    float shortEntry = strategy.position_avg_price
    float shortStop  = na
    float shortLimit = na

    if tradeMode == "Fixed RR"
        shortStop  := currentStopRef
        shortLimit := shortEntry - currentRisk * rrMultiple
    else
        int shortRunupR = math.floor((shortEntry - lowestSinceEntry) / currentRisk)
        shortStop := shortEntry - (shortRunupR - 1) * currentRisk

    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortLimit)

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and useNY ? nyHigh : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useNY ? nyLow  : na, "NY ORB Low",  color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and useLondon ? ldnHigh : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useLondon ? ldnLow  : na, "London ORB Low",  color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)