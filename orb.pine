//@version=5
strategy("15m ORB Backtest - NY / London", overlay=true, pyramiding=0, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.0, process_orders_on_close=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
sessionTZ  = input.string("America/New_York", "Session Timezone", group=groupSessions)

nySession      = input.session("0930-0945", "NY ORB Window", group=groupSessions)
londonSession  = input.session("0300-0315", "London ORB Window", group=groupSessions)

groupTrade = "Trade Logic"
tradeMode   = input.string("Fixed RR", "Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTrade)
rrMultiple  = input.float(2.0, "Fixed RR Multiple", minval=0.5, step=0.5, group=groupTrade)
// Optional stricter interpretation: require NO wick to dip back into ORB after closing outside.
// Default off, since you didn't ask for strict mode as required behavior.
noWickStrict = input.bool(false, "Strict: No wick back into ORB", group=groupTrade)

groupDisplay = "Display"
showORBLevels = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels    = input.bool(true, "Show Entry Labels", group=groupDisplay)

// =========================
// Helpers
// =========================
inSession(sess) =>
    not na(time(timeframe.period, sess, sessionTZ))

newSessionStart(sess) =>
    inSession(sess) and not inSession(sess)[1]

sessionEnd(sess) =>
    not inSession(sess) and inSession(sess)[1]

// Body-close breakout rules (what you want):
// Long: close above ORB high with bullish body (close > open). Not just a wick.
// Short: close below ORB low with bearish body (close < open). Not just a wick.
// Optional strict mode: also require the wick does not dip back into the ORB.
bodyCloseLong(orbHigh) =>
    close > orbHigh and close > open and (not noWickStrict or low >= orbHigh)

bodyCloseShort(orbLow) =>
    close < orbLow and close < open and (not noWickStrict or high <= orbLow)

// =========================
// ORB tracking for NY
// =========================
var float nyHigh = na
var float nyLow = na
var bool nyRangeReady = false
var bool nyTraded = false

if newSessionStart(nySession)
    nyHigh := high
    nyLow := low
    nyRangeReady := false
    nyTraded := false
else if inSession(nySession)
    nyHigh := na(nyHigh) ? high : math.max(nyHigh, high)
    nyLow := na(nyLow) ? low : math.min(nyLow, low)

if sessionEnd(nySession)
    nyRangeReady := true

// =========================
// ORB tracking for London
// =========================
var float londonHigh = na
var float londonLow = na
var bool londonRangeReady = false
var bool londonTraded = false

if newSessionStart(londonSession)
    londonHigh := high
    londonLow := low
    londonRangeReady := false
    londonTraded := false
else if inSession(londonSession)
    londonHigh := na(londonHigh) ? high : math.max(londonHigh, high)
    londonLow := na(londonLow) ? low : math.min(londonLow, low)

if sessionEnd(londonSession)
    londonRangeReady := true

// =========================
// Entry Logic
// Priority: NY first, then London
// One trade per enabled session
// =========================
var string activeORB = ""
longSignal = false
shortSignal = false
float entryStop = na

// NY setup
nyLongSignal  = useNY and nyRangeReady and not nyTraded and strategy.position_size == 0 and bodyCloseLong(nyHigh)
nyShortSignal = useNY and nyRangeReady and not nyTraded and strategy.position_size == 0 and bodyCloseShort(nyLow)

// London setup
londonLongSignal  = useLondon and londonRangeReady and not londonTraded and strategy.position_size == 0 and bodyCloseLong(londonHigh)
londonShortSignal = useLondon and londonRangeReady and not londonTraded and strategy.position_size == 0 and bodyCloseShort(londonLow)

// Prefer NY if both somehow trigger on same bar
if nyLongSignal
    longSignal := true
    activeORB := "NY"
    entryStop := nyLow
    nyTraded := true
else if nyShortSignal
    shortSignal := true
    activeORB := "NY"
    entryStop := nyHigh
    nyTraded := true
else if londonLongSignal
    longSignal := true
    activeORB := "London"
    entryStop := londonLow
    londonTraded := true
else if londonShortSignal
    shortSignal := true
    activeORB := "London"
    entryStop := londonHigh
    londonTraded := true

if longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 0))

if shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Track stop source from actual active setup
// =========================
var float currentStopRef = na
var float currentRisk = na
var float highestSinceEntry = na
var float lowestSinceEntry = na

// On signal bar, save intended stop reference
if longSignal or shortSignal
    currentStopRef := entryStop

// Reset tracking when flat
if strategy.position_size == 0
    currentRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na

// Initialize tracking once in a position
if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)
    currentRisk := na(currentRisk) ? (strategy.position_avg_price - currentStopRef) : currentRisk

if strategy.position_size < 0
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)
    currentRisk := na(currentRisk) ? (currentStopRef - strategy.position_avg_price) : currentRisk

// Safety check: do nothing if risk is invalid
validRiskLong  = strategy.position_size > 0 and not na(currentRisk) and currentRisk > 0
validRiskShort = strategy.position_size < 0 and not na(currentRisk) and currentRisk > 0

// =========================
// Exit Logic
// =========================
if validRiskLong
    longEntry = strategy.position_avg_price
    float longStop  = na
    float longLimit = na

    if tradeMode == "Fixed RR"
        longStop  := currentStopRef
        longLimit := longEntry + currentRisk * rrMultiple
    else
        // Trail by 1R each time another 1R is achieved.
        // Example: once price reaches +1R, stop moves to entry (0R).
        // once price reaches +2R, stop moves to +1R, etc.
        longRunupR = math.floor((highestSinceEntry - longEntry) / currentRisk)
        longStop   := longEntry + (longRunupR - 1) * currentRisk

    strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longLimit)

if validRiskShort
    shortEntry = strategy.position_avg_price
    float shortStop  = na
    float shortLimit = na

    if tradeMode == "Fixed RR"
        shortStop  := currentStopRef
        shortLimit := shortEntry - currentRisk * rrMultiple
    else
        // Trail by 1R each time another 1R is achieved.
        // Example: once price reaches +1R (in your favor), stop moves to entry (0R).
        // once price reaches +2R, stop moves to +1R, etc.
        shortRunupR = math.floor((shortEntry - lowestSinceEntry) / currentRisk)
        shortStop   := shortEntry - (shortRunupR - 1) * currentRisk

    strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortLimit)

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and useNY ? nyHigh : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useNY ? nyLow  : na, "NY ORB Low",  color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and useLondon ? londonHigh : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useLondon ? londonLow  : na, "London ORB Low",  color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)