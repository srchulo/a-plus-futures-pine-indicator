//@version=5
strategy("ORB Precision", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.0, process_orders_on_close=true, calc_on_every_tick=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
useAsia    = input.bool(false, "Asian Open On", group=groupSessions)

// Master strategy day / bookkeeping timezone
strategyDayTZ = input.string("America/New_York", "Strategy Day Timezone", group=groupSessions)

// Native session timezones
nyTZ   = input.string("America/New_York", "NY Timezone", group=groupSessions)
ldnTZ  = input.string("Europe/London", "London Timezone", group=groupSessions)
asiaTZ = input.string("Asia/Tokyo", "Asia Timezone", group=groupSessions)

// ORB windows by LOCAL SESSION clock time + duration (minutes)
nyStartH   = input.int(9,  "NY Start Hour",   minval=0, maxval=23, group=groupSessions)
nyStartM   = input.int(30, "NY Start Minute", minval=0, maxval=59, group=groupSessions)
nyDurM     = input.int(15, "NY ORB Minutes",  minval=1, maxval=120, group=groupSessions)

ldnStartH  = input.int(8,  "London Start Hour",   minval=0, maxval=23, group=groupSessions)
ldnStartM  = input.int(0,  "London Start Minute", minval=0, maxval=59, group=groupSessions)
ldnDurM    = input.int(15, "London ORB Minutes",  minval=1, maxval=120, group=groupSessions)

asiaStartH = input.int(9,  "Asian Start Hour",   minval=0, maxval=23, group=groupSessions)
asiaStartM = input.int(0,  "Asian Start Minute", minval=0, maxval=59, group=groupSessions)
asiaDurM   = input.int(15, "Asian ORB Minutes",  minval=1, maxval=120, group=groupSessions)

// Trade windows / session cutoffs in LOCAL SESSION clock time
nyEndH     = input.int(16, "NY End Hour", minval=0, maxval=23, group=groupSessions)
nyEndM     = input.int(0,  "NY End Minute", minval=0, maxval=59, group=groupSessions)

ldnEndH    = input.int(10, "London End Hour", minval=0, maxval=23, group=groupSessions)
ldnEndM    = input.int(0,  "London End Minute", minval=0, maxval=59, group=groupSessions)

asiaEndH   = input.int(13, "Asian End Hour", minval=0, maxval=23, group=groupSessions)
asiaEndM   = input.int(0,  "Asian End Minute", minval=0, maxval=59, group=groupSessions)

// =========================
// Session-specific trade logic inputs
// =========================
groupTradeNY = "Trade Logic - NY"
nyTradeMode       = input.string("1R Step Trail", "NY Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTradeNY)
nyRrMultiple      = input.float(2.0, "NY Fixed RR Multiple", minval=0.5, step=0.5, group=groupTradeNY)
nyNoWickStrict    = input.bool(false, "NY Strict: No wick back into ORB", group=groupTradeNY)
nyBreakoutMode    = input.string("Current Behavior", "NY Breakout Qualification Mode", options=["Current Behavior", "First Qualified Close Only", "Reset Inside Then Requalify", "One-Bar Grace Then Reset"], group=groupTradeNY)
nyAllowSecondBreak = input.bool(false, "NY Allow One Second Break After First Losing Trade + Reset Inside ORB", group=groupTradeNY)

groupFollowNY = "Follow-Through Confirmation Filter - NY"
nyUseFollowThroughConfirmation = input.bool(false, "NY Immediate Follow-Through / Reclaim Filter On", group=groupFollowNY)

groupRetestNY = "Large Breakout Retest Mode - NY"
nyUseLargeBreakoutRetest   = input.bool(false, "NY Large Breakout Retest On", group=groupRetestNY)
nyLargeBreakoutAtrThreshold = input.float(0.55, "NY Large Breakout Candle / ATR Threshold", minval=0.0, step=0.01, group=groupRetestNY)
nyRetestLevelMode          = input.string("ORB Boundary", "NY Retest Level", options=["ORB Boundary", "Breakout Midpoint"], group=groupRetestNY)
nyMaxRetestBars            = input.int(4, "NY Max Bars To Wait For Retest", minval=1, maxval=20, group=groupRetestNY)

groupStopAdjNY = "Stop Adjustment - NY"
nyUseStopAdjustment = input.bool(true, "NY Stop Adjustment On", group=groupStopAdjNY)
nyStopMultiplier    = input.float(1.85, "NY Stop Multiplier", minval=0.1, step=0.05, group=groupStopAdjNY)
nyTrailRiskBasis    = input.string("Adjusted Stop Risk", "NY Trail Risk Basis", options=["Adjusted Stop Risk", "Original Breakout Risk"], group=groupStopAdjNY)

groupDispNY = "Displacement Filter - NY"
nyUseDisplacementFilter = input.bool(true, "NY Displacement Filter On", group=groupDispNY)
nyMinCloseBeyondPct     = input.float(0.17, "NY Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispNY)
nyMaxBreakoutWickPct    = input.float(0.20, "NY Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispNY)

groupAtrNY = "ATR Filter - NY"
nyUseAtrOrbFilter = input.bool(true, "NY ATR ORB Filter On", group=groupAtrNY)
atrLen            = input.int(14, "ATR Length (Global)", minval=1, group=groupAtrNY)
nyMinOrbAtrPct    = input.float(0.17, "NY Min ORB / ATR", minval=0.0, step=0.01, group=groupAtrNY)
nyMaxOrbAtrPct    = input.float(1.20, "NY Max ORB / ATR", minval=0.0, step=0.01, group=groupAtrNY)

groupPrevDayCompressionNY = "Previous Day Compression Filter - NY"
nyUsePrevDayCompressionFilter = input.bool(false, "NY Previous Day Compression Filter On", group=groupPrevDayCompressionNY)
nyMaxPrevDayRangeAtrPct       = input.float(0.80, "NY Max Previous Day Range / ATR", minval=0.0, step=0.01, group=groupPrevDayCompressionNY)

groupPrevDayTrendNY = "Previous Day Trend Alignment Filter - NY"
nyUsePrevDayTrendAlignment = input.bool(false, "NY Previous Day Trend Alignment On", group=groupPrevDayTrendNY)

groupTimeExitNY = "Time Exit - NY"
nyUseTimeExit              = input.bool(true, "NY Time Exit On", group=groupTimeExitNY)
nyMaxBarsInTrade           = input.int(48, "NY Max Bars In Trade", minval=1, maxval=500, group=groupTimeExitNY)
nyTimeExitMode             = input.string("Any", "NY Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExitNY)
nyResetTimeExitOnTrailStep = input.bool(false, "NY Reset Time Exit On Trail Step", group=groupTimeExitNY)

groupVolDecayNY = "Volatility Decay Exit - NY"
nyUseVolatilityDecayExit             = input.bool(true, "NY Volatility Decay Exit On", group=groupVolDecayNY)
nyVolDecayMinBarsInTrade             = input.int(4, "NY Min Bars Before Vol Decay Exit", minval=1, maxval=500, group=groupVolDecayNY)
nyVolDecayAtrCompressionThreshold    = input.float(0.75, "NY ATR Compression Threshold (Current ATR / Entry ATR)", minval=0.10, maxval=2.00, step=0.05, group=groupVolDecayNY)
nyVolDecayNoProgressBars             = input.int(3, "NY No Progress Bars Required", minval=1, maxval=100, group=groupVolDecayNY)
nyVolDecayOnlyWhenTrailActive        = input.bool(false, "NY Only When Step Trail Active", group=groupVolDecayNY)

// London
groupTradeLDN = "Trade Logic - London"
ldnTradeMode       = input.string("1R Step Trail", "London Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTradeLDN)
ldnRrMultiple      = input.float(2.0, "London Fixed RR Multiple", minval=0.5, step=0.5, group=groupTradeLDN)
ldnNoWickStrict    = input.bool(false, "London Strict: No wick back into ORB", group=groupTradeLDN)
ldnBreakoutMode    = input.string("Current Behavior", "London Breakout Qualification Mode", options=["Current Behavior", "First Qualified Close Only", "Reset Inside Then Requalify", "One-Bar Grace Then Reset"], group=groupTradeLDN)
ldnAllowSecondBreak = input.bool(false, "London Allow One Second Break After First Losing Trade + Reset Inside ORB", group=groupTradeLDN)

groupFollowLDN = "Follow-Through Confirmation Filter - London"
ldnUseFollowThroughConfirmation = input.bool(false, "London Immediate Follow-Through / Reclaim Filter On", group=groupFollowLDN)

groupRetestLDN = "Large Breakout Retest Mode - London"
ldnUseLargeBreakoutRetest   = input.bool(false, "London Large Breakout Retest On", group=groupRetestLDN)
ldnLargeBreakoutAtrThreshold = input.float(0.55, "London Large Breakout Candle / ATR Threshold", minval=0.0, step=0.01, group=groupRetestLDN)
ldnRetestLevelMode          = input.string("ORB Boundary", "London Retest Level", options=["ORB Boundary", "Breakout Midpoint"], group=groupRetestLDN)
ldnMaxRetestBars            = input.int(4, "London Max Bars To Wait For Retest", minval=1, maxval=20, group=groupRetestLDN)

groupStopAdjLDN = "Stop Adjustment - London"
ldnUseStopAdjustment = input.bool(true, "London Stop Adjustment On", group=groupStopAdjLDN)
ldnStopMultiplier    = input.float(1.85, "London Stop Multiplier", minval=0.1, step=0.05, group=groupStopAdjLDN)
ldnTrailRiskBasis    = input.string("Adjusted Stop Risk", "London Trail Risk Basis", options=["Adjusted Stop Risk", "Original Breakout Risk"], group=groupStopAdjLDN)

groupDispLDN = "Displacement Filter - London"
ldnUseDisplacementFilter = input.bool(true, "London Displacement Filter On", group=groupDispLDN)
ldnMinCloseBeyondPct     = input.float(0.17, "London Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispLDN)
ldnMaxBreakoutWickPct    = input.float(0.20, "London Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispLDN)

groupAtrLDN = "ATR Filter - London"
ldnUseAtrOrbFilter = input.bool(true, "London ATR ORB Filter On", group=groupAtrLDN)
ldnMinOrbAtrPct    = input.float(0.17, "London Min ORB / ATR", minval=0.0, step=0.01, group=groupAtrLDN)
ldnMaxOrbAtrPct    = input.float(1.20, "London Max ORB / ATR", minval=0.0, step=0.01, group=groupAtrLDN)

groupPrevDayCompressionLDN = "Previous Day Compression Filter - London"
ldnUsePrevDayCompressionFilter = input.bool(false, "London Previous Day Compression Filter On", group=groupPrevDayCompressionLDN)
ldnMaxPrevDayRangeAtrPct       = input.float(0.80, "London Max Previous Day Range / ATR", minval=0.0, step=0.01, group=groupPrevDayCompressionLDN)

groupPrevDayTrendLDN = "Previous Day Trend Alignment Filter - London"
ldnUsePrevDayTrendAlignment = input.bool(false, "London Previous Day Trend Alignment On", group=groupPrevDayTrendLDN)

groupTimeExitLDN = "Time Exit - London"
ldnUseTimeExit              = input.bool(true, "London Time Exit On", group=groupTimeExitLDN)
ldnMaxBarsInTrade           = input.int(24, "London Max Bars In Trade", minval=1, maxval=500, group=groupTimeExitLDN)
ldnTimeExitMode             = input.string("Any", "London Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExitLDN)
ldnResetTimeExitOnTrailStep = input.bool(false, "London Reset Time Exit On Trail Step", group=groupTimeExitLDN)

groupVolDecayLDN = "Volatility Decay Exit - London"
ldnUseVolatilityDecayExit             = input.bool(false, "London Volatility Decay Exit On", group=groupVolDecayLDN)
ldnVolDecayMinBarsInTrade             = input.int(6, "London Min Bars Before Vol Decay Exit", minval=1, maxval=500, group=groupVolDecayLDN)
ldnVolDecayAtrCompressionThreshold    = input.float(0.75, "London ATR Compression Threshold (Current ATR / Entry ATR)", minval=0.10, maxval=2.00, step=0.05, group=groupVolDecayLDN)
ldnVolDecayNoProgressBars             = input.int(3, "London No Progress Bars Required", minval=1, maxval=100, group=groupVolDecayLDN)
ldnVolDecayOnlyWhenTrailActive        = input.bool(true, "London Only When Step Trail Active", group=groupVolDecayLDN)

// Asia
groupTradeASIA = "Trade Logic - Asia"
asiaTradeMode       = input.string("1R Step Trail", "Asia Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTradeASIA)
asiaRrMultiple      = input.float(2.0, "Asia Fixed RR Multiple", minval=0.5, step=0.5, group=groupTradeASIA)
asiaNoWickStrict    = input.bool(false, "Asia Strict: No wick back into ORB", group=groupTradeASIA)
asiaBreakoutMode    = input.string("Current Behavior", "Asia Breakout Qualification Mode", options=["Current Behavior", "First Qualified Close Only", "Reset Inside Then Requalify", "One-Bar Grace Then Reset"], group=groupTradeASIA)
asiaAllowSecondBreak = input.bool(false, "Asia Allow One Second Break After First Losing Trade + Reset Inside ORB", group=groupTradeASIA)

groupFollowASIA = "Follow-Through Confirmation Filter - Asia"
asiaUseFollowThroughConfirmation = input.bool(false, "Asia Immediate Follow-Through / Reclaim Filter On", group=groupFollowASIA)

groupRetestASIA = "Large Breakout Retest Mode - Asia"
asiaUseLargeBreakoutRetest   = input.bool(false, "Asia Large Breakout Retest On", group=groupRetestASIA)
asiaLargeBreakoutAtrThreshold = input.float(0.55, "Asia Large Breakout Candle / ATR Threshold", minval=0.0, step=0.01, group=groupRetestASIA)
asiaRetestLevelMode          = input.string("ORB Boundary", "Asia Retest Level", options=["ORB Boundary", "Breakout Midpoint"], group=groupRetestASIA)
asiaMaxRetestBars            = input.int(4, "Asia Max Bars To Wait For Retest", minval=1, maxval=20, group=groupRetestASIA)

groupStopAdjASIA = "Stop Adjustment - Asia"
asiaUseStopAdjustment = input.bool(true, "Asia Stop Adjustment On", group=groupStopAdjASIA)
asiaStopMultiplier    = input.float(1.85, "Asia Stop Multiplier", minval=0.1, step=0.05, group=groupStopAdjASIA)
asiaTrailRiskBasis    = input.string("Adjusted Stop Risk", "Asia Trail Risk Basis", options=["Adjusted Stop Risk", "Original Breakout Risk"], group=groupStopAdjASIA)

groupDispASIA = "Displacement Filter - Asia"
asiaUseDisplacementFilter = input.bool(true, "Asia Displacement Filter On", group=groupDispASIA)
asiaMinCloseBeyondPct     = input.float(0.17, "Asia Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispASIA)
asiaMaxBreakoutWickPct    = input.float(0.20, "Asia Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDispASIA)

groupAtrASIA = "ATR Filter - Asia"
asiaUseAtrOrbFilter = input.bool(true, "Asia ATR ORB Filter On", group=groupAtrASIA)
asiaMinOrbAtrPct    = input.float(0.17, "Asia Min ORB / ATR", minval=0.0, step=0.01, group=groupAtrASIA)
asiaMaxOrbAtrPct    = input.float(1.20, "Asia Max ORB / ATR", minval=0.0, step=0.01, group=groupAtrASIA)

groupPrevDayCompressionASIA = "Previous Day Compression Filter - Asia"
asiaUsePrevDayCompressionFilter = input.bool(false, "Asia Previous Day Compression Filter On", group=groupPrevDayCompressionASIA)
asiaMaxPrevDayRangeAtrPct       = input.float(0.80, "Asia Max Previous Day Range / ATR", minval=0.0, step=0.01, group=groupPrevDayCompressionASIA)

groupPrevDayTrendASIA = "Previous Day Trend Alignment Filter - Asia"
asiaUsePrevDayTrendAlignment = input.bool(false, "Asia Previous Day Trend Alignment On", group=groupPrevDayTrendASIA)

groupTimeExitASIA = "Time Exit - Asia"
asiaUseTimeExit              = input.bool(true, "Asia Time Exit On", group=groupTimeExitASIA)
asiaMaxBarsInTrade           = input.int(24, "Asia Max Bars In Trade", minval=1, maxval=500, group=groupTimeExitASIA)
asiaTimeExitMode             = input.string("Any", "Asia Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExitASIA)
asiaResetTimeExitOnTrailStep = input.bool(false, "Asia Reset Time Exit On Trail Step", group=groupTimeExitASIA)

groupVolDecayASIA = "Volatility Decay Exit - Asia"
asiaUseVolatilityDecayExit             = input.bool(false, "Asia Volatility Decay Exit On", group=groupVolDecayASIA)
asiaVolDecayMinBarsInTrade             = input.int(6, "Asia Min Bars Before Vol Decay Exit", minval=1, maxval=500, group=groupVolDecayASIA)
asiaVolDecayAtrCompressionThreshold    = input.float(0.75, "Asia ATR Compression Threshold (Current ATR / Entry ATR)", minval=0.10, maxval=2.00, step=0.05, group=groupVolDecayASIA)
asiaVolDecayNoProgressBars             = input.int(3, "Asia No Progress Bars Required", minval=1, maxval=100, group=groupVolDecayASIA)
asiaVolDecayOnlyWhenTrailActive        = input.bool(true, "Asia Only When Step Trail Active", group=groupVolDecayASIA)

// optional tiny buffer so stops/targets aren’t exactly on a level
groupTradeGlobal = "Trade Logic - Global"
useBufferTicks = input.bool(false, "Use Tick Buffer", group=groupTradeGlobal)
bufferTicks    = input.int(1, "Buffer (ticks)", minval=0, maxval=20, group=groupTradeGlobal)

groupOvernight = "Overnight Range Filter"
useOvernightRangeFilter = input.bool(false, "NY Overnight Range Filter On", group=groupOvernight)
minOvernightAtrPct = input.float(0.00, "Min Overnight / ATR", minval=0.0, step=0.01, group=groupOvernight)
maxOvernightAtrPct = input.float(0.80, "Max Overnight / ATR", minval=0.0, step=0.01, group=groupOvernight)

groupEntryTime = "Entry Time Filter"

// =========================
// NY entry cutoff controls (NY local timezone)
// =========================
nyUseNoTradeAfter = input.bool(false, "NY: Don't Enter After Time (Global Default)", group=groupEntryTime)
nyLastEntryH      = input.int(11, "NY Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyLastEntryM      = input.int(0,  "NY Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyUseWeekdaySpecificCutoffs = input.bool(true, "NY: Use Weekday-Specific Cutoffs", group=groupEntryTime)

nyMonUseNoTradeAfter = input.bool(true, "NY Monday Override On", group=groupEntryTime)
nyMonLastEntryH      = input.int(11, "NY Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyMonLastEntryM      = input.int(0,  "NY Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyTueUseNoTradeAfter = input.bool(false, "NY Tuesday Override On", group=groupEntryTime)
nyTueLastEntryH      = input.int(11, "NY Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyTueLastEntryM      = input.int(0,  "NY Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyWedUseNoTradeAfter = input.bool(false, "NY Wednesday Override On", group=groupEntryTime)
nyWedLastEntryH      = input.int(11, "NY Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyWedLastEntryM      = input.int(0,  "NY Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyThuUseNoTradeAfter = input.bool(true, "NY Thursday Override On", group=groupEntryTime)
nyThuLastEntryH      = input.int(11, "NY Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyThuLastEntryM      = input.int(0,  "NY Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyFriUseNoTradeAfter = input.bool(false, "NY Friday Override On", group=groupEntryTime)
nyFriLastEntryH      = input.int(11, "NY Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyFriLastEntryM      = input.int(0,  "NY Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

// =========================
// London entry cutoff controls (London local timezone)
// =========================
ldnUseNoTradeAfter = input.bool(false, "London: Don't Enter After Time (Global Default)", group=groupEntryTime)
ldnLastEntryH      = input.int(10, "London Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnLastEntryM      = input.int(0,  "London Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnUseWeekdaySpecificCutoffs = input.bool(false, "London: Use Weekday-Specific Cutoffs", group=groupEntryTime)

ldnMonUseNoTradeAfter = input.bool(false, "London Monday Override On", group=groupEntryTime)
ldnMonLastEntryH      = input.int(10, "London Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnMonLastEntryM      = input.int(0,  "London Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnTueUseNoTradeAfter = input.bool(false, "London Tuesday Override On", group=groupEntryTime)
ldnTueLastEntryH      = input.int(10, "London Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnTueLastEntryM      = input.int(0,  "London Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnWedUseNoTradeAfter = input.bool(false, "London Wednesday Override On", group=groupEntryTime)
ldnWedLastEntryH      = input.int(10, "London Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnWedLastEntryM      = input.int(0,  "London Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnThuUseNoTradeAfter = input.bool(false, "London Thursday Override On", group=groupEntryTime)
ldnThuLastEntryH      = input.int(10, "London Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnThuLastEntryM      = input.int(0,  "London Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnFriUseNoTradeAfter = input.bool(false, "London Friday Override On", group=groupEntryTime)
ldnFriLastEntryH      = input.int(10, "London Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnFriLastEntryM      = input.int(0,  "London Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

// =========================
// Asia entry cutoff controls (Asia local timezone)
// =========================
asiaUseNoTradeAfter = input.bool(false, "Asia: Don't Enter After Time (Global Default)", group=groupEntryTime)
asiaLastEntryH      = input.int(11, "Asia Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaLastEntryM      = input.int(0,  "Asia Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaUseWeekdaySpecificCutoffs = input.bool(false, "Asia: Use Weekday-Specific Cutoffs", group=groupEntryTime)

asiaMonUseNoTradeAfter = input.bool(false, "Asia Monday Override On", group=groupEntryTime)
asiaMonLastEntryH      = input.int(11, "Asia Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaMonLastEntryM      = input.int(0,  "Asia Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaTueUseNoTradeAfter = input.bool(false, "Asia Tuesday Override On", group=groupEntryTime)
asiaTueLastEntryH      = input.int(11, "Asia Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaTueLastEntryM      = input.int(0,  "Asia Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaWedUseNoTradeAfter = input.bool(false, "Asia Wednesday Override On", group=groupEntryTime)
asiaWedLastEntryH      = input.int(11, "Asia Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaWedLastEntryM      = input.int(0,  "Asia Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaThuUseNoTradeAfter = input.bool(false, "Asia Thursday Override On", group=groupEntryTime)
asiaThuLastEntryH      = input.int(11, "Asia Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaThuLastEntryM      = input.int(0,  "Asia Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaFriUseNoTradeAfter = input.bool(false, "Asia Friday Override On", group=groupEntryTime)
asiaFriLastEntryH      = input.int(11, "Asia Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaFriLastEntryM      = input.int(0,  "Asia Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

groupEOD = "End Of Day Close"
useEodClose = input.bool(true, "Session Close On", group=groupEOD)

groupFilters = "Trade Filters"
skipDecember = input.bool(true, "Skip December", group=groupFilters)
skipThanksgivingWeek = input.bool(true, "Skip Thanksgiving Week", group=groupFilters)
skipUSHalfDays = input.bool(true, "Skip US Half Days (Approximation)", group=groupFilters)
skipMondays = input.bool(false, "Skip Mondays", group=groupFilters)
skipTuesdays = input.bool(false, "Skip Tuesdays", group=groupFilters)
skipWednesdays = input.bool(false, "Skip Wednesdays", group=groupFilters)
skipThursdays = input.bool(false, "Skip Thursdays", group=groupFilters)
skipFridays = input.bool(false, "Skip Fridays", group=groupFilters)
skipManualDates = input.string("", "Skip Dates (YYYY-MM-DD, comma-separated)", group=groupFilters)

groupDisplay = "Display"
showORBLevels                = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels                   = input.bool(true, "Show Entry Labels", group=groupDisplay)
showActiveStop               = input.bool(true, "Show Active Stop", group=groupDisplay)
showActiveTarget             = input.bool(true, "Show Active Target", group=groupDisplay)
showORBOnlyDuringTradeWindow = input.bool(true, "Show ORB Only During Trade Window", group=groupDisplay)

// =========================
// Debug inputs
// =========================
groupDebug = "Debug"
debugTradeOn = input.bool(true, "Debug Specific Trade", group=groupDebug)
debugTradeYear = input.int(2026, "Debug Year", minval=2000, maxval=2100, group=groupDebug)
debugTradeMonth = input.int(3, "Debug Month", minval=1, maxval=12, group=groupDebug)
debugTradeDay = input.int(2, "Debug Day", minval=1, maxval=31, group=groupDebug)
debugTradeHour = input.int(10, "Debug Entry Hour", minval=0, maxval=23, group=groupDebug)
debugTradeMinute = input.int(35, "Debug Entry Minute", minval=0, maxval=59, group=groupDebug)
debugTradeSession = input.string("NY", "Debug Session", options=["NY", "London", "Asia"], group=groupDebug)
debugTradeDirection = input.string("Long", "Debug Direction", options=["Long", "Short"], group=groupDebug)

// =========================
// Session-specific getters
// =========================
getTradeMode(sessionName) =>
    sessionName == "NY" ? nyTradeMode : sessionName == "London" ? ldnTradeMode : sessionName == "Asia" ? asiaTradeMode : nyTradeMode

getRrMultiple(sessionName) =>
    sessionName == "NY" ? nyRrMultiple : sessionName == "London" ? ldnRrMultiple : sessionName == "Asia" ? asiaRrMultiple : nyRrMultiple

getNoWickStrict(sessionName) =>
    sessionName == "NY" ? nyNoWickStrict : sessionName == "London" ? ldnNoWickStrict : sessionName == "Asia" ? asiaNoWickStrict : false

getBreakoutMode(sessionName) =>
    sessionName == "NY" ? nyBreakoutMode : sessionName == "London" ? ldnBreakoutMode : sessionName == "Asia" ? asiaBreakoutMode : "Current Behavior"

getAllowSecondBreak(sessionName) =>
    sessionName == "NY" ? nyAllowSecondBreak : sessionName == "London" ? ldnAllowSecondBreak : sessionName == "Asia" ? asiaAllowSecondBreak : false

getUseFollowThroughConfirmation(sessionName) =>
    sessionName == "NY" ? nyUseFollowThroughConfirmation : sessionName == "London" ? ldnUseFollowThroughConfirmation : sessionName == "Asia" ? asiaUseFollowThroughConfirmation : false

getUseLargeBreakoutRetest(sessionName) =>
    sessionName == "NY" ? nyUseLargeBreakoutRetest : sessionName == "London" ? ldnUseLargeBreakoutRetest : sessionName == "Asia" ? asiaUseLargeBreakoutRetest : false

getLargeBreakoutAtrThreshold(sessionName) =>
    sessionName == "NY" ? nyLargeBreakoutAtrThreshold : sessionName == "London" ? ldnLargeBreakoutAtrThreshold : sessionName == "Asia" ? asiaLargeBreakoutAtrThreshold : 0.55

getRetestLevelMode(sessionName) =>
    sessionName == "NY" ? nyRetestLevelMode : sessionName == "London" ? ldnRetestLevelMode : sessionName == "Asia" ? asiaRetestLevelMode : "ORB Boundary"

getMaxRetestBars(sessionName) =>
    sessionName == "NY" ? nyMaxRetestBars : sessionName == "London" ? ldnMaxRetestBars : sessionName == "Asia" ? asiaMaxRetestBars : 4

getUseStopAdjustment(sessionName) =>
    sessionName == "NY" ? nyUseStopAdjustment : sessionName == "London" ? ldnUseStopAdjustment : sessionName == "Asia" ? asiaUseStopAdjustment : true

getStopMultiplier(sessionName) =>
    sessionName == "NY" ? nyStopMultiplier : sessionName == "London" ? ldnStopMultiplier : sessionName == "Asia" ? asiaStopMultiplier : 1.85

getTrailRiskBasis(sessionName) =>
    sessionName == "NY" ? nyTrailRiskBasis : sessionName == "London" ? ldnTrailRiskBasis : sessionName == "Asia" ? asiaTrailRiskBasis : "Adjusted Stop Risk"

getUseDisplacementFilter(sessionName) =>
    sessionName == "NY" ? nyUseDisplacementFilter : sessionName == "London" ? ldnUseDisplacementFilter : sessionName == "Asia" ? asiaUseDisplacementFilter : true

getMinCloseBeyondPct(sessionName) =>
    sessionName == "NY" ? nyMinCloseBeyondPct : sessionName == "London" ? ldnMinCloseBeyondPct : sessionName == "Asia" ? asiaMinCloseBeyondPct : 0.17

getMaxBreakoutWickPct(sessionName) =>
    sessionName == "NY" ? nyMaxBreakoutWickPct : sessionName == "London" ? ldnMaxBreakoutWickPct : sessionName == "Asia" ? asiaMaxBreakoutWickPct : 0.20

getUseAtrOrbFilter(sessionName) =>
    sessionName == "NY" ? nyUseAtrOrbFilter : sessionName == "London" ? ldnUseAtrOrbFilter : sessionName == "Asia" ? asiaUseAtrOrbFilter : true

getMinOrbAtrPct(sessionName) =>
    sessionName == "NY" ? nyMinOrbAtrPct : sessionName == "London" ? ldnMinOrbAtrPct : sessionName == "Asia" ? asiaMinOrbAtrPct : 0.17

getMaxOrbAtrPct(sessionName) =>
    sessionName == "NY" ? nyMaxOrbAtrPct : sessionName == "London" ? ldnMaxOrbAtrPct : sessionName == "Asia" ? asiaMaxOrbAtrPct : 1.20

getUsePrevDayCompressionFilter(sessionName) =>
    sessionName == "NY" ? nyUsePrevDayCompressionFilter : sessionName == "London" ? ldnUsePrevDayCompressionFilter : sessionName == "Asia" ? asiaUsePrevDayCompressionFilter : false

getMaxPrevDayRangeAtrPct(sessionName) =>
    sessionName == "NY" ? nyMaxPrevDayRangeAtrPct : sessionName == "London" ? ldnMaxPrevDayRangeAtrPct : sessionName == "Asia" ? asiaMaxPrevDayRangeAtrPct : 0.80

getUsePrevDayTrendAlignment(sessionName) =>
    sessionName == "NY" ? nyUsePrevDayTrendAlignment : sessionName == "London" ? ldnUsePrevDayTrendAlignment : sessionName == "Asia" ? asiaUsePrevDayTrendAlignment : false

getUseTimeExit(sessionName) =>
    sessionName == "NY" ? nyUseTimeExit : sessionName == "London" ? ldnUseTimeExit : sessionName == "Asia" ? asiaUseTimeExit : true

getMaxBarsInTrade(sessionName) =>
    sessionName == "NY" ? nyMaxBarsInTrade : sessionName == "London" ? ldnMaxBarsInTrade : sessionName == "Asia" ? asiaMaxBarsInTrade : 24

getTimeExitMode(sessionName) =>
    sessionName == "NY" ? nyTimeExitMode : sessionName == "London" ? ldnTimeExitMode : sessionName == "Asia" ? asiaTimeExitMode : "Any"

getResetTimeExitOnTrailStep(sessionName) =>
    sessionName == "NY" ? nyResetTimeExitOnTrailStep : sessionName == "London" ? ldnResetTimeExitOnTrailStep : sessionName == "Asia" ? asiaResetTimeExitOnTrailStep : false

getUseVolatilityDecayExit(sessionName) =>
    sessionName == "NY" ? nyUseVolatilityDecayExit : sessionName == "London" ? ldnUseVolatilityDecayExit : sessionName == "Asia" ? asiaUseVolatilityDecayExit : false

getVolDecayMinBarsInTrade(sessionName) =>
    sessionName == "NY" ? nyVolDecayMinBarsInTrade : sessionName == "London" ? ldnVolDecayMinBarsInTrade : sessionName == "Asia" ? asiaVolDecayMinBarsInTrade : 6

getVolDecayAtrCompressionThreshold(sessionName) =>
    sessionName == "NY" ? nyVolDecayAtrCompressionThreshold : sessionName == "London" ? ldnVolDecayAtrCompressionThreshold : sessionName == "Asia" ? asiaVolDecayAtrCompressionThreshold : 0.75

getVolDecayNoProgressBars(sessionName) =>
    sessionName == "NY" ? nyVolDecayNoProgressBars : sessionName == "London" ? ldnVolDecayNoProgressBars : sessionName == "Asia" ? asiaVolDecayNoProgressBars : 3

getVolDecayOnlyWhenTrailActive(sessionName) =>
    sessionName == "NY" ? nyVolDecayOnlyWhenTrailActive : sessionName == "London" ? ldnVolDecayOnlyWhenTrailActive : sessionName == "Asia" ? asiaVolDecayOnlyWhenTrailActive : true

// =========================
// Entry rules (evaluated on CURRENT CHART timeframe)
// =========================
bodyCloseLong(sessionName, orbHigh) =>
    close > orbHigh and close > open and (not getNoWickStrict(sessionName) or low >= orbHigh)

bodyCloseShort(sessionName, orbLow) =>
    close < orbLow and close < open and (not getNoWickStrict(sessionName) or high <= orbLow)

displacementLong(sessionName, orbHigh) =>
    candleRange = high - low
    breakoutWick = high - close
    closeBeyond = close - orbHigh
    candleRange > 0 and closeBeyond >= candleRange * getMinCloseBeyondPct(sessionName) and breakoutWick <= candleRange * getMaxBreakoutWickPct(sessionName)

displacementShort(sessionName, orbLow) =>
    candleRange = high - low
    breakoutWick = close - low
    closeBeyond = orbLow - close
    candleRange > 0 and closeBeyond >= candleRange * getMinCloseBeyondPct(sessionName) and breakoutWick <= candleRange * getMaxBreakoutWickPct(sessionName)

entryLongOk(sessionName, orbHigh) =>
    bodyCloseLong(sessionName, orbHigh) and (not getUseDisplacementFilter(sessionName) or displacementLong(sessionName, orbHigh))

entryShortOk(sessionName, orbLow) =>
    bodyCloseShort(sessionName, orbLow) and (not getUseDisplacementFilter(sessionName) or displacementShort(sessionName, orbLow))

closeInsideOrb(orbHigh, orbLow) =>
    close <= orbHigh and close >= orbLow

closeAboveOrb(orbHigh) =>
    close > orbHigh

closeBelowOrb(orbLow) =>
    close < orbLow

followThroughLongOk(orbHigh, breakoutHigh, breakoutClose) =>
    close > orbHigh and high >= breakoutHigh and close >= breakoutClose

followThroughShortOk(orbLow, breakoutLow, breakoutClose) =>
    close < orbLow and low <= breakoutLow and close <= breakoutClose

minuteOfDay(h, m) =>
    h * 60 + m

inWindow(curMin, startMin, endMin) =>
    startMin <= endMin ? (curMin >= startMin and curMin <= endMin) : (curMin >= startMin or curMin <= endMin)

tradeWindowActive(tz, startH, startM, durM, endH, endM) =>
    int curH = hour(time, tz)
    int curM = minute(time, tz)
    int curMin = minuteOfDay(curH, curM)
    int orbEndMin = minuteOfDay(startH, startM) + durM
    int endMin = minuteOfDay(endH, endM)
    orbEndMin := orbEndMin % 1440
    inWindow(curMin, orbEndMin, endMin)

displayWindowActive(tz, startH, startM, endH, endM) =>
    int curH = hour(time, tz)
    int curM = minute(time, tz)
    int curMin = minuteOfDay(curH, curM)
    int startMin = minuteOfDay(startH, startM)
    int endMin = minuteOfDay(endH, endM)
    inWindow(curMin, startMin, endMin)

entryTimeAllowedWithWeekdayOverrides(
     tz,
     useNoTradeAfterGlobal,
     lastEntryHGlobal,
     lastEntryMGlobal,
     useWeekdaySpecific,
     monUse,
     monH,
     monM,
     tueUse,
     tueH,
     tueM,
     wedUse,
     wedH,
     wedM,
     thuUse,
     thuH,
     thuM,
     friUse,
     friH,
     friM) =>

    int curH = hour(time, tz)
    int curM = minute(time, tz)
    int curMin = minuteOfDay(curH, curM)
    int curDowLocal = dayofweek(time, tz)

    int globalCutoffMin = minuteOfDay(lastEntryHGlobal, lastEntryMGlobal)
    bool globalAllowed = not useNoTradeAfterGlobal or curMin <= globalCutoffMin

    int weekdayCutoffMin =
         curDowLocal == dayofweek.monday    ? minuteOfDay(monH, monM) :
         curDowLocal == dayofweek.tuesday   ? minuteOfDay(tueH, tueM) :
         curDowLocal == dayofweek.wednesday ? minuteOfDay(wedH, wedM) :
         curDowLocal == dayofweek.thursday  ? minuteOfDay(thuH, thuM) :
         curDowLocal == dayofweek.friday    ? minuteOfDay(friH, friM) :
         globalCutoffMin

    bool weekdayOverrideEnabled =
         curDowLocal == dayofweek.monday    ? monUse :
         curDowLocal == dayofweek.tuesday   ? tueUse :
         curDowLocal == dayofweek.wednesday ? wedUse :
         curDowLocal == dayofweek.thursday  ? thuUse :
         curDowLocal == dayofweek.friday    ? friUse :
         false

    useWeekdaySpecific and weekdayOverrideEnabled ? (curMin <= weekdayCutoffMin) : globalAllowed

dateToInt(y, mo, d) =>
    y * 10000 + mo * 100 + d

nthWeekdayDom(y, mo, targetDow, nth) =>
    int firstDow = dayofweek(timestamp(strategyDayTZ, y, mo, 1, 0, 0))
    int offset = (targetDow - firstDow + 7) % 7
    1 + offset + (nth - 1) * 7

isManualSkipDate(dateList, ymd) =>
    bool match = false
    arr = str.split(dateList, ",")
    for i = 0 to array.size(arr) - 1
        raw = array.get(arr, i)
        cleaned = str.replace_all(str.replace_all(raw, "-", ""), " ", "")
        val = str.tonumber(cleaned)
        if not na(val) and int(val) == ymd
            match := true
    match

getSessionTz(sessionName) =>
    sessionName == "NY" ? nyTZ : sessionName == "London" ? ldnTZ : sessionName == "Asia" ? asiaTZ : strategyDayTZ

getSessionCloseTs(sessionName) =>
    string tz = getSessionTz(sessionName)
    int y = year(time, tz)
    int mo = month(time, tz)
    int d = dayofmonth(time, tz)
    sessionName == "NY" ? timestamp(tz, y, mo, d, nyEndH, nyEndM) :
     sessionName == "London" ? timestamp(tz, y, mo, d, ldnEndH, ldnEndM) :
     sessionName == "Asia" ? timestamp(tz, y, mo, d, asiaEndH, asiaEndM) :
     na

sessionEntryAllowed(sessionName) =>
    sessionName == "NY" ? entryTimeAllowedWithWeekdayOverrides(nyTZ, nyUseNoTradeAfter, nyLastEntryH, nyLastEntryM, nyUseWeekdaySpecificCutoffs, nyMonUseNoTradeAfter, nyMonLastEntryH, nyMonLastEntryM, nyTueUseNoTradeAfter, nyTueLastEntryH, nyTueLastEntryM, nyWedUseNoTradeAfter, nyWedLastEntryH, nyWedLastEntryM, nyThuUseNoTradeAfter, nyThuLastEntryH, nyThuLastEntryM, nyFriUseNoTradeAfter, nyFriLastEntryH, nyFriLastEntryM) :
     sessionName == "London" ? entryTimeAllowedWithWeekdayOverrides(ldnTZ, ldnUseNoTradeAfter, ldnLastEntryH, ldnLastEntryM, ldnUseWeekdaySpecificCutoffs, ldnMonUseNoTradeAfter, ldnMonLastEntryH, ldnMonLastEntryM, ldnTueUseNoTradeAfter, ldnTueLastEntryH, ldnTueLastEntryM, ldnWedUseNoTradeAfter, ldnWedLastEntryH, ldnWedLastEntryM, ldnThuUseNoTradeAfter, ldnThuLastEntryH, ldnThuLastEntryM, ldnFriUseNoTradeAfter, ldnFriLastEntryH, ldnFriLastEntryM) :
     sessionName == "Asia" ? entryTimeAllowedWithWeekdayOverrides(asiaTZ, asiaUseNoTradeAfter, asiaLastEntryH, asiaLastEntryM, asiaUseWeekdaySpecificCutoffs, asiaMonUseNoTradeAfter, asiaMonLastEntryH, asiaMonLastEntryM, asiaTueUseNoTradeAfter, asiaTueLastEntryH, asiaTueLastEntryM, asiaWedUseNoTradeAfter, asiaWedLastEntryH, asiaWedLastEntryM, asiaThuUseNoTradeAfter, asiaThuLastEntryH, asiaThuLastEntryM, asiaFriUseNoTradeAfter, asiaFriLastEntryH, asiaFriLastEntryM) :
     true

orbAtrOk(sessionName, orbSize, atrValue) =>
    not getUseAtrOrbFilter(sessionName) or (not na(orbSize) and not na(atrValue) and atrValue > 0 and orbSize / atrValue >= getMinOrbAtrPct(sessionName) and orbSize / atrValue <= getMaxOrbAtrPct(sessionName))

prevDayCompressionOk(sessionName, prevDayRange, atrValue) =>
    not getUsePrevDayCompressionFilter(sessionName) or (not na(prevDayRange) and not na(atrValue) and atrValue > 0 and prevDayRange / atrValue <= getMaxPrevDayRangeAtrPct(sessionName))

prevDayTrendLongOk(sessionName, prevDayOpen, prevDayClose) =>
    not getUsePrevDayTrendAlignment(sessionName) or (not na(prevDayOpen) and not na(prevDayClose) and prevDayClose > prevDayOpen)

prevDayTrendShortOk(sessionName, prevDayOpen, prevDayClose) =>
    not getUsePrevDayTrendAlignment(sessionName) or (not na(prevDayOpen) and not na(prevDayClose) and prevDayClose < prevDayOpen)

overnightAtrOk(overnightSize, atrValue) =>
    not useOvernightRangeFilter or (not na(overnightSize) and not na(atrValue) and atrValue > 0 and overnightSize / atrValue >= minOvernightAtrPct and overnightSize / atrValue <= maxOvernightAtrPct)

breakoutIsLarge(sessionName, candleRange, atrValue) =>
    getUseLargeBreakoutRetest(sessionName) and not na(candleRange) and not na(atrValue) and atrValue > 0 and candleRange / atrValue >= getLargeBreakoutAtrThreshold(sessionName)

calcRetestLevel(sessionName, isLong, orbHigh, orbLow, breakoutHigh, breakoutLow) =>
    getRetestLevelMode(sessionName) == "ORB Boundary" ? (isLong ? orbHigh : orbLow) : ((breakoutHigh + breakoutLow) / 2.0)

// =========================
// Debug helpers
// =========================
isDebugTradeEntryMatch(entryTs, sessionName, direction) =>
    debugTradeOn and not na(entryTs) and year(entryTs, strategyDayTZ) == debugTradeYear and month(entryTs, strategyDayTZ) == debugTradeMonth and dayofmonth(entryTs, strategyDayTZ) == debugTradeDay and hour(entryTs, strategyDayTZ) == debugTradeHour and minute(entryTs, strategyDayTZ) == debugTradeMinute and sessionName == debugTradeSession and direction == debugTradeDirection

fmtBool(v) =>
    v ? "T" : "F"

fmtNum(v) =>
    na(v) ? "na" : str.tostring(v)

fmtNum4(v) =>
    na(v) ? "na" : str.tostring(v, "#.####")

pad2(v) =>
    v < 10 ? "0" + str.tostring(v) : str.tostring(v)

fmtTs(ts) =>
    na(ts) ? "na" :
     str.tostring(year(ts, strategyDayTZ)) + "-" +
     pad2(month(ts, strategyDayTZ)) + "-" +
     pad2(dayofmonth(ts, strategyDayTZ)) + " " +
     pad2(hour(ts, strategyDayTZ)) + ":" +
     pad2(minute(ts, strategyDayTZ))

// =========================
// ORB engine on 1m (range accuracy)
// =========================
orbLevels1m(tz, startH, startM, durM) =>
    int y  = year(time, tz)
    int mo = month(time, tz)
    int d  = dayofmonth(time, tz)
    int h  = hour(time, tz)
    int m  = minute(time, tz)
    int dayId = y * 10000 + mo * 100 + d
    int curMin   = h * 60 + m
    int startMin = startH * 60 + startM
    int endMin   = startMin + durM
    bool inOrb = curMin >= startMin and curMin < endMin
    var float hi = na
    var float lo = na
    var bool  ready = false
    var int   lastDayId = na
    if na(lastDayId) or dayId != lastDayId
        hi := na
        lo := na
        ready := false
        lastDayId := dayId
    bool startBar = inOrb and not inOrb[1]
    bool ended    = not inOrb and inOrb[1]
    if startBar
        hi := high
        lo := low
        ready := false
    else if inOrb
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low  : math.min(lo, low)
    if ended
        ready := true
    float outHi = (inOrb or ready) ? hi : na
    float outLo = (inOrb or ready) ? lo : na
    [outHi, outLo, ready, dayId]

overnightLevels1m(tz, startH, startM, prevEndH, prevEndM) =>
    int y  = year(time, tz)
    int mo = month(time, tz)
    int d  = dayofmonth(time, tz)
    int h  = hour(time, tz)
    int m  = minute(time, tz)
    int dayId = y * 10000 + mo * 100 + d
    int curMin = h * 60 + m
    int startMin = startH * 60 + startM
    int prevEndMin = prevEndH * 60 + prevEndM
    bool atPrevEnd = curMin == prevEndMin
    bool atStart = curMin == startMin
    bool inOvernight = curMin >= prevEndMin or curMin < startMin
    var float hi = na
    var float lo = na
    var bool ready = false
    var int readyDayId = na
    if atPrevEnd
        hi := high
        lo := low
        ready := false
        readyDayId := na
    else if inOvernight and not atStart
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low : math.min(lo, low)
    if atStart and not na(hi) and not na(lo)
        ready := true
        readyDayId := dayId
    float outHi = ready and readyDayId == dayId ? hi : na
    float outLo = ready and readyDayId == dayId ? lo : na
    [outHi, outLo, ready, readyDayId]

// Pull confirmed ORBs from 1m for strategy logic
[nyHigh, nyLow, nyReady, nyDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(nyTZ, nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_off)
[ldnHigh, ldnLow, ldnReady, ldnDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(ldnTZ, ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_off)
[asiaHigh, asiaLow, asiaReady, asiaDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(asiaTZ, asiaStartH, asiaStartM, asiaDurM), barmerge.gaps_off, barmerge.lookahead_off)

// Pull live ORBs from 1m for display only
[nyHighLive, nyLowLive, nyReadyLive, nyDayIdLive] = request.security(syminfo.tickerid, "1", orbLevels1m(nyTZ, nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_on)
[ldnHighLive, ldnLowLive, ldnReadyLive, ldnDayIdLive] = request.security(syminfo.tickerid, "1", orbLevels1m(ldnTZ, ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_on)
[asiaHighLive, asiaLowLive, asiaReadyLive, asiaDayIdLive] = request.security(syminfo.tickerid, "1", orbLevels1m(asiaTZ, asiaStartH, asiaStartM, asiaDurM), barmerge.gaps_off, barmerge.lookahead_on)

// Pull NY overnight range from 1m
[nyOverHigh, nyOverLow, nyOverReady, nyOverDayId] = request.security(syminfo.tickerid, "1", overnightLevels1m(nyTZ, nyStartH, nyStartM, nyEndH, nyEndM), barmerge.gaps_off, barmerge.lookahead_off)

// Daily ATR remains for structural filters
dailyAtrValue = request.security(syminfo.tickerid, "D", ta.atr(atrLen))
// Local/chart ATR is used for large breakout candle sizing
breakoutAtrLocal = ta.atr(atrLen)

prevDayHigh  = request.security(syminfo.tickerid, "D", high[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayLow   = request.security(syminfo.tickerid, "D", low[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayOpen  = request.security(syminfo.tickerid, "D", open[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayClose = request.security(syminfo.tickerid, "D", close[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayRange = not na(prevDayHigh) and not na(prevDayLow) ? prevDayHigh - prevDayLow : na

nyOrbSize = nyReady and not na(nyHigh) and not na(nyLow) ? nyHigh - nyLow : na
ldnOrbSize = ldnReady and not na(ldnHigh) and not na(ldnLow) ? ldnHigh - ldnLow : na
asiaOrbSize = asiaReady and not na(asiaHigh) and not na(asiaLow) ? asiaHigh - asiaLow : na
nyOvernightSize = nyOverReady and not na(nyOverHigh) and not na(nyOverLow) ? nyOverHigh - nyOverLow : na

// Calendar / trade filters
int curY = year(time, strategyDayTZ)
int curMo = month(time, strategyDayTZ)
int curD = dayofmonth(time, strategyDayTZ)
int curDow = dayofweek(time, strategyDayTZ)
int curYmd = dateToInt(curY, curMo, curD)
int thanksgivingDom = nthWeekdayDom(curY, 11, dayofweek.thursday, 4)
bool isDecember = curMo == 12
bool isThanksgivingWeek = curMo == 11 and curD >= thanksgivingDom - 3 and curD <= thanksgivingDom + 1
bool isDayAfterThanksgiving = curMo == 11 and curD == thanksgivingDom + 1
bool isChristmasEveHalfDay = curMo == 12 and curD == 24 and curDow >= dayofweek.monday and curDow <= dayofweek.friday
bool isJuly3HalfDay = curMo == 7 and curD == 3 and curDow >= dayofweek.monday and curDow <= dayofweek.friday
bool isUSHalfDay = isDayAfterThanksgiving or isChristmasEveHalfDay or isJuly3HalfDay
bool isSkippedWeekday = (skipMondays and curDow == dayofweek.monday) or (skipTuesdays and curDow == dayofweek.tuesday) or (skipWednesdays and curDow == dayofweek.wednesday) or (skipThursdays and curDow == dayofweek.thursday) or (skipFridays and curDow == dayofweek.friday)
bool isManualSkip = str.length(str.replace_all(skipManualDates, " ", "")) > 0 and isManualSkipDate(skipManualDates, curYmd)
bool skipToday = (skipDecember and isDecember) or (skipThanksgivingWeek and isThanksgivingWeek) or (skipUSHalfDays and isUSHalfDay) or isSkippedWeekday or isManualSkip
bool tradeDayAllowed = not skipToday

// Session trade windows
nyTradeWindowActive   = tradeDayAllowed and useNY and nyReady and tradeWindowActive(nyTZ, nyStartH, nyStartM, nyDurM, nyEndH, nyEndM)
ldnTradeWindowActive  = tradeDayAllowed and useLondon and ldnReady and tradeWindowActive(ldnTZ, ldnStartH, ldnStartM, ldnDurM, ldnEndH, ldnEndM)
asiaTradeWindowActive = tradeDayAllowed and useAsia and asiaReady and tradeWindowActive(asiaTZ, asiaStartH, asiaStartM, asiaDurM, asiaEndH, asiaEndM)

// Session display windows (start at ORB start, stop at that session's close)
nyDisplayWindow   = tradeDayAllowed and useNY and displayWindowActive(nyTZ, nyStartH, nyStartM, nyEndH, nyEndM)
ldnDisplayWindow  = tradeDayAllowed and useLondon and displayWindowActive(ldnTZ, ldnStartH, ldnStartM, ldnEndH, ldnEndM)
asiaDisplayWindow = tradeDayAllowed and useAsia and displayWindowActive(asiaTZ, asiaStartH, asiaStartM, asiaEndH, asiaEndM)

// Confirmed-bar gate for all trade-state logic
bool tradeLogicConfirmedBar = barstate.isconfirmed

// =========================
// One trade per session per day gating
// =========================
var int lastDay = na
var bool nyTraded = false
var bool ldnTraded = false
var bool asiaTraded = false
var bool nyLongNeedsReset = false
var bool nyShortNeedsReset = false
var bool ldnLongNeedsReset = false
var bool ldnShortNeedsReset = false
var bool asiaLongNeedsReset = false
var bool asiaShortNeedsReset = false
var bool nyLongDead = false
var bool nyShortDead = false
var bool ldnLongDead = false
var bool ldnShortDead = false
var bool asiaLongDead = false
var bool asiaShortDead = false
var int nyLongOutsideCount = 0
var int nyShortOutsideCount = 0
var int ldnLongOutsideCount = 0
var int ldnShortOutsideCount = 0
var int asiaLongOutsideCount = 0
var int asiaShortOutsideCount = 0

// Second-break state: actual trades only
var int nyLongTradeCount = 0
var int nyShortTradeCount = 0
var int ldnLongTradeCount = 0
var int ldnShortTradeCount = 0
var int asiaLongTradeCount = 0
var int asiaShortTradeCount = 0

var bool nyLongRetryEligible = false
var bool nyShortRetryEligible = false
var bool ldnLongRetryEligible = false
var bool ldnShortRetryEligible = false
var bool asiaLongRetryEligible = false
var bool asiaShortRetryEligible = false

var bool nyLongRetryArmed = false
var bool nyShortRetryArmed = false
var bool ldnLongRetryArmed = false
var bool ldnShortRetryArmed = false
var bool asiaLongRetryArmed = false
var bool asiaShortRetryArmed = false

// Pending confirmation state
var bool pendingConfirmActive = false
var string pendingConfirmSession = ""
var string pendingConfirmDirection = ""
var float pendingConfirmStop = na
var float pendingConfirmOrbHigh = na
var float pendingConfirmOrbLow = na
var float pendingConfirmBreakoutHigh = na
var float pendingConfirmBreakoutLow = na
var float pendingConfirmBreakoutClose = na
var int pendingConfirmBarIndex = na
var int pendingConfirmSessionCloseTs = na

// Pending retest state
var bool pendingRetestActive = false
var string pendingRetestSession = ""
var string pendingRetestDirection = ""
var float pendingRetestStop = na
var float pendingRetestLevel = na
var float pendingRetestOrbHigh = na
var float pendingRetestOrbLow = na
var int pendingRetestBarIndex = na
var int pendingRetestSessionCloseTs = na

// Debug persistent state
var int debugEntryTs = na
var int debugSignalTs = na
var int debugFillTs = na
var float debugAtrOnSignal = na
var float debugAtrOnFill = na
var float debugAtrOnNextBarAfterSignal = na
var bool debugTradeActive = false
var bool debugLastVolDecay = false
var bool debugLastTimeExit = false
var bool debugLastSessionCloseNow = false
var int debugLastBarsSinceProgress = na
var int debugLastBarsInTrade = na
var float debugLastAtrRatio = na
var bool debugExitTriggerLogged = false
var bool debugTradeLatched = false
var string debugLatchedSession = ""
var string debugLatchedDirection = ""
var table debugTable = table.new(position.top_right, 2, 22, border_width=1)

var int pendingSignalTs = na
var float pendingSignalAtr = na

// Exit-event debug snapshots
var float debugPrevClose = na
var float debugPrevBarsInTrade = na
var float debugPrevTimeExitBars = na
var float debugPrevBarsSinceProgress = na
var float debugPrevAtrAtEntry = na
var float debugPrevCurrentAtr = na
var float debugPrevAtrCompressionRatio = na
var bool debugPrevTimeExit = false
var bool debugPrevVolDecay = false
var bool debugPrevSessionClose = false
var float debugPrevActiveStop = na
var float debugPrevActiveTarget = na
var string debugPrevSession = ""
var string debugPrevDirection = ""

curDay = year(time, strategyDayTZ) * 10000 + month(time, strategyDayTZ) * 100 + dayofmonth(time, strategyDayTZ)

if na(lastDay) or curDay != lastDay
    nyTraded := false
    ldnTraded := false
    asiaTraded := false
    nyLongNeedsReset := false
    nyShortNeedsReset := false
    ldnLongNeedsReset := false
    ldnShortNeedsReset := false
    asiaLongNeedsReset := false
    asiaShortNeedsReset := false
    nyLongDead := false
    nyShortDead := false
    ldnLongDead := false
    ldnShortDead := false
    asiaLongDead := false
    asiaShortDead := false
    nyLongOutsideCount := 0
    nyShortOutsideCount := 0
    ldnLongOutsideCount := 0
    ldnShortOutsideCount := 0
    asiaLongOutsideCount := 0
    asiaShortOutsideCount := 0
    nyLongTradeCount := 0
    nyShortTradeCount := 0
    ldnLongTradeCount := 0
    ldnShortTradeCount := 0
    asiaLongTradeCount := 0
    asiaShortTradeCount := 0
    nyLongRetryEligible := false
    nyShortRetryEligible := false
    ldnLongRetryEligible := false
    ldnShortRetryEligible := false
    asiaLongRetryEligible := false
    asiaShortRetryEligible := false
    nyLongRetryArmed := false
    nyShortRetryArmed := false
    ldnLongRetryArmed := false
    ldnShortRetryArmed := false
    asiaLongRetryArmed := false
    asiaShortRetryArmed := false

    pendingConfirmActive := false
    pendingConfirmSession := ""
    pendingConfirmDirection := ""
    pendingConfirmStop := na
    pendingConfirmOrbHigh := na
    pendingConfirmOrbLow := na
    pendingConfirmBreakoutHigh := na
    pendingConfirmBreakoutLow := na
    pendingConfirmBreakoutClose := na
    pendingConfirmBarIndex := na
    pendingConfirmSessionCloseTs := na

    pendingRetestActive := false
    pendingRetestSession := ""
    pendingRetestDirection := ""
    pendingRetestStop := na
    pendingRetestLevel := na
    pendingRetestOrbHigh := na
    pendingRetestOrbLow := na
    pendingRetestBarIndex := na
    pendingRetestSessionCloseTs := na

    pendingSignalTs := na
    pendingSignalAtr := na
    debugSignalTs := na
    debugFillTs := na
    debugEntryTs := na
    debugAtrOnSignal := na
    debugAtrOnFill := na
    debugAtrOnNextBarAfterSignal := na
    debugTradeActive := false
    debugLastVolDecay := false
    debugLastTimeExit := false
    debugLastSessionCloseNow := false
    debugLastBarsSinceProgress := na
    debugLastBarsInTrade := na
    debugLastAtrRatio := na
    debugExitTriggerLogged := false
    debugTradeLatched := false
    debugLatchedSession := ""
    debugLatchedDirection := ""

    lastDay := curDay

// =========================
// Breakout state management
// =========================
nyLongPathActive   = nyTradeWindowActive   and not nyLongDead   and ((nyLongTradeCount == 0 and not nyTraded)   or (getAllowSecondBreak("NY") and nyLongTradeCount == 1 and nyLongRetryEligible))
nyShortPathActive  = nyTradeWindowActive   and not nyShortDead  and ((nyShortTradeCount == 0 and not nyTraded)  or (getAllowSecondBreak("NY") and nyShortTradeCount == 1 and nyShortRetryEligible))
ldnLongPathActive  = ldnTradeWindowActive  and not ldnLongDead  and ((ldnLongTradeCount == 0 and not ldnTraded) or (getAllowSecondBreak("London") and ldnLongTradeCount == 1 and ldnLongRetryEligible))
ldnShortPathActive = ldnTradeWindowActive  and not ldnShortDead and ((ldnShortTradeCount == 0 and not ldnTraded) or (getAllowSecondBreak("London") and ldnShortTradeCount == 1 and ldnShortRetryEligible))
asiaLongPathActive = asiaTradeWindowActive and not asiaLongDead and ((asiaLongTradeCount == 0 and not asiaTraded) or (getAllowSecondBreak("Asia") and asiaLongTradeCount == 1 and asiaLongRetryEligible))
asiaShortPathActive = asiaTradeWindowActive and not asiaShortDead and ((asiaShortTradeCount == 0 and not asiaTraded) or (getAllowSecondBreak("Asia") and asiaShortTradeCount == 1 and asiaShortRetryEligible))

if tradeLogicConfirmedBar and strategy.position_size == 0 and not pendingConfirmActive and not pendingRetestActive
    if nyLongPathActive
        if closeInsideOrb(nyHigh, nyLow)
            nyLongNeedsReset := false
            nyLongOutsideCount := 0
            if getAllowSecondBreak("NY") and nyLongRetryEligible and nyLongTradeCount == 1
                nyLongRetryArmed := true
        else if closeAboveOrb(nyHigh)
            if nyLongNeedsReset
                nyLongOutsideCount += 1
                if getBreakoutMode("NY") == "One-Bar Grace Then Reset" and nyLongOutsideCount > 1
                    nyLongDead := true

    if nyShortPathActive
        if closeInsideOrb(nyHigh, nyLow)
            nyShortNeedsReset := false
            nyShortOutsideCount := 0
            if getAllowSecondBreak("NY") and nyShortRetryEligible and nyShortTradeCount == 1
                nyShortRetryArmed := true
        else if closeBelowOrb(nyLow)
            if nyShortNeedsReset
                nyShortOutsideCount += 1
                if getBreakoutMode("NY") == "One-Bar Grace Then Reset" and nyShortOutsideCount > 1
                    nyShortDead := true

    if ldnLongPathActive
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnLongNeedsReset := false
            ldnLongOutsideCount := 0
            if getAllowSecondBreak("London") and ldnLongRetryEligible and ldnLongTradeCount == 1
                ldnLongRetryArmed := true
        else if closeAboveOrb(ldnHigh)
            if ldnLongNeedsReset
                ldnLongOutsideCount += 1
                if getBreakoutMode("London") == "One-Bar Grace Then Reset" and ldnLongOutsideCount > 1
                    ldnLongDead := true

    if ldnShortPathActive
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnShortNeedsReset := false
            ldnShortOutsideCount := 0
            if getAllowSecondBreak("London") and ldnShortRetryEligible and ldnShortTradeCount == 1
                ldnShortRetryArmed := true
        else if closeBelowOrb(ldnLow)
            if ldnShortNeedsReset
                ldnShortOutsideCount += 1
                if getBreakoutMode("London") == "One-Bar Grace Then Reset" and ldnShortOutsideCount > 1
                    ldnShortDead := true

    if asiaLongPathActive
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaLongNeedsReset := false
            asiaLongOutsideCount := 0
            if getAllowSecondBreak("Asia") and asiaLongRetryEligible and asiaLongTradeCount == 1
                asiaLongRetryArmed := true
        else if closeAboveOrb(asiaHigh)
            if asiaLongNeedsReset
                asiaLongOutsideCount += 1
                if getBreakoutMode("Asia") == "One-Bar Grace Then Reset" and asiaLongOutsideCount > 1
                    asiaLongDead := true

    if asiaShortPathActive
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaShortNeedsReset := false
            asiaShortOutsideCount := 0
            if getAllowSecondBreak("Asia") and asiaShortRetryEligible and asiaShortTradeCount == 1
                asiaShortRetryArmed := true
        else if closeBelowOrb(asiaLow)
            if asiaShortNeedsReset
                asiaShortOutsideCount += 1
                if getBreakoutMode("Asia") == "One-Bar Grace Then Reset" and asiaShortOutsideCount > 1
                    asiaShortDead := true

// =========================
// Entry permission logic by mode
// =========================
canConsiderLong(sessionName, ready, traded, dead, needsReset, orbHigh, tradeCount, retryArmed) =>
    bool firstTradeAllowed  = tradeCount == 0 and not traded
    bool secondTradeAllowed = getAllowSecondBreak(sessionName) and tradeCount == 1 and retryArmed
    ready and strategy.position_size == 0 and not dead and (firstTradeAllowed or secondTradeAllowed) and (
         getBreakoutMode(sessionName) == "Current Behavior" ? closeAboveOrb(orbHigh) :
         getBreakoutMode(sessionName) == "First Qualified Close Only" ? closeAboveOrb(orbHigh) and not needsReset :
         getBreakoutMode(sessionName) == "Reset Inside Then Requalify" ? closeAboveOrb(orbHigh) and not needsReset :
         getBreakoutMode(sessionName) == "One-Bar Grace Then Reset" ? closeAboveOrb(orbHigh) :
         false)

canConsiderShort(sessionName, ready, traded, dead, needsReset, orbLow, tradeCount, retryArmed) =>
    bool firstTradeAllowed  = tradeCount == 0 and not traded
    bool secondTradeAllowed = getAllowSecondBreak(sessionName) and tradeCount == 1 and retryArmed
    ready and strategy.position_size == 0 and not dead and (firstTradeAllowed or secondTradeAllowed) and (
         getBreakoutMode(sessionName) == "Current Behavior" ? closeBelowOrb(orbLow) :
         getBreakoutMode(sessionName) == "First Qualified Close Only" ? closeBelowOrb(orbLow) and not needsReset :
         getBreakoutMode(sessionName) == "Reset Inside Then Requalify" ? closeBelowOrb(orbLow) and not needsReset :
         getBreakoutMode(sessionName) == "One-Bar Grace Then Reset" ? closeBelowOrb(orbLow) :
         false)

// =========================
// Entry Logic
// =========================
float tick = syminfo.mintick
float buf  = useBufferTicks ? bufferTicks * tick : 0.0

var string activeORB = ""
var string pendingORB = ""
bool longSignal = false
bool shortSignal = false
float intendedStop = na
var int pendingSessionCloseTs = na

bool nyEntryTimeOk   = sessionEntryAllowed("NY")
bool ldnEntryTimeOk  = sessionEntryAllowed("London")
bool asiaEntryTimeOk = sessionEntryAllowed("Asia")

bool nyPrevDayCompressionPass   = prevDayCompressionOk("NY", prevDayRange, dailyAtrValue)
bool nyPrevDayTrendLongPass     = prevDayTrendLongOk("NY", prevDayOpen, prevDayClose)
bool nyPrevDayTrendShortPass    = prevDayTrendShortOk("NY", prevDayOpen, prevDayClose)

bool ldnPrevDayCompressionPass  = prevDayCompressionOk("London", prevDayRange, dailyAtrValue)
bool ldnPrevDayTrendLongPass    = prevDayTrendLongOk("London", prevDayOpen, prevDayClose)
bool ldnPrevDayTrendShortPass   = prevDayTrendShortOk("London", prevDayOpen, prevDayClose)

bool asiaPrevDayCompressionPass = prevDayCompressionOk("Asia", prevDayRange, dailyAtrValue)
bool asiaPrevDayTrendLongPass   = prevDayTrendLongOk("Asia", prevDayOpen, prevDayClose)
bool asiaPrevDayTrendShortPass  = prevDayTrendShortOk("Asia", prevDayOpen, prevDayClose)

nyLongCandidate   = nyEntryTimeOk and nyPrevDayCompressionPass and nyPrevDayTrendLongPass and nyTradeWindowActive and orbAtrOk("NY", nyOrbSize, dailyAtrValue) and overnightAtrOk(nyOvernightSize, dailyAtrValue) and canConsiderLong("NY", nyReady, nyTraded, nyLongDead, nyLongNeedsReset, nyHigh, nyLongTradeCount, nyLongRetryArmed)
nyShortCandidate  = nyEntryTimeOk and nyPrevDayCompressionPass and nyPrevDayTrendShortPass and nyTradeWindowActive and orbAtrOk("NY", nyOrbSize, dailyAtrValue) and overnightAtrOk(nyOvernightSize, dailyAtrValue) and canConsiderShort("NY", nyReady, nyTraded, nyShortDead, nyShortNeedsReset, nyLow, nyShortTradeCount, nyShortRetryArmed)

ldnLongCandidate  = ldnEntryTimeOk and ldnPrevDayCompressionPass and ldnPrevDayTrendLongPass and ldnTradeWindowActive and orbAtrOk("London", ldnOrbSize, dailyAtrValue) and canConsiderLong("London", ldnReady, ldnTraded, ldnLongDead, ldnLongNeedsReset, ldnHigh, ldnLongTradeCount, ldnLongRetryArmed)
ldnShortCandidate = ldnEntryTimeOk and ldnPrevDayCompressionPass and ldnPrevDayTrendShortPass and ldnTradeWindowActive and orbAtrOk("London", ldnOrbSize, dailyAtrValue) and canConsiderShort("London", ldnReady, ldnTraded, ldnShortDead, ldnShortNeedsReset, ldnLow, ldnShortTradeCount, ldnShortRetryArmed)

asiaLongCandidate = asiaEntryTimeOk and asiaPrevDayCompressionPass and asiaPrevDayTrendLongPass and asiaTradeWindowActive and orbAtrOk("Asia", asiaOrbSize, dailyAtrValue) and canConsiderLong("Asia", asiaReady, asiaTraded, asiaLongDead, asiaLongNeedsReset, asiaHigh, asiaLongTradeCount, asiaLongRetryArmed)
asiaShortCandidate = asiaEntryTimeOk and asiaPrevDayCompressionPass and asiaPrevDayTrendShortPass and asiaTradeWindowActive and orbAtrOk("Asia", asiaOrbSize, dailyAtrValue) and canConsiderShort("Asia", asiaReady, asiaTraded, asiaShortDead, asiaShortNeedsReset, asiaLow, asiaShortTradeCount, asiaShortRetryArmed)

// Raw breakout events on the breakout bar
nyLongBreakout   = nyLongCandidate and entryLongOk("NY", nyHigh)
nyShortBreakout  = nyShortCandidate and entryShortOk("NY", nyLow)
ldnLongBreakout  = ldnLongCandidate and entryLongOk("London", ldnHigh)
ldnShortBreakout = ldnShortCandidate and entryShortOk("London", ldnLow)
asiaLongBreakout = asiaLongCandidate and entryLongOk("Asia", asiaHigh)
asiaShortBreakout = asiaShortCandidate and entryShortOk("Asia", asiaLow)

// Mark failed breakout attempts based on mode
if tradeLogicConfirmedBar and strategy.position_size == 0 and not pendingConfirmActive and not pendingRetestActive
    if nyLongCandidate and not entryLongOk("NY", nyHigh)
        if getBreakoutMode("NY") == "First Qualified Close Only"
            nyLongDead := true
            nyLongNeedsReset := true
        else if getBreakoutMode("NY") == "Reset Inside Then Requalify"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0
        else if getBreakoutMode("NY") == "One-Bar Grace Then Reset"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0

    if nyShortCandidate and not entryShortOk("NY", nyLow)
        if getBreakoutMode("NY") == "First Qualified Close Only"
            nyShortDead := true
            nyShortNeedsReset := true
        else if getBreakoutMode("NY") == "Reset Inside Then Requalify"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0
        else if getBreakoutMode("NY") == "One-Bar Grace Then Reset"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0

    if ldnLongCandidate and not entryLongOk("London", ldnHigh)
        if getBreakoutMode("London") == "First Qualified Close Only"
            ldnLongDead := true
            ldnLongNeedsReset := true
        else if getBreakoutMode("London") == "Reset Inside Then Requalify"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0
        else if getBreakoutMode("London") == "One-Bar Grace Then Reset"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0

    if ldnShortCandidate and not entryShortOk("London", ldnLow)
        if getBreakoutMode("London") == "First Qualified Close Only"
            ldnShortDead := true
            ldnShortNeedsReset := true
        else if getBreakoutMode("London") == "Reset Inside Then Requalify"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0
        else if getBreakoutMode("London") == "One-Bar Grace Then Reset"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0

    if asiaLongCandidate and not entryLongOk("Asia", asiaHigh)
        if getBreakoutMode("Asia") == "First Qualified Close Only"
            asiaLongDead := true
            asiaLongNeedsReset := true
        else if getBreakoutMode("Asia") == "Reset Inside Then Requalify"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0
        else if getBreakoutMode("Asia") == "One-Bar Grace Then Reset"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0

    if asiaShortCandidate and not entryShortOk("Asia", asiaLow)
        if getBreakoutMode("Asia") == "First Qualified Close Only"
            asiaShortDead := true
            asiaShortNeedsReset := true
        else if getBreakoutMode("Asia") == "Reset Inside Then Requalify"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0
        else if getBreakoutMode("Asia") == "One-Bar Grace Then Reset"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0

// Determine breakout size for routing
float breakoutCandleRange = high - low

// large breakout detection now uses chart-timeframe ATR, not daily ATR
bool nyLongLargeBreakout   = nyLongBreakout and breakoutIsLarge("NY", breakoutCandleRange, breakoutAtrLocal)
bool nyShortLargeBreakout  = nyShortBreakout and breakoutIsLarge("NY", breakoutCandleRange, breakoutAtrLocal)
bool ldnLongLargeBreakout  = ldnLongBreakout and breakoutIsLarge("London", breakoutCandleRange, breakoutAtrLocal)
bool ldnShortLargeBreakout = ldnShortBreakout and breakoutIsLarge("London", breakoutCandleRange, breakoutAtrLocal)
bool asiaLongLargeBreakout = asiaLongBreakout and breakoutIsLarge("Asia", breakoutCandleRange, breakoutAtrLocal)
bool asiaShortLargeBreakout = asiaShortBreakout and breakoutIsLarge("Asia", breakoutCandleRange, breakoutAtrLocal)

// =========================
// Pending retest evaluation
// =========================
if tradeLogicConfirmedBar and pendingRetestActive and strategy.position_size == 0
    bool retestExpired = not na(pendingRetestBarIndex) and bar_index > pendingRetestBarIndex + getMaxRetestBars(pendingRetestSession)
    bool retestSameBarBlocked = not na(pendingRetestBarIndex) and bar_index <= pendingRetestBarIndex
    bool retestStoppedOut = pendingRetestDirection == "Long" ? low <= pendingRetestStop : high >= pendingRetestStop
    bool retestEntryTimeOk = sessionEntryAllowed(pendingRetestSession)

    if retestExpired or retestStoppedOut
        pendingRetestActive := false
        pendingRetestSession := ""
        pendingRetestDirection := ""
        pendingRetestStop := na
        pendingRetestLevel := na
        pendingRetestOrbHigh := na
        pendingRetestOrbLow := na
        pendingRetestBarIndex := na
        pendingRetestSessionCloseTs := na
    else if not retestSameBarBlocked and retestEntryTimeOk
        bool longRetestHit =
             pendingRetestDirection == "Long" and
             low <= pendingRetestLevel and
             close > pendingRetestLevel and
             close > open

        bool shortRetestHit =
             pendingRetestDirection == "Short" and
             high >= pendingRetestLevel and
             close < pendingRetestLevel and
             close < open

        if longRetestHit
            longSignal := true
            activeORB := pendingRetestSession
            pendingORB := pendingRetestSession
            pendingSessionCloseTs := pendingRetestSessionCloseTs
            intendedStop := pendingRetestStop
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal

            if pendingRetestSession == "NY"
                nyTraded := true
                nyLongTradeCount += 1
                nyLongRetryEligible := false
                nyLongRetryArmed := false
                nyLongNeedsReset := false
                nyLongDead := true
            else if pendingRetestSession == "London"
                ldnTraded := true
                ldnLongTradeCount += 1
                ldnLongRetryEligible := false
                ldnLongRetryArmed := false
                ldnLongNeedsReset := false
                ldnLongDead := true
            else if pendingRetestSession == "Asia"
                asiaTraded := true
                asiaLongTradeCount += 1
                asiaLongRetryEligible := false
                asiaLongRetryArmed := false
                asiaLongNeedsReset := false
                asiaLongDead := true

            pendingRetestActive := false
            pendingRetestSession := ""
            pendingRetestDirection := ""
            pendingRetestStop := na
            pendingRetestLevel := na
            pendingRetestOrbHigh := na
            pendingRetestOrbLow := na
            pendingRetestBarIndex := na
            pendingRetestSessionCloseTs := na

        else if shortRetestHit
            shortSignal := true
            activeORB := pendingRetestSession
            pendingORB := pendingRetestSession
            pendingSessionCloseTs := pendingRetestSessionCloseTs
            intendedStop := pendingRetestStop
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal

            if pendingRetestSession == "NY"
                nyTraded := true
                nyShortTradeCount += 1
                nyShortRetryEligible := false
                nyShortRetryArmed := false
                nyShortNeedsReset := false
                nyShortDead := true
            else if pendingRetestSession == "London"
                ldnTraded := true
                ldnShortTradeCount += 1
                ldnShortRetryEligible := false
                ldnShortRetryArmed := false
                ldnShortNeedsReset := false
                ldnShortDead := true
            else if pendingRetestSession == "Asia"
                asiaTraded := true
                asiaShortTradeCount += 1
                asiaShortRetryEligible := false
                asiaShortRetryArmed := false
                asiaShortNeedsReset := false
                asiaShortDead := true

            pendingRetestActive := false
            pendingRetestSession := ""
            pendingRetestDirection := ""
            pendingRetestStop := na
            pendingRetestLevel := na
            pendingRetestOrbHigh := na
            pendingRetestOrbLow := na
            pendingRetestBarIndex := na
            pendingRetestSessionCloseTs := na

// =========================
// Pending follow-through evaluation
// =========================
if tradeLogicConfirmedBar and pendingConfirmActive and strategy.position_size == 0 and not longSignal and not shortSignal
    bool confirmEntryTimeOk = sessionEntryAllowed(pendingConfirmSession)
    if not na(pendingConfirmBarIndex) and bar_index == pendingConfirmBarIndex + 1 and confirmEntryTimeOk
        bool confirmLong = pendingConfirmDirection == "Long" and followThroughLongOk(pendingConfirmOrbHigh, pendingConfirmBreakoutHigh, pendingConfirmBreakoutClose)
        bool confirmShort = pendingConfirmDirection == "Short" and followThroughShortOk(pendingConfirmOrbLow, pendingConfirmBreakoutLow, pendingConfirmBreakoutClose)

        if confirmLong
            longSignal := true
            activeORB := pendingConfirmSession
            pendingORB := pendingConfirmSession
            pendingSessionCloseTs := pendingConfirmSessionCloseTs
            intendedStop := pendingConfirmStop
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal

            if pendingConfirmSession == "NY"
                nyTraded := true
                nyLongTradeCount += 1
                nyLongRetryEligible := false
                nyLongRetryArmed := false
                nyLongNeedsReset := false
                nyLongDead := true
            else if pendingConfirmSession == "London"
                ldnTraded := true
                ldnLongTradeCount += 1
                ldnLongRetryEligible := false
                ldnLongRetryArmed := false
                ldnLongNeedsReset := false
                ldnLongDead := true
            else if pendingConfirmSession == "Asia"
                asiaTraded := true
                asiaLongTradeCount += 1
                asiaLongRetryEligible := false
                asiaLongRetryArmed := false
                asiaLongNeedsReset := false
                asiaLongDead := true

        else if confirmShort
            shortSignal := true
            activeORB := pendingConfirmSession
            pendingORB := pendingConfirmSession
            pendingSessionCloseTs := pendingConfirmSessionCloseTs
            intendedStop := pendingConfirmStop
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal

            if pendingConfirmSession == "NY"
                nyTraded := true
                nyShortTradeCount += 1
                nyShortRetryEligible := false
                nyShortRetryArmed := false
                nyShortNeedsReset := false
                nyShortDead := true
            else if pendingConfirmSession == "London"
                ldnTraded := true
                ldnShortTradeCount += 1
                ldnShortRetryEligible := false
                ldnShortRetryArmed := false
                ldnShortNeedsReset := false
                ldnShortDead := true
            else if pendingConfirmSession == "Asia"
                asiaTraded := true
                asiaShortTradeCount += 1
                asiaShortRetryEligible := false
                asiaShortRetryArmed := false
                asiaShortNeedsReset := false
                asiaShortDead := true
        else
            if pendingConfirmSession == "NY" and pendingConfirmDirection == "Long"
                if getBreakoutMode("NY") == "First Qualified Close Only"
                    nyLongDead := true
                    nyLongNeedsReset := true
                else if getBreakoutMode("NY") == "Reset Inside Then Requalify"
                    nyLongNeedsReset := true
                    nyLongOutsideCount := 0
                else if getBreakoutMode("NY") == "One-Bar Grace Then Reset"
                    nyLongNeedsReset := true
                    nyLongOutsideCount := 0

            if pendingConfirmSession == "NY" and pendingConfirmDirection == "Short"
                if getBreakoutMode("NY") == "First Qualified Close Only"
                    nyShortDead := true
                    nyShortNeedsReset := true
                else if getBreakoutMode("NY") == "Reset Inside Then Requalify"
                    nyShortNeedsReset := true
                    nyShortOutsideCount := 0
                else if getBreakoutMode("NY") == "One-Bar Grace Then Reset"
                    nyShortNeedsReset := true
                    nyShortOutsideCount := 0

            if pendingConfirmSession == "London" and pendingConfirmDirection == "Long"
                if getBreakoutMode("London") == "First Qualified Close Only"
                    ldnLongDead := true
                    ldnLongNeedsReset := true
                else if getBreakoutMode("London") == "Reset Inside Then Requalify"
                    ldnLongNeedsReset := true
                    ldnLongOutsideCount := 0
                else if getBreakoutMode("London") == "One-Bar Grace Then Reset"
                    ldnLongNeedsReset := true
                    ldnLongOutsideCount := 0

            if pendingConfirmSession == "London" and pendingConfirmDirection == "Short"
                if getBreakoutMode("London") == "First Qualified Close Only"
                    ldnShortDead := true
                    ldnShortNeedsReset := true
                else if getBreakoutMode("London") == "Reset Inside Then Requalify"
                    ldnShortNeedsReset := true
                    ldnShortOutsideCount := 0
                else if getBreakoutMode("London") == "One-Bar Grace Then Reset"
                    ldnShortNeedsReset := true
                    ldnShortOutsideCount := 0

            if pendingConfirmSession == "Asia" and pendingConfirmDirection == "Long"
                if getBreakoutMode("Asia") == "First Qualified Close Only"
                    asiaLongDead := true
                    asiaLongNeedsReset := true
                else if getBreakoutMode("Asia") == "Reset Inside Then Requalify"
                    asiaLongNeedsReset := true
                    asiaLongOutsideCount := 0
                else if getBreakoutMode("Asia") == "One-Bar Grace Then Reset"
                    asiaLongNeedsReset := true
                    asiaLongOutsideCount := 0

            if pendingConfirmSession == "Asia" and pendingConfirmDirection == "Short"
                if getBreakoutMode("Asia") == "First Qualified Close Only"
                    asiaShortDead := true
                    asiaShortNeedsReset := true
                else if getBreakoutMode("Asia") == "Reset Inside Then Requalify"
                    asiaShortNeedsReset := true
                    asiaShortOutsideCount := 0
                else if getBreakoutMode("Asia") == "One-Bar Grace Then Reset"
                    asiaShortNeedsReset := true
                    asiaShortOutsideCount := 0

        pendingConfirmActive := false
        pendingConfirmSession := ""
        pendingConfirmDirection := ""
        pendingConfirmStop := na
        pendingConfirmOrbHigh := na
        pendingConfirmOrbLow := na
        pendingConfirmBreakoutHigh := na
        pendingConfirmBreakoutLow := na
        pendingConfirmBreakoutClose := na
        pendingConfirmBarIndex := na
        pendingConfirmSessionCloseTs := na

// =========================
// New breakout routing
// Priority:
// 1) Large breakout retest
// 2) Follow-through confirmation
// 3) Immediate entry
// =========================
if tradeLogicConfirmedBar and strategy.position_size == 0 and not pendingRetestActive and not pendingConfirmActive and not longSignal and not shortSignal
    // 1) Large breakout retest path
    if getUseLargeBreakoutRetest("NY") or getUseLargeBreakoutRetest("London") or getUseLargeBreakoutRetest("Asia")
        if nyLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "NY"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel("NY", true, nyHigh, nyLow, high, low)
            pendingRetestOrbHigh := nyHigh
            pendingRetestOrbLow := nyLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("NY")
        else if nyShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "NY"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel("NY", false, nyHigh, nyLow, high, low)
            pendingRetestOrbHigh := nyHigh
            pendingRetestOrbLow := nyLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("NY")
        else if ldnLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "London"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel("London", true, ldnHigh, ldnLow, high, low)
            pendingRetestOrbHigh := ldnHigh
            pendingRetestOrbLow := ldnLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("London")
        else if ldnShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "London"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel("London", false, ldnHigh, ldnLow, high, low)
            pendingRetestOrbHigh := ldnHigh
            pendingRetestOrbLow := ldnLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("London")
        else if asiaLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "Asia"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel("Asia", true, asiaHigh, asiaLow, high, low)
            pendingRetestOrbHigh := asiaHigh
            pendingRetestOrbLow := asiaLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("Asia")
        else if asiaShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "Asia"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel("Asia", false, asiaHigh, asiaLow, high, low)
            pendingRetestOrbHigh := asiaHigh
            pendingRetestOrbLow := asiaLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("Asia")

    // 2) Follow-through confirmation path for non-large breakouts
    if not pendingRetestActive
        if getUseFollowThroughConfirmation("NY") and nyLongBreakout and not nyLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "NY"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := nyHigh
            pendingConfirmOrbLow := nyLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("NY")
        else if getUseFollowThroughConfirmation("NY") and nyShortBreakout and not nyShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "NY"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := nyHigh
            pendingConfirmOrbLow := nyLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("NY")
        else if getUseFollowThroughConfirmation("London") and ldnLongBreakout and not ldnLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "London"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := ldnHigh
            pendingConfirmOrbLow := ldnLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("London")
        else if getUseFollowThroughConfirmation("London") and ldnShortBreakout and not ldnShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "London"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := ldnHigh
            pendingConfirmOrbLow := ldnLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("London")
        else if getUseFollowThroughConfirmation("Asia") and asiaLongBreakout and not asiaLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "Asia"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := asiaHigh
            pendingConfirmOrbLow := asiaLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("Asia")
        else if getUseFollowThroughConfirmation("Asia") and asiaShortBreakout and not asiaShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "Asia"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := asiaHigh
            pendingConfirmOrbLow := asiaLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("Asia")

    // 3) Immediate entry path
    if not pendingRetestActive and not pendingConfirmActive
        bool allowImmediateNyLong = nyLongBreakout and not nyLongLargeBreakout
        bool allowImmediateNyShort = nyShortBreakout and not nyShortLargeBreakout
        bool allowImmediateLdnLong = ldnLongBreakout and not ldnLongLargeBreakout
        bool allowImmediateLdnShort = ldnShortBreakout and not ldnShortLargeBreakout
        bool allowImmediateAsiaLong = asiaLongBreakout and not asiaLongLargeBreakout
        bool allowImmediateAsiaShort = asiaShortBreakout and not asiaShortLargeBreakout

        if allowImmediateNyLong
            longSignal := true
            activeORB := "NY"
            pendingORB := "NY"
            pendingSessionCloseTs := getSessionCloseTs("NY")
            intendedStop := low - buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            nyTraded := true
            nyLongTradeCount += 1
            nyLongRetryEligible := false
            nyLongRetryArmed := false
            nyLongNeedsReset := false
            nyLongDead := true
        else if allowImmediateNyShort
            shortSignal := true
            activeORB := "NY"
            pendingORB := "NY"
            pendingSessionCloseTs := getSessionCloseTs("NY")
            intendedStop := high + buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            nyTraded := true
            nyShortTradeCount += 1
            nyShortRetryEligible := false
            nyShortRetryArmed := false
            nyShortNeedsReset := false
            nyShortDead := true
        else if allowImmediateLdnLong
            longSignal := true
            activeORB := "London"
            pendingORB := "London"
            pendingSessionCloseTs := getSessionCloseTs("London")
            intendedStop := low - buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            ldnTraded := true
            ldnLongTradeCount += 1
            ldnLongRetryEligible := false
            ldnLongRetryArmed := false
            ldnLongNeedsReset := false
            ldnLongDead := true
        else if allowImmediateLdnShort
            shortSignal := true
            activeORB := "London"
            pendingORB := "London"
            pendingSessionCloseTs := getSessionCloseTs("London")
            intendedStop := high + buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            ldnTraded := true
            ldnShortTradeCount += 1
            ldnShortRetryEligible := false
            ldnShortRetryArmed := false
            ldnShortNeedsReset := false
            ldnShortDead := true
        else if allowImmediateAsiaLong
            longSignal := true
            activeORB := "Asia"
            pendingORB := "Asia"
            pendingSessionCloseTs := getSessionCloseTs("Asia")
            intendedStop := low - buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            asiaTraded := true
            asiaLongTradeCount += 1
            asiaLongRetryEligible := false
            asiaLongRetryArmed := false
            asiaLongNeedsReset := false
            asiaLongDead := true
        else if allowImmediateAsiaShort
            shortSignal := true
            activeORB := "Asia"
            pendingORB := "Asia"
            pendingSessionCloseTs := getSessionCloseTs("Asia")
            intendedStop := high + buf
            pendingSignalTs := time
            pendingSignalAtr := breakoutAtrLocal
            asiaTraded := true
            asiaShortTradeCount += 1
            asiaShortRetryEligible := false
            asiaShortRetryArmed := false
            asiaShortNeedsReset := false
            asiaShortDead := true

if tradeLogicConfirmedBar and longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 0))

if tradeLogicConfirmedBar and shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Freeze entry/stop/risk on actual fill bar
// =========================
var float posStopRef = na
var float posEntry   = na
var float posRisk    = na
var float posBaseRisk = na
var float posTrailRisk = na
var float highestSinceEntry = na
var float lowestSinceEntry  = na
var int   entryBarIndex = na
var int   activeSessionCloseTs = na
var int   timeExitStartBarIndex = na
var int   lastTrailStepCount = 0
var string openTradeSession = ""
var string openTradeDirection = ""
var float atrAtEntry = na
var int lastProgressBarIndex = na

if tradeLogicConfirmedBar and (longSignal or shortSignal)
    posStopRef := intendedStop

newLong  = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
flatNow  = strategy.position_size == 0 and strategy.position_size[1] != 0

if flatNow
    closedTradePnl = strategy.netprofit - nz(strategy.netprofit[1])

    // Log the exact exit event BEFORE all state gets wiped.
    if debugTradeLatched
        string exitLog =
             "EXIT_EVENT" +
             " | BAR=" + fmtTs(time_close) +
             " | SIGNAL_TS=" + fmtTs(debugSignalTs) +
             " | FILL_TS=" + fmtTs(debugFillTs) +
             " | ENTRY_MATCH_TS=" + fmtTs(debugEntryTs) +
             " | SESSION=" + debugPrevSession +
             " | DIR=" + debugPrevDirection +
             " | prevClose=" + fmtNum(debugPrevClose) +
             " | prevBarsInTrade=" + fmtNum(debugPrevBarsInTrade) +
             " | prevTimeExitBars=" + fmtNum(debugPrevTimeExitBars) +
             " | prevBarsSinceProgress=" + fmtNum(debugPrevBarsSinceProgress) +
             " | prevAtrAtEntry=" + fmtNum4(debugPrevAtrAtEntry) +
             " | prevCurrentAtr=" + fmtNum4(debugPrevCurrentAtr) +
             " | prevAtrRatio=" + fmtNum4(debugPrevAtrCompressionRatio) +
             " | prevTimeExit=" + fmtBool(debugPrevTimeExit) +
             " | prevVolDecay=" + fmtBool(debugPrevVolDecay) +
             " | prevSessionClose=" + fmtBool(debugPrevSessionClose) +
             " | prevActiveStop=" + fmtNum(debugPrevActiveStop) +
             " | prevActiveTarget=" + fmtNum(debugPrevActiveTarget) +
             " | closedTradePnl=" + fmtNum(closedTradePnl)

        log.info(exitLog)

    debugTradeLatched := false
    debugLatchedSession := ""
    debugLatchedDirection := ""

    if getAllowSecondBreak(openTradeSession) and closedTradePnl < 0
        if openTradeSession == "NY" and openTradeDirection == "Long" and nyLongTradeCount == 1
            nyLongRetryEligible := true
            nyLongRetryArmed := false
            nyLongDead := false
            nyLongNeedsReset := false
            nyLongOutsideCount := 0
        else if openTradeSession == "NY" and openTradeDirection == "Short" and nyShortTradeCount == 1
            nyShortRetryEligible := true
            nyShortRetryArmed := false
            nyShortDead := false
            nyShortNeedsReset := false
            nyShortOutsideCount := 0
        else if openTradeSession == "London" and openTradeDirection == "Long" and ldnLongTradeCount == 1
            ldnLongRetryEligible := true
            ldnLongRetryArmed := false
            ldnLongDead := false
            ldnLongNeedsReset := false
            ldnLongOutsideCount := 0
        else if openTradeSession == "London" and openTradeDirection == "Short" and ldnShortTradeCount == 1
            ldnShortRetryEligible := true
            ldnShortRetryArmed := false
            ldnShortDead := false
            ldnShortNeedsReset := false
            ldnShortOutsideCount := 0
        else if openTradeSession == "Asia" and openTradeDirection == "Long" and asiaLongTradeCount == 1
            asiaLongRetryEligible := true
            asiaLongRetryArmed := false
            asiaLongDead := false
            asiaLongNeedsReset := false
            asiaLongOutsideCount := 0
        else if openTradeSession == "Asia" and openTradeDirection == "Short" and asiaShortTradeCount == 1
            asiaShortRetryEligible := true
            asiaShortRetryArmed := false
            asiaShortDead := false
            asiaShortNeedsReset := false
            asiaShortOutsideCount := 0

    posEntry := na
    posRisk := na
    posBaseRisk := na
    posTrailRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na
    activeORB := ""
    pendingORB := ""
    activeSessionCloseTs := na
    pendingSessionCloseTs := na
    timeExitStartBarIndex := na
    lastTrailStepCount := 0
    openTradeSession := ""
    openTradeDirection := ""
    atrAtEntry := na
    lastProgressBarIndex := na

    pendingSignalTs := na
    pendingSignalAtr := na
    debugSignalTs := na
    debugFillTs := na
    debugEntryTs := na
    debugAtrOnSignal := na
    debugAtrOnFill := na
    debugAtrOnNextBarAfterSignal := na
    debugTradeActive := false
    debugLastVolDecay := false
    debugLastTimeExit := false
    debugLastSessionCloseNow := false
    debugLastBarsSinceProgress := na
    debugLastBarsInTrade := na
    debugLastAtrRatio := na
    debugExitTriggerLogged := false

    debugPrevClose := na
    debugPrevBarsInTrade := na
    debugPrevTimeExitBars := na
    debugPrevBarsSinceProgress := na
    debugPrevAtrAtEntry := na
    debugPrevCurrentAtr := na
    debugPrevAtrCompressionRatio := na
    debugPrevTimeExit := false
    debugPrevVolDecay := false
    debugPrevSessionClose := false
    debugPrevActiveStop := na
    debugPrevActiveTarget := na
    debugPrevSession := ""
    debugPrevDirection := ""
else if strategy.position_size == 0
    posEntry := na
    posRisk := na
    posBaseRisk := na
    posTrailRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na
    activeORB := ""
    activeSessionCloseTs := na
    timeExitStartBarIndex := na
    lastTrailStepCount := 0
    atrAtEntry := na
    lastProgressBarIndex := na
    pendingSignalTs := na
    pendingSignalAtr := na
    debugLastVolDecay := false
    debugLastTimeExit := false
    debugLastSessionCloseNow := false
    debugLastBarsSinceProgress := na
    debugLastBarsInTrade := na
    debugLastAtrRatio := na
    debugExitTriggerLogged := false

if newLong
    posEntry := strategy.position_avg_price
    posBaseRisk := posEntry - posStopRef
    posRisk := getUseStopAdjustment(pendingORB) ? posBaseRisk * getStopMultiplier(pendingORB) : posBaseRisk
    posTrailRisk := getTradeMode(pendingORB) == "1R Step Trail" and getUseStopAdjustment(pendingORB) and getTrailRiskBasis(pendingORB) == "Original Breakout Risk" ? posBaseRisk : posRisk
    posStopRef := posEntry - posRisk
    highestSinceEntry := high
    entryBarIndex := bar_index
    activeORB := pendingORB
    activeSessionCloseTs := pendingSessionCloseTs
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := 0
    openTradeSession := pendingORB
    openTradeDirection := "Long"
    atrAtEntry := breakoutAtrLocal
    lastProgressBarIndex := bar_index
    debugExitTriggerLogged := false

    if isDebugTradeEntryMatch(nz(pendingSignalTs, time), pendingORB, "Long")
        debugSignalTs := pendingSignalTs
        debugFillTs := time
        debugEntryTs := nz(pendingSignalTs, time)
        debugAtrOnSignal := pendingSignalAtr
        debugAtrOnFill := breakoutAtrLocal
        debugTradeActive := true
        debugTradeLatched := true
        debugLatchedSession := pendingORB
        debugLatchedDirection := "Long"

if newShort
    posEntry := strategy.position_avg_price
    posBaseRisk := posStopRef - posEntry
    posRisk := getUseStopAdjustment(pendingORB) ? posBaseRisk * getStopMultiplier(pendingORB) : posBaseRisk
    posTrailRisk := getTradeMode(pendingORB) == "1R Step Trail" and getUseStopAdjustment(pendingORB) and getTrailRiskBasis(pendingORB) == "Original Breakout Risk" ? posBaseRisk : posRisk
    posStopRef := posEntry + posRisk
    lowestSinceEntry := low
    entryBarIndex := bar_index
    activeORB := pendingORB
    activeSessionCloseTs := pendingSessionCloseTs
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := 0
    openTradeSession := pendingORB
    openTradeDirection := "Short"
    atrAtEntry := breakoutAtrLocal
    lastProgressBarIndex := bar_index
    debugExitTriggerLogged := false

    if isDebugTradeEntryMatch(nz(pendingSignalTs, time), pendingORB, "Short")
        debugSignalTs := pendingSignalTs
        debugFillTs := time
        debugEntryTs := nz(pendingSignalTs, time)
        debugAtrOnSignal := pendingSignalAtr
        debugAtrOnFill := breakoutAtrLocal
        debugTradeActive := true
        debugTradeLatched := true
        debugLatchedSession := pendingORB
        debugLatchedDirection := "Short"

if debugTradeActive and not na(debugSignalTs) and na(debugAtrOnNextBarAfterSignal)
    if time > debugSignalTs
        debugAtrOnNextBarAfterSignal := breakoutAtrLocal

if strategy.position_size > 0
    float prevHighSinceEntry = highestSinceEntry
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)
    if na(prevHighSinceEntry) or high > prevHighSinceEntry
        lastProgressBarIndex := bar_index

if strategy.position_size < 0
    float prevLowSinceEntry = lowestSinceEntry
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)
    if na(prevLowSinceEntry) or low < prevLowSinceEntry
        lastProgressBarIndex := bar_index

validLong  = strategy.position_size > 0 and not na(posEntry) and not na(posRisk) and not na(posTrailRisk) and posRisk > 0 and posTrailRisk > 0 and not na(posStopRef)
validShort = strategy.position_size < 0 and not na(posEntry) and not na(posRisk) and not na(posTrailRisk) and posRisk > 0 and posTrailRisk > 0 and not na(posStopRef)

// =========================
// Helper state for trail activation
// =========================
curTradeMode = getTradeMode(openTradeSession)
curResetTimeExitOnTrailStep = getResetTimeExitOnTrailStep(openTradeSession)

longRunupR  = validLong ? math.floor((highestSinceEntry - posEntry) / posTrailRisk) : na
shortRunupR = validShort ? math.floor((posEntry - lowestSinceEntry) / posTrailRisk) : na

trailActiveLong  = validLong and curTradeMode == "1R Step Trail" and longRunupR >= 1
trailActiveShort = validShort and curTradeMode == "1R Step Trail" and shortRunupR >= 1

if validLong and curResetTimeExitOnTrailStep and curTradeMode == "1R Step Trail" and longRunupR >= 1 and longRunupR > lastTrailStepCount
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := longRunupR

if validShort and curResetTimeExitOnTrailStep and curTradeMode == "1R Step Trail" and shortRunupR >= 1 and shortRunupR > lastTrailStepCount
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := shortRunupR

// =========================
// Time Exit Logic
// =========================
barsInTrade = not na(entryBarIndex) ? (bar_index - entryBarIndex) : na
barsSinceTimeExitReset = not na(timeExitStartBarIndex) ? (bar_index - timeExitStartBarIndex) : na
timeExitBars = curResetTimeExitOnTrailStep and curTradeMode == "1R Step Trail" ? barsSinceTimeExitReset : barsInTrade
longInProfit  = validLong and close > posEntry
shortInProfit = validShort and close < posEntry

timeExitEligibleLong = true
timeExitEligibleShort = true

// use if you only want to time exit trades that are not in profit
// timeExitEligibleLong  = not longInProfit
// timeExitEligibleShort = not shortInProfit

// use if you want to only time exit non-trailing trades
// timeExitEligibleLong = not trailActiveLong
// timeExitEligibleShort = not trailActiveShort

timeExitLong = getUseTimeExit(openTradeSession) and validLong and timeExitEligibleLong and not na(timeExitBars) and timeExitBars >= getMaxBarsInTrade(openTradeSession) and (getTimeExitMode(openTradeSession) == "Any" or (getTimeExitMode(openTradeSession) == "Only In Profit" and longInProfit))
timeExitShort = getUseTimeExit(openTradeSession) and validShort and timeExitEligibleShort and not na(timeExitBars) and timeExitBars >= getMaxBarsInTrade(openTradeSession) and (getTimeExitMode(openTradeSession) == "Any" or (getTimeExitMode(openTradeSession) == "Only In Profit" and shortInProfit))

// =========================
// Volatility Decay Exit Logic
// =========================
currentAtr = breakoutAtrLocal
atrCompressionRatio = not na(atrAtEntry) and atrAtEntry > 0 ? currentAtr / atrAtEntry : na
barsSinceProgress = not na(lastProgressBarIndex) ? (bar_index - lastProgressBarIndex) : na

volDecayLong = getUseVolatilityDecayExit(openTradeSession) and validLong and longInProfit and not na(barsInTrade) and barsInTrade >= getVolDecayMinBarsInTrade(openTradeSession) and not na(atrCompressionRatio) and atrCompressionRatio <= getVolDecayAtrCompressionThreshold(openTradeSession) and not na(barsSinceProgress) and barsSinceProgress >= getVolDecayNoProgressBars(openTradeSession) and (not getVolDecayOnlyWhenTrailActive(openTradeSession) or trailActiveLong)

volDecayShort = getUseVolatilityDecayExit(openTradeSession) and validShort and shortInProfit and not na(barsInTrade) and barsInTrade >= getVolDecayMinBarsInTrade(openTradeSession) and not na(atrCompressionRatio) and atrCompressionRatio <= getVolDecayAtrCompressionThreshold(openTradeSession) and not na(barsSinceProgress) and barsSinceProgress >= getVolDecayNoProgressBars(openTradeSession) and (not getVolDecayOnlyWhenTrailActive(openTradeSession) or trailActiveShort)

// =========================
// Session-specific forced close logic
// =========================
sessionCloseNow = useEodClose and strategy.position_size != 0 and not na(activeSessionCloseTs) and time_close >= activeSessionCloseTs

// =========================
// Visible active stop / target levels
// =========================
float activeLongStop   = na
float activeShortStop  = na
float activeLongTarget = na
float activeShortTarget = na

if validLong
    if curTradeMode == "Fixed RR"
        activeLongStop   := posStopRef
        activeLongTarget := posEntry + posRisk * getRrMultiple(openTradeSession)
    else
        activeLongStop := longRunupR < 1 ? posStopRef : posEntry + (longRunupR - 1) * posTrailRisk

if validShort
    if curTradeMode == "Fixed RR"
        activeShortStop   := posStopRef
        activeShortTarget := posEntry - posRisk * getRrMultiple(openTradeSession)
    else
        activeShortStop := shortRunupR < 1 ? posStopRef : posEntry - (shortRunupR - 1) * posTrailRisk

// =========================
// Debug logging / table
// =========================
debugThisBar = debugTradeLatched and strategy.position_size != 0 and openTradeSession == debugLatchedSession and openTradeDirection == debugLatchedDirection

if debugThisBar and barstate.isconfirmed
    bool dbgValidLong = validLong
    bool dbgValidShort = validShort
    bool dbgTrailActive = dbgValidLong ? trailActiveLong : dbgValidShort ? trailActiveShort : false
    bool dbgTimeExit = dbgValidLong ? timeExitLong : dbgValidShort ? timeExitShort : false
    bool dbgVolDecay = dbgValidLong ? volDecayLong : dbgValidShort ? volDecayShort : false
    bool dbgInProfit = dbgValidLong ? longInProfit : dbgValidShort ? shortInProfit : false
    float dbgActiveStop = dbgValidLong ? activeLongStop : dbgValidShort ? activeShortStop : na
    float dbgActiveTarget = dbgValidLong ? activeLongTarget : dbgValidShort ? activeShortTarget : na
    float dbgRunupR = dbgValidLong ? longRunupR : dbgValidShort ? shortRunupR : na

    // Snapshot the most recent fully-known in-trade state so flatNow can log it.
    debugPrevClose := close
    debugPrevBarsInTrade := barsInTrade
    debugPrevTimeExitBars := timeExitBars
    debugPrevBarsSinceProgress := barsSinceProgress
    debugPrevAtrAtEntry := atrAtEntry
    debugPrevCurrentAtr := currentAtr
    debugPrevAtrCompressionRatio := atrCompressionRatio
    debugPrevTimeExit := dbgTimeExit
    debugPrevVolDecay := dbgVolDecay
    debugPrevSessionClose := sessionCloseNow
    debugPrevActiveStop := dbgActiveStop
    debugPrevActiveTarget := dbgActiveTarget
    debugPrevSession := openTradeSession
    debugPrevDirection := openTradeDirection

    bool shouldLogStateChange =
         na(debugLastBarsInTrade) or barsInTrade != debugLastBarsInTrade or
         na(debugLastBarsSinceProgress) or barsSinceProgress != debugLastBarsSinceProgress or
         na(debugLastAtrRatio) or math.abs(atrCompressionRatio - debugLastAtrRatio) >= 0.01 or
         dbgVolDecay != debugLastVolDecay or
         dbgTimeExit != debugLastTimeExit or
         sessionCloseNow != debugLastSessionCloseNow

    if shouldLogStateChange
        string logLine =
             "BAR=" + fmtTs(time_close) +
             " | SIGNAL_TS=" + fmtTs(debugSignalTs) +
             " | FILL_TS=" + fmtTs(debugFillTs) +
             " | ENTRY_MATCH_TS=" + fmtTs(debugEntryTs) +
             " | SESSION=" + openTradeSession +
             " | DIR=" + openTradeDirection +
             " | barsInTrade=" + fmtNum(barsInTrade) +
             " | timeExitBars=" + fmtNum(timeExitBars) +
             " | barsSinceProgress=" + fmtNum(barsSinceProgress) +
             " | lastProgressBarIndex=" + fmtNum(lastProgressBarIndex) +
             " | entryBarIndex=" + fmtNum(entryBarIndex) +
             " | entry=" + fmtNum(posEntry) +
             " | close=" + fmtNum(close) +
             " | high=" + fmtNum(high) +
             " | low=" + fmtNum(low) +
             " | pendingSignalTs=" + fmtTs(pendingSignalTs) +
             " | atrSignal=" + fmtNum4(debugAtrOnSignal) +
             " | atrFill=" + fmtNum4(debugAtrOnFill) +
             " | atrNextBar=" + fmtNum4(debugAtrOnNextBarAfterSignal) +
             " | atrAtEntry=" + fmtNum4(atrAtEntry) +
             " | rawBreakoutAtr=" + fmtNum4(breakoutAtrLocal) +
             " | currentAtr=" + fmtNum4(currentAtr) +
             " | atrRatio=" + fmtNum4(atrCompressionRatio) +
             " | runupR=" + fmtNum(dbgRunupR) +
             " | trailActive=" + fmtBool(dbgTrailActive) +
             " | inProfit=" + fmtBool(dbgInProfit) +
             " | activeStop=" + fmtNum(dbgActiveStop) +
             " | activeTarget=" + fmtNum(dbgActiveTarget) +
             " | timeExit=" + fmtBool(dbgTimeExit) +
             " | volDecay=" + fmtBool(dbgVolDecay) +
             " | sessionCloseNow=" + fmtBool(sessionCloseNow)

        log.info(logLine)

    debugLastBarsInTrade := barsInTrade
    debugLastBarsSinceProgress := barsSinceProgress
    debugLastAtrRatio := atrCompressionRatio
    debugLastVolDecay := dbgVolDecay
    debugLastTimeExit := dbgTimeExit
    debugLastSessionCloseNow := sessionCloseNow

    table.cell(debugTable, 0, 0, "Field", text_color=color.white, bgcolor=color.black)
    table.cell(debugTable, 1, 0, "Value", text_color=color.white, bgcolor=color.black)

    table.cell(debugTable, 0, 1, "Bar Time")
    table.cell(debugTable, 1, 1, fmtTs(time_close))

    table.cell(debugTable, 0, 2, "Entry Time")
    table.cell(debugTable, 1, 2, fmtTs(debugEntryTs))

    table.cell(debugTable, 0, 3, "barsInTrade")
    table.cell(debugTable, 1, 3, fmtNum(barsInTrade))

    table.cell(debugTable, 0, 4, "timeExitBars")
    table.cell(debugTable, 1, 4, fmtNum(timeExitBars))

    table.cell(debugTable, 0, 5, "barsSinceProgress")
    table.cell(debugTable, 1, 5, fmtNum(barsSinceProgress))

    table.cell(debugTable, 0, 6, "Entry")
    table.cell(debugTable, 1, 6, fmtNum(posEntry))

    table.cell(debugTable, 0, 7, "Close")
    table.cell(debugTable, 1, 7, fmtNum(close))

    table.cell(debugTable, 0, 8, "ATR@Entry")
    table.cell(debugTable, 1, 8, fmtNum4(atrAtEntry))

    table.cell(debugTable, 0, 9, "Current ATR")
    table.cell(debugTable, 1, 9, fmtNum4(currentAtr))

    table.cell(debugTable, 0, 10, "ATR Ratio")
    table.cell(debugTable, 1, 10, fmtNum4(atrCompressionRatio))

    table.cell(debugTable, 0, 11, "Trail Active")
    table.cell(debugTable, 1, 11, dbgValidLong ? fmtBool(trailActiveLong) : dbgValidShort ? fmtBool(trailActiveShort) : "F")

    table.cell(debugTable, 0, 12, "In Profit")
    table.cell(debugTable, 1, 12, dbgValidLong ? fmtBool(longInProfit) : dbgValidShort ? fmtBool(shortInProfit) : "F")

    table.cell(debugTable, 0, 13, "Time Exit")
    table.cell(debugTable, 1, 13, dbgValidLong ? fmtBool(timeExitLong) : dbgValidShort ? fmtBool(timeExitShort) : "F")

    table.cell(debugTable, 0, 14, "Vol Decay")
    table.cell(debugTable, 1, 14, dbgValidLong ? fmtBool(volDecayLong) : dbgValidShort ? fmtBool(volDecayShort) : "F")

    table.cell(debugTable, 0, 15, "Signal TS")
    table.cell(debugTable, 1, 15, fmtTs(debugSignalTs))

    table.cell(debugTable, 0, 16, "Fill TS")
    table.cell(debugTable, 1, 16, fmtTs(debugFillTs))

    table.cell(debugTable, 0, 17, "ATR Signal/Fill")
    table.cell(debugTable, 1, 17, fmtNum4(debugAtrOnSignal) + " / " + fmtNum4(debugAtrOnFill))

    table.cell(debugTable, 0, 18, "ATR Next Bar")
    table.cell(debugTable, 1, 18, fmtNum4(debugAtrOnNextBarAfterSignal))

    table.cell(debugTable, 0, 19, "Debug Active")
    table.cell(debugTable, 1, 19, fmtBool(debugTradeActive))

    table.cell(debugTable, 0, 20, "Last Progress Bar")
    table.cell(debugTable, 1, 20, fmtNum(lastProgressBarIndex))

    table.cell(debugTable, 0, 21, "Entry Bar Index")
    table.cell(debugTable, 1, 21, fmtNum(entryBarIndex))
else if barstate.isconfirmed
    for r = 0 to 21
        table.cell(debugTable, 0, r, "")
        table.cell(debugTable, 1, r, "")

// =========================
// Exit Logic
// =========================
if debugTradeActive and strategy.position_size != 0 and barstate.isconfirmed and not debugExitTriggerLogged
    string triggerReason =
         timeExitLong or timeExitShort ? "Time Exit" :
         volDecayLong or volDecayShort ? "Vol Decay Exit" :
         sessionCloseNow ? "Session Close" :
         na

    if not na(triggerReason)
        string triggerLog =
             "EXIT_TRIGGER" +
             " | BAR=" + fmtTs(time_close) +
             " | SIGNAL_TS=" + fmtTs(debugSignalTs) +
             " | FILL_TS=" + fmtTs(debugFillTs) +
             " | ENTRY_MATCH_TS=" + fmtTs(debugEntryTs) +
             " | SESSION=" + openTradeSession +
             " | DIR=" + openTradeDirection +
             " | REASON=" + triggerReason +
             " | barsInTrade=" + fmtNum(barsInTrade) +
             " | timeExitBars=" + fmtNum(timeExitBars) +
             " | barsSinceProgress=" + fmtNum(barsSinceProgress) +
             " | lastProgressBarIndex=" + fmtNum(lastProgressBarIndex) +
             " | entryBarIndex=" + fmtNum(entryBarIndex) +
             " | entry=" + fmtNum(posEntry) +
             " | close=" + fmtNum(close) +
             " | currentAtr=" + fmtNum4(currentAtr) +
             " | atrAtEntry=" + fmtNum4(atrAtEntry) +
             " | atrRatio=" + fmtNum4(atrCompressionRatio) +
             " | inProfit=" + fmtBool(longInProfit or shortInProfit) +
             " | trailActive=" + fmtBool(trailActiveLong or trailActiveShort) +
             " | activeStop=" + fmtNum(strategy.position_size > 0 ? activeLongStop : activeShortStop) +
             " | activeTarget=" + fmtNum(strategy.position_size > 0 ? activeLongTarget : activeShortTarget) +
             " | timeExit=" + fmtBool(timeExitLong or timeExitShort) +
             " | volDecay=" + fmtBool(volDecayLong or volDecayShort) +
             " | sessionCloseNow=" + fmtBool(sessionCloseNow)

        log.info(triggerLog)
        debugExitTriggerLogged := true

if validLong
    strategy.exit("Long Exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if validShort
    strategy.exit("Short Exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

if timeExitLong
    strategy.close("Long", comment="Time Exit")

if timeExitShort
    strategy.close("Short", comment="Time Exit")

if volDecayLong
    strategy.close("Long", comment="Vol Decay Exit")

if volDecayShort
    strategy.close("Short", comment="Vol Decay Exit")

if sessionCloseNow and strategy.position_size > 0
    strategy.close("Long", comment="Session Close")

if sessionCloseNow and strategy.position_size < 0
    strategy.close("Short", comment="Session Close")

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and tradeDayAllowed and useNY and (not showORBOnlyDuringTradeWindow or nyDisplayWindow) ? nyHighLive : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useNY and (not showORBOnlyDuringTradeWindow or nyDisplayWindow) ? nyLowLive  : na, "NY ORB Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and tradeDayAllowed and useLondon and (not showORBOnlyDuringTradeWindow or ldnDisplayWindow) ? ldnHighLive : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useLondon and (not showORBOnlyDuringTradeWindow or ldnDisplayWindow) ? ldnLowLive  : na, "London ORB Low", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and tradeDayAllowed and useAsia and (not showORBOnlyDuringTradeWindow or asiaDisplayWindow) ? asiaHighLive : na, "Asia ORB High", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useAsia and (not showORBOnlyDuringTradeWindow or asiaDisplayWindow) ? asiaLowLive  : na, "Asia ORB Low", color=color.new(color.purple, 0), linewidth=2, style=plot.style_linebr)

// Pending visuals
plot(pendingRetestActive and pendingRetestDirection == "Long" ? pendingRetestLevel : na, "Pending Long Retest", color=color.new(color.green, 40), linewidth=2, style=plot.style_linebr)
plot(pendingRetestActive and pendingRetestDirection == "Short" ? pendingRetestLevel : na, "Pending Short Retest", color=color.new(color.red, 40), linewidth=2, style=plot.style_linebr)

// =========================
// Plot active stop / target
// =========================
plot(showActiveStop and validLong ? activeLongStop : na, "Long Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)
plot(showActiveStop and validShort ? activeShortStop : na, "Short Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)
plot(showActiveTarget and curTradeMode == "Fixed RR" and validLong ? activeLongTarget : na, "Long Target", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(showActiveTarget and curTradeMode == "Fixed RR" and validShort ? activeShortTarget : na, "Short Target", color=color.new(color.maroon, 0), linewidth=2, style=plot.style_linebr)
