//@version=5
strategy("15m ORB Backtest - NY / London (ORB 1m, Entry TF) - SL=Breakout Candle", overlay=true, pyramiding=0,
     initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.0,
     process_orders_on_close=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
sessionTZ  = input.string("America/New_York", "Session Timezone", group=groupSessions)

// ORB windows by clock time + duration (minutes)
nyStartH   = input.int(9,  "NY Start Hour",   minval=0, maxval=23, group=groupSessions)
nyStartM   = input.int(30, "NY Start Minute", minval=0, maxval=59, group=groupSessions)
nyDurM     = input.int(15, "NY ORB Minutes",  minval=1, maxval=120, group=groupSessions)

ldnStartH  = input.int(3,  "London Start Hour",   minval=0, maxval=23, group=groupSessions)
ldnStartM  = input.int(0,  "London Start Minute", minval=0, maxval=59, group=groupSessions)
ldnDurM    = input.int(15, "London ORB Minutes",  minval=1, maxval=120, group=groupSessions)

groupTrade = "Trade Logic"
tradeMode    = input.string("Fixed RR", "Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTrade)
rrMultiple   = input.float(2.0, "Fixed RR Multiple", minval=0.5, step=0.5, group=groupTrade)
noWickStrict = input.bool(false, "Strict: No wick back into ORB", group=groupTrade)

// optional tiny buffer so stops/targets aren’t exactly on a level
useBufferTicks = input.bool(false, "Use Tick Buffer", group=groupTrade)
bufferTicks    = input.int(1, "Buffer (ticks)", minval=0, maxval=20, group=groupTrade)

groupDisp = "Displacement Filter"
useDisplacementFilter = input.bool(true, "Displacement Filter On", group=groupDisp)
minCloseBeyondPct     = input.float(0.25, "Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)
maxBreakoutWickPct    = input.float(0.20, "Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)

groupTimeExit = "Time Exit"
useTimeExit   = input.bool(true, "Time Exit On", group=groupTimeExit)
maxBarsInTrade = input.int(12, "Max Bars In Trade", minval=1, maxval=500, group=groupTimeExit)
timeExitMode   = input.string("Any", "Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExit)

groupEOD = "End Of Day Close"
useEodClose = input.bool(true, "EOD Close On", group=groupEOD)
eodHour     = input.int(15, "EOD Hour", minval=0, maxval=23, group=groupEOD)
eodMinute   = input.int(55, "EOD Minute", minval=0, maxval=59, group=groupEOD)

groupDisplay = "Display"
showORBLevels = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels    = input.bool(true, "Show Entry Labels", group=groupDisplay)

// =========================
// Entry rules (evaluated on CURRENT CHART timeframe)
// =========================
bodyCloseLong(orbHigh) =>
    close > orbHigh and close > open and (not noWickStrict or low >= orbHigh)

bodyCloseShort(orbLow) =>
    close < orbLow and close < open and (not noWickStrict or high <= orbLow)

// Displacement / momentum filter
displacementLong(orbHigh) =>
    candleRange = high - low
    breakoutWick = high - close
    closeBeyond = close - orbHigh
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

displacementShort(orbLow) =>
    candleRange = high - low
    breakoutWick = close - low
    closeBeyond = orbLow - close
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

entryLongOk(orbHigh) =>
    bodyCloseLong(orbHigh) and (not useDisplacementFilter or displacementLong(orbHigh))

entryShortOk(orbLow) =>
    bodyCloseShort(orbLow) and (not useDisplacementFilter or displacementShort(orbLow))

// =========================
// ORB engine on 1m (range accuracy)
// =========================
orbLevels1m(startH, startM, durM) =>
    int y  = year(time, sessionTZ)
    int mo = month(time, sessionTZ)
    int d  = dayofmonth(time, sessionTZ)
    int h  = hour(time, sessionTZ)
    int m  = minute(time, sessionTZ)

    int dayId = y * 10000 + mo * 100 + d

    int curMin   = h * 60 + m
    int startMin = startH * 60 + startM
    int endMin   = startMin + durM

    bool inOrb = curMin >= startMin and curMin < endMin

    var float hi = na
    var float lo = na
    var bool  ready = false
    var int   lastDayId = na

    if na(lastDayId) or dayId != lastDayId
        hi := na
        lo := na
        ready := false
        lastDayId := dayId

    bool startBar = inOrb and not inOrb[1]
    bool ended    = not inOrb and inOrb[1]

    if startBar
        hi := high
        lo := low
        ready := false
    else if inOrb
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low  : math.min(lo, low)

    if ended
        ready := true

    float outHi = (inOrb or ready) ? hi : na
    float outLo = (inOrb or ready) ? lo : na

    [outHi, outLo, ready, dayId]

// Pull ORBs from 1m
[nyHigh, nyLow, nyReady, nyDayId] =
     request.security(syminfo.tickerid, "1", orbLevels1m(nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_off)

[ldnHigh, ldnLow, ldnReady, ldnDayId] =
     request.security(syminfo.tickerid, "1", orbLevels1m(ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_off)

// =========================
// One trade per session per day gating
// =========================
var int lastDay = na
var bool nyTraded = false
var bool ldnTraded = false

if na(lastDay) or nyDayId != lastDay
    nyTraded := false
    ldnTraded := false
    lastDay := nyDayId

// =========================
// Entry Logic (FIRST CHART-TF candle to close outside ORB)
// Stop = breakout candle low/high
// =========================
float tick = syminfo.mintick
float buf  = useBufferTicks ? bufferTicks * tick : 0.0

var string activeORB = ""
bool longSignal = false
bool shortSignal = false
float intendedStop = na

nyLongSignal  = useNY and nyReady and not nyTraded and strategy.position_size == 0 and entryLongOk(nyHigh)
nyShortSignal = useNY and nyReady and not nyTraded and strategy.position_size == 0 and entryShortOk(nyLow)

ldnLongSignal  = useLondon and ldnReady and not ldnTraded and strategy.position_size == 0 and entryLongOk(ldnHigh)
ldnShortSignal = useLondon and ldnReady and not ldnTraded and strategy.position_size == 0 and entryShortOk(ldnLow)

// Prefer NY if both trigger same bar
if nyLongSignal
    longSignal := true
    activeORB := "NY"
    intendedStop := low - buf
    nyTraded := true
else if nyShortSignal
    shortSignal := true
    activeORB := "NY"
    intendedStop := high + buf
    nyTraded := true
else if ldnLongSignal
    longSignal := true
    activeORB := "London"
    intendedStop := low - buf
    ldnTraded := true
else if ldnShortSignal
    shortSignal := true
    activeORB := "London"
    intendedStop := high + buf
    ldnTraded := true

if longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up,
          textcolor=color.white, color=color.new(color.green, 0))

if shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down,
          textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Freeze entry/stop/risk on actual fill bar
// =========================
var float posStopRef = na
var float posEntry   = na
var float posRisk    = na
var float highestSinceEntry = na
var float lowestSinceEntry  = na
var int   entryBarIndex = na

if longSignal or shortSignal
    posStopRef := intendedStop

newLong  = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
flatNow  = strategy.position_size == 0 and strategy.position_size[1] != 0

if flatNow or strategy.position_size == 0
    posEntry := na
    posRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na

if newLong
    posEntry := strategy.position_avg_price
    posRisk  := posEntry - posStopRef
    highestSinceEntry := high
    entryBarIndex := bar_index

if newShort
    posEntry := strategy.position_avg_price
    posRisk  := posStopRef - posEntry
    lowestSinceEntry := low
    entryBarIndex := bar_index

if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)

if strategy.position_size < 0
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)

validLong  = strategy.position_size > 0 and not na(posEntry) and not na(posRisk) and posRisk > 0 and not na(posStopRef)
validShort = strategy.position_size < 0 and not na(posEntry) and not na(posRisk) and posRisk > 0 and not na(posStopRef)

// =========================
// Helper state for trail activation
// =========================
longRunupR  = validLong  ? math.floor((highestSinceEntry - posEntry) / posRisk) : na
shortRunupR = validShort ? math.floor((posEntry - lowestSinceEntry) / posRisk) : na

trailActiveLong  = validLong and tradeMode == "1R Step Trail" and longRunupR >= 1
trailActiveShort = validShort and tradeMode == "1R Step Trail" and shortRunupR >= 1

// =========================
// Time Exit Logic
// Fixed RR: normal time exit logic
// 1R Trail: time exit only BEFORE trail activates
// =========================
barsInTrade = not na(entryBarIndex) ? (bar_index - entryBarIndex) : na

longInProfit  = validLong and close > posEntry
shortInProfit = validShort and close < posEntry

timeExitEligibleLong = tradeMode == "Fixed RR" or (tradeMode == "1R Step Trail" and not trailActiveLong)

timeExitEligibleShort = tradeMode == "Fixed RR" or (tradeMode == "1R Step Trail" and not trailActiveShort)

timeExitLong = useTimeExit and validLong and timeExitEligibleLong and not na(barsInTrade) and barsInTrade >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and longInProfit))

timeExitShort = useTimeExit and validShort and timeExitEligibleShort and not na(barsInTrade) and barsInTrade >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and shortInProfit))

// =========================
// End-of-day close logic
// =========================
int curHour = hour(time, sessionTZ)
int curMinute = minute(time, sessionTZ)
int curMinuteOfDay = curHour * 60 + curMinute
int eodMinuteOfDay = eodHour * 60 + eodMinute

eodCloseNow = useEodClose and curMinuteOfDay >= eodMinuteOfDay

// =========================
// Exit Logic
// - Fixed RR: fixed stop + limit
// - 1R Trail:
//   Before +1R: stop stays at original SL
//   At +1R: stop moves to BE
//   At +2R: stop moves to +1R, etc.
// =========================
if validLong
    float stopPrice  = na
    float limitPrice = na

    if tradeMode == "Fixed RR"
        stopPrice  := posStopRef
        limitPrice := posEntry + posRisk * rrMultiple
    else
        if longRunupR < 1
            stopPrice := posStopRef
        else
            stopPrice := posEntry + (longRunupR - 1) * posRisk

    strategy.exit("Long Exit", from_entry="Long", stop=stopPrice, limit=limitPrice)

if validShort
    float stopPrice  = na
    float limitPrice = na

    if tradeMode == "Fixed RR"
        stopPrice  := posStopRef
        limitPrice := posEntry - posRisk * rrMultiple
    else
        if shortRunupR < 1
            stopPrice := posStopRef
        else
            stopPrice := posEntry - (shortRunupR - 1) * posRisk

    strategy.exit("Short Exit", from_entry="Short", stop=stopPrice, limit=limitPrice)

// Time-based close
if timeExitLong
    strategy.close("Long", comment="Time Exit")

if timeExitShort
    strategy.close("Short", comment="Time Exit")

// EOD forced close
if eodCloseNow and strategy.position_size > 0
    strategy.close("Long", comment="EOD Close")

if eodCloseNow and strategy.position_size < 0
    strategy.close("Short", comment="EOD Close")

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and useNY ? nyHigh : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useNY ? nyLow  : na, "NY ORB Low",  color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)

plot(showORBLevels and useLondon ? ldnHigh : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and useLondon ? ldnLow  : na, "London ORB Low",  color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)