//@version=5
strategy("ORB Precision", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.0, process_orders_on_close=true)

// =========================
// Inputs
// =========================
groupSessions = "Sessions"
useNY      = input.bool(true,  "NY Open On", group=groupSessions)
useLondon  = input.bool(false, "London Open On", group=groupSessions)
useAsia    = input.bool(false, "Asian Open On", group=groupSessions)

// Master strategy day / bookkeeping timezone
strategyDayTZ = input.string("America/New_York", "Strategy Day Timezone", group=groupSessions)

// Native session timezones
nyTZ   = input.string("America/New_York", "NY Timezone", group=groupSessions)
ldnTZ  = input.string("Europe/London", "London Timezone", group=groupSessions)
asiaTZ = input.string("Asia/Tokyo", "Asia Timezone", group=groupSessions)

// ORB windows by LOCAL SESSION clock time + duration (minutes)
nyStartH   = input.int(9,  "NY Start Hour",   minval=0, maxval=23, group=groupSessions)
nyStartM   = input.int(30, "NY Start Minute", minval=0, maxval=59, group=groupSessions)
nyDurM     = input.int(15, "NY ORB Minutes",  minval=1, maxval=120, group=groupSessions)

ldnStartH  = input.int(8,  "London Start Hour",   minval=0, maxval=23, group=groupSessions)
ldnStartM  = input.int(0,  "London Start Minute", minval=0, maxval=59, group=groupSessions)
ldnDurM    = input.int(15, "London ORB Minutes",  minval=1, maxval=120, group=groupSessions)

asiaStartH = input.int(9,  "Asian Start Hour",   minval=0, maxval=23, group=groupSessions)
asiaStartM = input.int(0,  "Asian Start Minute", minval=0, maxval=59, group=groupSessions)
asiaDurM   = input.int(15, "Asian ORB Minutes",  minval=1, maxval=120, group=groupSessions)

// Trade windows / session cutoffs in LOCAL SESSION clock time
nyEndH     = input.int(16, "NY End Hour", minval=0, maxval=23, group=groupSessions)
nyEndM     = input.int(0,  "NY End Minute", minval=0, maxval=59, group=groupSessions)

ldnEndH    = input.int(10, "London End Hour", minval=0, maxval=23, group=groupSessions)
ldnEndM    = input.int(0,  "London End Minute", minval=0, maxval=59, group=groupSessions)

asiaEndH   = input.int(13, "Asian End Hour", minval=0, maxval=23, group=groupSessions)
asiaEndM   = input.int(0,  "Asian End Minute", minval=0, maxval=59, group=groupSessions)

groupTrade = "Trade Logic"
tradeMode    = input.string("1R Step Trail", "Exit Mode", options=["Fixed RR", "1R Step Trail"], group=groupTrade)
rrMultiple   = input.float(2.0, "Fixed RR Multiple", minval=0.5, step=0.5, group=groupTrade)
noWickStrict = input.bool(false, "Strict: No wick back into ORB", group=groupTrade)
breakoutMode = input.string("Current Behavior", "Breakout Qualification Mode", options=["Current Behavior", "First Qualified Close Only", "Reset Inside Then Requalify", "One-Bar Grace Then Reset"], group=groupTrade)
allowSecondBreak = input.bool(false, "Allow One Second Break After First Losing Trade + Reset Inside ORB", group=groupTrade)

// NEW: next-bar confirmation
groupFollow = "Follow-Through Confirmation Filter"
useFollowThroughConfirmation = input.bool(false, "Immediate Follow-Through / Reclaim Filter On", group=groupFollow)

// NEW: large breakout retest mode
groupRetest = "Large Breakout Retest Mode"
useLargeBreakoutRetest = input.bool(false, "Large Breakout Retest On", group=groupRetest)
largeBreakoutAtrThreshold = input.float(0.55, "Large Breakout Candle / ATR Threshold", minval=0.0, step=0.01, group=groupRetest)
retestLevelMode = input.string("ORB Boundary", "Retest Level", options=["ORB Boundary", "Breakout Midpoint"], group=groupRetest)
maxRetestBars = input.int(4, "Max Bars To Wait For Retest", minval=1, maxval=20, group=groupRetest)

// optional tiny buffer so stops/targets aren’t exactly on a level
useBufferTicks = input.bool(false, "Use Tick Buffer", group=groupTrade)
bufferTicks    = input.int(1, "Buffer (ticks)", minval=0, maxval=20, group=groupTrade)

groupStopAdj = "Stop Adjustment"
useStopAdjustment = input.bool(true, "Stop Adjustment On", group=groupStopAdj)
stopMultiplier = input.float(1.85, "Stop Multiplier", minval=0.1, step=0.05, group=groupStopAdj)
trailRiskBasis = input.string("Adjusted Stop Risk", "Trail Risk Basis", options=["Adjusted Stop Risk", "Original Breakout Risk"], group=groupStopAdj)

groupDisp = "Displacement Filter"
useDisplacementFilter = input.bool(true, "Displacement Filter On", group=groupDisp)
minCloseBeyondPct     = input.float(0.17, "Min Close Beyond ORB (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)
maxBreakoutWickPct    = input.float(0.20, "Max Breakout Wick (% of candle range)", minval=0.0, maxval=1.0, step=0.01, group=groupDisp)

groupAtr = "ATR Filter"
useAtrOrbFilter = input.bool(true, "ATR ORB Filter On", group=groupAtr)
atrLen = input.int(14, "ATR Length", minval=1, group=groupAtr)
minOrbAtrPct = input.float(0.17, "Min ORB / ATR", minval=0.0, step=0.01, group=groupAtr)
maxOrbAtrPct = input.float(1.20, "Max ORB / ATR", minval=0.0, step=0.01, group=groupAtr)

groupPrevDayCompression = "Previous Day Compression Filter"
usePrevDayCompressionFilter = input.bool(false, "Previous Day Compression Filter On", group=groupPrevDayCompression)
maxPrevDayRangeAtrPct       = input.float(0.80, "Max Previous Day Range / ATR", minval=0.0, step=0.01, group=groupPrevDayCompression)

groupPrevDayTrend = "Previous Day Trend Alignment Filter"
usePrevDayTrendAlignment = input.bool(false, "Previous Day Trend Alignment On", group=groupPrevDayTrend)

groupOvernight = "Overnight Range Filter"
useOvernightRangeFilter = input.bool(false, "NY Overnight Range Filter On", group=groupOvernight)
minOvernightAtrPct = input.float(0.00, "Min Overnight / ATR", minval=0.0, step=0.01, group=groupOvernight)
maxOvernightAtrPct = input.float(0.80, "Max Overnight / ATR", minval=0.0, step=0.01, group=groupOvernight)

groupTimeExit = "Time Exit"
useTimeExit    = input.bool(true, "Time Exit On", group=groupTimeExit)
maxBarsInTrade = input.int(24, "Max Bars In Trade", minval=1, maxval=500, group=groupTimeExit)
timeExitMode   = input.string("Any", "Time Exit Mode", options=["Any", "Only In Profit"], group=groupTimeExit)
resetTimeExitOnTrailStep = input.bool(false, "Reset Time Exit On Trail Step", group=groupTimeExit)

groupEntryTime = "Entry Time Filter"

// =========================
// NY entry cutoff controls (NY local timezone)
// =========================
nyUseNoTradeAfter = input.bool(false, "NY: Don't Enter After Time (Global Default)", group=groupEntryTime)
nyLastEntryH      = input.int(11, "NY Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyLastEntryM      = input.int(0,  "NY Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyUseWeekdaySpecificCutoffs = input.bool(true, "NY: Use Weekday-Specific Cutoffs", group=groupEntryTime)

nyMonUseNoTradeAfter = input.bool(true, "NY Monday Override On", group=groupEntryTime)
nyMonLastEntryH      = input.int(11, "NY Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyMonLastEntryM      = input.int(0,  "NY Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyTueUseNoTradeAfter = input.bool(false, "NY Tuesday Override On", group=groupEntryTime)
nyTueLastEntryH      = input.int(11, "NY Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyTueLastEntryM      = input.int(0,  "NY Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyWedUseNoTradeAfter = input.bool(false, "NY Wednesday Override On", group=groupEntryTime)
nyWedLastEntryH      = input.int(11, "NY Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyWedLastEntryM      = input.int(0,  "NY Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyThuUseNoTradeAfter = input.bool(true, "NY Thursday Override On", group=groupEntryTime)
nyThuLastEntryH      = input.int(11, "NY Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyThuLastEntryM      = input.int(0,  "NY Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

nyFriUseNoTradeAfter = input.bool(false, "NY Friday Override On", group=groupEntryTime)
nyFriLastEntryH      = input.int(11, "NY Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
nyFriLastEntryM      = input.int(0,  "NY Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

// =========================
// London entry cutoff controls (London local timezone)
// =========================
ldnUseNoTradeAfter = input.bool(false, "London: Don't Enter After Time (Global Default)", group=groupEntryTime)
ldnLastEntryH      = input.int(10, "London Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnLastEntryM      = input.int(0,  "London Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnUseWeekdaySpecificCutoffs = input.bool(false, "London: Use Weekday-Specific Cutoffs", group=groupEntryTime)

ldnMonUseNoTradeAfter = input.bool(false, "London Monday Override On", group=groupEntryTime)
ldnMonLastEntryH      = input.int(10, "London Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnMonLastEntryM      = input.int(0,  "London Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnTueUseNoTradeAfter = input.bool(false, "London Tuesday Override On", group=groupEntryTime)
ldnTueLastEntryH      = input.int(10, "London Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnTueLastEntryM      = input.int(0,  "London Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnWedUseNoTradeAfter = input.bool(false, "London Wednesday Override On", group=groupEntryTime)
ldnWedLastEntryH      = input.int(10, "London Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnWedLastEntryM      = input.int(0,  "London Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnThuUseNoTradeAfter = input.bool(false, "London Thursday Override On", group=groupEntryTime)
ldnThuLastEntryH      = input.int(10, "London Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnThuLastEntryM      = input.int(0,  "London Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

ldnFriUseNoTradeAfter = input.bool(false, "London Friday Override On", group=groupEntryTime)
ldnFriLastEntryH      = input.int(10, "London Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
ldnFriLastEntryM      = input.int(0,  "London Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

// =========================
// Asia entry cutoff controls (Asia local timezone)
// =========================
asiaUseNoTradeAfter = input.bool(false, "Asia: Don't Enter After Time (Global Default)", group=groupEntryTime)
asiaLastEntryH      = input.int(11, "Asia Global Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaLastEntryM      = input.int(0,  "Asia Global Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaUseWeekdaySpecificCutoffs = input.bool(false, "Asia: Use Weekday-Specific Cutoffs", group=groupEntryTime)

asiaMonUseNoTradeAfter = input.bool(false, "Asia Monday Override On", group=groupEntryTime)
asiaMonLastEntryH      = input.int(11, "Asia Monday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaMonLastEntryM      = input.int(0,  "Asia Monday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaTueUseNoTradeAfter = input.bool(false, "Asia Tuesday Override On", group=groupEntryTime)
asiaTueLastEntryH      = input.int(11, "Asia Tuesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaTueLastEntryM      = input.int(0,  "Asia Tuesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaWedUseNoTradeAfter = input.bool(false, "Asia Wednesday Override On", group=groupEntryTime)
asiaWedLastEntryH      = input.int(11, "Asia Wednesday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaWedLastEntryM      = input.int(0,  "Asia Wednesday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaThuUseNoTradeAfter = input.bool(false, "Asia Thursday Override On", group=groupEntryTime)
asiaThuLastEntryH      = input.int(11, "Asia Thursday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaThuLastEntryM      = input.int(0,  "Asia Thursday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

asiaFriUseNoTradeAfter = input.bool(false, "Asia Friday Override On", group=groupEntryTime)
asiaFriLastEntryH      = input.int(11, "Asia Friday Last Entry Hour", minval=0, maxval=23, group=groupEntryTime)
asiaFriLastEntryM      = input.int(0,  "Asia Friday Last Entry Minute", minval=0, maxval=59, group=groupEntryTime)

groupEOD = "End Of Day Close"
useEodClose = input.bool(false, "Session Close On", group=groupEOD)

groupFilters = "Trade Filters"
skipDecember = input.bool(true, "Skip December", group=groupFilters)
skipThanksgivingWeek = input.bool(true, "Skip Thanksgiving Week", group=groupFilters)
skipUSHalfDays = input.bool(true, "Skip US Half Days (Approximation)", group=groupFilters)
skipMondays = input.bool(false, "Skip Mondays", group=groupFilters)
skipTuesdays = input.bool(false, "Skip Tuesdays", group=groupFilters)
skipWednesdays = input.bool(false, "Skip Wednesdays", group=groupFilters)
skipThursdays = input.bool(false, "Skip Thursdays", group=groupFilters)
skipFridays = input.bool(false, "Skip Fridays", group=groupFilters)
skipManualDates = input.string("", "Skip Dates (YYYY-MM-DD, comma-separated)", group=groupFilters)

groupDisplay = "Display"
showORBLevels                = input.bool(true, "Show ORB Levels", group=groupDisplay)
showLabels                   = input.bool(true, "Show Entry Labels", group=groupDisplay)
showActiveStop               = input.bool(true, "Show Active Stop", group=groupDisplay)
showActiveTarget             = input.bool(true, "Show Active Target", group=groupDisplay)
showORBOnlyDuringTradeWindow = input.bool(true, "Show ORB Only During Trade Window", group=groupDisplay)

// =========================
// Entry rules (evaluated on CURRENT CHART timeframe)
// =========================
bodyCloseLong(orbHigh) =>
    close > orbHigh and close > open and (not noWickStrict or low >= orbHigh)

bodyCloseShort(orbLow) =>
    close < orbLow and close < open and (not noWickStrict or high <= orbLow)

displacementLong(orbHigh) =>
    candleRange = high - low
    breakoutWick = high - close
    closeBeyond = close - orbHigh
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

displacementShort(orbLow) =>
    candleRange = high - low
    breakoutWick = close - low
    closeBeyond = orbLow - close
    candleRange > 0 and closeBeyond >= candleRange * minCloseBeyondPct and breakoutWick <= candleRange * maxBreakoutWickPct

entryLongOk(orbHigh) =>
    bodyCloseLong(orbHigh) and (not useDisplacementFilter or displacementLong(orbHigh))

entryShortOk(orbLow) =>
    bodyCloseShort(orbLow) and (not useDisplacementFilter or displacementShort(orbLow))

closeInsideOrb(orbHigh, orbLow) =>
    close <= orbHigh and close >= orbLow

closeAboveOrb(orbHigh) =>
    close > orbHigh

closeBelowOrb(orbLow) =>
    close < orbLow

followThroughLongOk(orbHigh, breakoutHigh, breakoutClose) =>
    close > orbHigh and high >= breakoutHigh and close >= breakoutClose

followThroughShortOk(orbLow, breakoutLow, breakoutClose) =>
    close < orbLow and low <= breakoutLow and close <= breakoutClose

minuteOfDay(h, m) =>
    h * 60 + m

inWindow(curMin, startMin, endMin) =>
    startMin <= endMin ? (curMin >= startMin and curMin <= endMin) : (curMin >= startMin or curMin <= endMin)

tradeWindowActive(tz, startH, startM, durM, endH, endM) =>
    int curH = hour(time, tz)
    int curM = minute(time, tz)
    int curMin = minuteOfDay(curH, curM)
    int orbEndMin = minuteOfDay(startH, startM) + durM
    int endMin = minuteOfDay(endH, endM)
    orbEndMin := orbEndMin % 1440
    inWindow(curMin, orbEndMin, endMin)

entryTimeAllowedWithWeekdayOverrides(
     tz,
     useNoTradeAfterGlobal,
     lastEntryHGlobal,
     lastEntryMGlobal,
     useWeekdaySpecific,
     monUse,
     monH,
     monM,
     tueUse,
     tueH,
     tueM,
     wedUse,
     wedH,
     wedM,
     thuUse,
     thuH,
     thuM,
     friUse,
     friH,
     friM) =>

    int curH = hour(time, tz)
    int curM = minute(time, tz)
    int curMin = minuteOfDay(curH, curM)
    int curDowLocal = dayofweek(time, tz)

    int globalCutoffMin = minuteOfDay(lastEntryHGlobal, lastEntryMGlobal)
    bool globalAllowed = not useNoTradeAfterGlobal or curMin <= globalCutoffMin

    int weekdayCutoffMin =
         curDowLocal == dayofweek.monday    ? minuteOfDay(monH, monM) :
         curDowLocal == dayofweek.tuesday   ? minuteOfDay(tueH, tueM) :
         curDowLocal == dayofweek.wednesday ? minuteOfDay(wedH, wedM) :
         curDowLocal == dayofweek.thursday  ? minuteOfDay(thuH, thuM) :
         curDowLocal == dayofweek.friday    ? minuteOfDay(friH, friM) :
         globalCutoffMin

    bool weekdayOverrideEnabled =
         curDowLocal == dayofweek.monday    ? monUse :
         curDowLocal == dayofweek.tuesday   ? tueUse :
         curDowLocal == dayofweek.wednesday ? wedUse :
         curDowLocal == dayofweek.thursday  ? thuUse :
         curDowLocal == dayofweek.friday    ? friUse :
         false

    useWeekdaySpecific and weekdayOverrideEnabled ? (curMin <= weekdayCutoffMin) : globalAllowed

dateToInt(y, mo, d) =>
    y * 10000 + mo * 100 + d

nthWeekdayDom(y, mo, targetDow, nth) =>
    int firstDow = dayofweek(timestamp(strategyDayTZ, y, mo, 1, 0, 0))
    int offset = (targetDow - firstDow + 7) % 7
    1 + offset + (nth - 1) * 7

isManualSkipDate(dateList, ymd) =>
    bool match = false
    arr = str.split(dateList, ",")
    for i = 0 to array.size(arr) - 1
        raw = array.get(arr, i)
        cleaned = str.replace_all(str.replace_all(raw, "-", ""), " ", "")
        val = str.tonumber(cleaned)
        if not na(val) and int(val) == ymd
            match := true
    match

getSessionTz(sessionName) =>
    sessionName == "NY" ? nyTZ : sessionName == "London" ? ldnTZ : sessionName == "Asia" ? asiaTZ : strategyDayTZ

getSessionCloseTs(sessionName) =>
    string tz = getSessionTz(sessionName)
    int y = year(time, tz)
    int mo = month(time, tz)
    int d = dayofmonth(time, tz)
    sessionName == "NY" ? timestamp(tz, y, mo, d, nyEndH, nyEndM) :
     sessionName == "London" ? timestamp(tz, y, mo, d, ldnEndH, ldnEndM) :
     sessionName == "Asia" ? timestamp(tz, y, mo, d, asiaEndH, asiaEndM) :
     na

sessionEntryAllowed(sessionName) =>
    sessionName == "NY" ? entryTimeAllowedWithWeekdayOverrides(nyTZ, nyUseNoTradeAfter, nyLastEntryH, nyLastEntryM, nyUseWeekdaySpecificCutoffs, nyMonUseNoTradeAfter, nyMonLastEntryH, nyMonLastEntryM, nyTueUseNoTradeAfter, nyTueLastEntryH, nyTueLastEntryM, nyWedUseNoTradeAfter, nyWedLastEntryH, nyWedLastEntryM, nyThuUseNoTradeAfter, nyThuLastEntryH, nyThuLastEntryM, nyFriUseNoTradeAfter, nyFriLastEntryH, nyFriLastEntryM) : sessionName == "London" ? entryTimeAllowedWithWeekdayOverrides(ldnTZ, ldnUseNoTradeAfter, ldnLastEntryH, ldnLastEntryM, ldnUseWeekdaySpecificCutoffs, ldnMonUseNoTradeAfter, ldnMonLastEntryH, ldnMonLastEntryM, ldnTueUseNoTradeAfter, ldnTueLastEntryH, ldnTueLastEntryM, ldnWedUseNoTradeAfter, ldnWedLastEntryH, ldnWedLastEntryM, ldnThuUseNoTradeAfter, ldnThuLastEntryH, ldnThuLastEntryM, ldnFriUseNoTradeAfter, ldnFriLastEntryH, ldnFriLastEntryM) : sessionName == "Asia" ? entryTimeAllowedWithWeekdayOverrides(asiaTZ, asiaUseNoTradeAfter, asiaLastEntryH, asiaLastEntryM, asiaUseWeekdaySpecificCutoffs, asiaMonUseNoTradeAfter, asiaMonLastEntryH, asiaMonLastEntryM, asiaTueUseNoTradeAfter, asiaTueLastEntryH, asiaTueLastEntryM, asiaWedUseNoTradeAfter, asiaWedLastEntryH, asiaWedLastEntryM, asiaThuUseNoTradeAfter, asiaThuLastEntryH, asiaThuLastEntryM, asiaFriUseNoTradeAfter, asiaFriLastEntryH, asiaFriLastEntryM) : true

orbAtrOk(orbSize, atrValue) =>
    not useAtrOrbFilter or (not na(orbSize) and not na(atrValue) and atrValue > 0 and orbSize / atrValue >= minOrbAtrPct and orbSize / atrValue <= maxOrbAtrPct)

prevDayCompressionOk(prevDayRange, atrValue) =>
    not usePrevDayCompressionFilter or (not na(prevDayRange) and not na(atrValue) and atrValue > 0 and prevDayRange / atrValue <= maxPrevDayRangeAtrPct)

prevDayTrendLongOk(prevDayOpen, prevDayClose) =>
    not usePrevDayTrendAlignment or (not na(prevDayOpen) and not na(prevDayClose) and prevDayClose > prevDayOpen)

prevDayTrendShortOk(prevDayOpen, prevDayClose) =>
    not usePrevDayTrendAlignment or (not na(prevDayOpen) and not na(prevDayClose) and prevDayClose < prevDayOpen)

overnightAtrOk(overnightSize, atrValue) =>
    not useOvernightRangeFilter or (not na(overnightSize) and not na(atrValue) and atrValue > 0 and overnightSize / atrValue >= minOvernightAtrPct and overnightSize / atrValue <= maxOvernightAtrPct)

breakoutIsLarge(candleRange, atrValue) =>
    useLargeBreakoutRetest and not na(candleRange) and not na(atrValue) and atrValue > 0 and candleRange / atrValue >= largeBreakoutAtrThreshold

calcRetestLevel(isLong, orbHigh, orbLow, breakoutHigh, breakoutLow) =>
    retestLevelMode == "ORB Boundary" ? (isLong ? orbHigh : orbLow) : ((breakoutHigh + breakoutLow) / 2.0)

// =========================
// ORB engine on 1m (range accuracy)
// =========================
orbLevels1m(tz, startH, startM, durM) =>
    int y  = year(time, tz)
    int mo = month(time, tz)
    int d  = dayofmonth(time, tz)
    int h  = hour(time, tz)
    int m  = minute(time, tz)
    int dayId = y * 10000 + mo * 100 + d
    int curMin   = h * 60 + m
    int startMin = startH * 60 + startM
    int endMin   = startMin + durM
    bool inOrb = curMin >= startMin and curMin < endMin
    var float hi = na
    var float lo = na
    var bool  ready = false
    var int   lastDayId = na
    if na(lastDayId) or dayId != lastDayId
        hi := na
        lo := na
        ready := false
        lastDayId := dayId
    bool startBar = inOrb and not inOrb[1]
    bool ended    = not inOrb and inOrb[1]
    if startBar
        hi := high
        lo := low
        ready := false
    else if inOrb
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low  : math.min(lo, low)
    if ended
        ready := true
    float outHi = (inOrb or ready) ? hi : na
    float outLo = (inOrb or ready) ? lo : na
    [outHi, outLo, ready, dayId]

overnightLevels1m(tz, startH, startM, prevEndH, prevEndM) =>
    int y  = year(time, tz)
    int mo = month(time, tz)
    int d  = dayofmonth(time, tz)
    int h  = hour(time, tz)
    int m  = minute(time, tz)
    int dayId = y * 10000 + mo * 100 + d
    int curMin = h * 60 + m
    int startMin = startH * 60 + startM
    int prevEndMin = prevEndH * 60 + prevEndM
    bool atPrevEnd = curMin == prevEndMin
    bool atStart = curMin == startMin
    bool inOvernight = curMin >= prevEndMin or curMin < startMin
    var float hi = na
    var float lo = na
    var bool ready = false
    var int readyDayId = na
    if atPrevEnd
        hi := high
        lo := low
        ready := false
        readyDayId := na
    else if inOvernight and not atStart
        hi := na(hi) ? high : math.max(hi, high)
        lo := na(lo) ? low : math.min(lo, low)
    if atStart and not na(hi) and not na(lo)
        ready := true
        readyDayId := dayId
    float outHi = ready and readyDayId == dayId ? hi : na
    float outLo = ready and readyDayId == dayId ? lo : na
    [outHi, outLo, ready, readyDayId]

// Pull ORBs from 1m
[nyHigh, nyLow, nyReady, nyDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(nyTZ, nyStartH, nyStartM, nyDurM), barmerge.gaps_off, barmerge.lookahead_off)
[ldnHigh, ldnLow, ldnReady, ldnDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(ldnTZ, ldnStartH, ldnStartM, ldnDurM), barmerge.gaps_off, barmerge.lookahead_off)
[asiaHigh, asiaLow, asiaReady, asiaDayId] = request.security(syminfo.tickerid, "1", orbLevels1m(asiaTZ, asiaStartH, asiaStartM, asiaDurM), barmerge.gaps_off, barmerge.lookahead_off)

// Pull NY overnight range from 1m
[nyOverHigh, nyOverLow, nyOverReady, nyOverDayId] = request.security(syminfo.tickerid, "1", overnightLevels1m(nyTZ, nyStartH, nyStartM, nyEndH, nyEndM), barmerge.gaps_off, barmerge.lookahead_off)

// Daily ATR remains for structural filters
dailyAtrValue = request.security(syminfo.tickerid, "D", ta.atr(atrLen))
// Local/chart ATR is used for large breakout candle sizing
breakoutAtrLocal = ta.atr(atrLen)

prevDayHigh  = request.security(syminfo.tickerid, "D", high[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayLow   = request.security(syminfo.tickerid, "D", low[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayOpen  = request.security(syminfo.tickerid, "D", open[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayClose = request.security(syminfo.tickerid, "D", close[1], barmerge.gaps_off, barmerge.lookahead_off)
prevDayRange = not na(prevDayHigh) and not na(prevDayLow) ? prevDayHigh - prevDayLow : na

nyOrbSize = nyReady and not na(nyHigh) and not na(nyLow) ? nyHigh - nyLow : na
ldnOrbSize = ldnReady and not na(ldnHigh) and not na(ldnLow) ? ldnHigh - ldnLow : na
asiaOrbSize = asiaReady and not na(asiaHigh) and not na(asiaLow) ? asiaHigh - asiaLow : na
nyOvernightSize = nyOverReady and not na(nyOverHigh) and not na(nyOverLow) ? nyOverHigh - nyOverLow : na

// Calendar / trade filters
int curY = year(time, strategyDayTZ)
int curMo = month(time, strategyDayTZ)
int curD = dayofmonth(time, strategyDayTZ)
int curDow = dayofweek(time, strategyDayTZ)
int curYmd = dateToInt(curY, curMo, curD)
int thanksgivingDom = nthWeekdayDom(curY, 11, dayofweek.thursday, 4)
bool isDecember = curMo == 12
bool isThanksgivingWeek = curMo == 11 and curD >= thanksgivingDom - 3 and curD <= thanksgivingDom + 1
bool isDayAfterThanksgiving = curMo == 11 and curD == thanksgivingDom + 1
bool isChristmasEveHalfDay = curMo == 12 and curD == 24 and curDow >= dayofweek.monday and curDow <= dayofweek.friday
bool isJuly3HalfDay = curMo == 7 and curD == 3 and curDow >= dayofweek.monday and curDow <= dayofweek.friday
bool isUSHalfDay = isDayAfterThanksgiving or isChristmasEveHalfDay or isJuly3HalfDay
bool isSkippedWeekday = (skipMondays and curDow == dayofweek.monday) or (skipTuesdays and curDow == dayofweek.tuesday) or (skipWednesdays and curDow == dayofweek.wednesday) or (skipThursdays and curDow == dayofweek.thursday) or (skipFridays and curDow == dayofweek.friday)
bool isManualSkip = str.length(str.replace_all(skipManualDates, " ", "")) > 0 and isManualSkipDate(skipManualDates, curYmd)
bool skipToday = (skipDecember and isDecember) or (skipThanksgivingWeek and isThanksgivingWeek) or (skipUSHalfDays and isUSHalfDay) or isSkippedWeekday or isManualSkip
bool tradeDayAllowed = not skipToday

// Session trade windows
nyTradeWindowActive   = tradeDayAllowed and useNY and nyReady and tradeWindowActive(nyTZ, nyStartH, nyStartM, nyDurM, nyEndH, nyEndM)
ldnTradeWindowActive  = tradeDayAllowed and useLondon and ldnReady and tradeWindowActive(ldnTZ, ldnStartH, ldnStartM, ldnDurM, ldnEndH, ldnEndM)
asiaTradeWindowActive = tradeDayAllowed and useAsia and asiaReady and tradeWindowActive(asiaTZ, asiaStartH, asiaStartM, asiaDurM, asiaEndH, asiaEndM)

// =========================
// One trade per session per day gating
// =========================
var int lastDay = na
var bool nyTraded = false
var bool ldnTraded = false
var bool asiaTraded = false
var bool nyLongNeedsReset = false
var bool nyShortNeedsReset = false
var bool ldnLongNeedsReset = false
var bool ldnShortNeedsReset = false
var bool asiaLongNeedsReset = false
var bool asiaShortNeedsReset = false
var bool nyLongDead = false
var bool nyShortDead = false
var bool ldnLongDead = false
var bool ldnShortDead = false
var bool asiaLongDead = false
var bool asiaShortDead = false
var int nyLongOutsideCount = 0
var int nyShortOutsideCount = 0
var int ldnLongOutsideCount = 0
var int ldnShortOutsideCount = 0
var int asiaLongOutsideCount = 0
var int asiaShortOutsideCount = 0

// Second-break state: actual trades only
var int nyLongTradeCount = 0
var int nyShortTradeCount = 0
var int ldnLongTradeCount = 0
var int ldnShortTradeCount = 0
var int asiaLongTradeCount = 0
var int asiaShortTradeCount = 0

var bool nyLongRetryEligible = false
var bool nyShortRetryEligible = false
var bool ldnLongRetryEligible = false
var bool ldnShortRetryEligible = false
var bool asiaLongRetryEligible = false
var bool asiaShortRetryEligible = false

var bool nyLongRetryArmed = false
var bool nyShortRetryArmed = false
var bool ldnLongRetryArmed = false
var bool ldnShortRetryArmed = false
var bool asiaLongRetryArmed = false
var bool asiaShortRetryArmed = false

// Pending confirmation state
var bool pendingConfirmActive = false
var string pendingConfirmSession = ""
var string pendingConfirmDirection = ""
var float pendingConfirmStop = na
var float pendingConfirmOrbHigh = na
var float pendingConfirmOrbLow = na
var float pendingConfirmBreakoutHigh = na
var float pendingConfirmBreakoutLow = na
var float pendingConfirmBreakoutClose = na
var int pendingConfirmBarIndex = na
var int pendingConfirmSessionCloseTs = na

// Pending retest state
var bool pendingRetestActive = false
var string pendingRetestSession = ""
var string pendingRetestDirection = ""
var float pendingRetestStop = na
var float pendingRetestLevel = na
var float pendingRetestOrbHigh = na
var float pendingRetestOrbLow = na
var int pendingRetestBarIndex = na
var int pendingRetestSessionCloseTs = na

curDay = year(time, strategyDayTZ) * 10000 + month(time, strategyDayTZ) * 100 + dayofmonth(time, strategyDayTZ)

if na(lastDay) or curDay != lastDay
    nyTraded := false
    ldnTraded := false
    asiaTraded := false
    nyLongNeedsReset := false
    nyShortNeedsReset := false
    ldnLongNeedsReset := false
    ldnShortNeedsReset := false
    asiaLongNeedsReset := false
    asiaShortNeedsReset := false
    nyLongDead := false
    nyShortDead := false
    ldnLongDead := false
    ldnShortDead := false
    asiaLongDead := false
    asiaShortDead := false
    nyLongOutsideCount := 0
    nyShortOutsideCount := 0
    ldnLongOutsideCount := 0
    ldnShortOutsideCount := 0
    asiaLongOutsideCount := 0
    asiaShortOutsideCount := 0
    nyLongTradeCount := 0
    nyShortTradeCount := 0
    ldnLongTradeCount := 0
    ldnShortTradeCount := 0
    asiaLongTradeCount := 0
    asiaShortTradeCount := 0
    nyLongRetryEligible := false
    nyShortRetryEligible := false
    ldnLongRetryEligible := false
    ldnShortRetryEligible := false
    asiaLongRetryEligible := false
    asiaShortRetryEligible := false
    nyLongRetryArmed := false
    nyShortRetryArmed := false
    ldnLongRetryArmed := false
    ldnShortRetryArmed := false
    asiaLongRetryArmed := false
    asiaShortRetryArmed := false

    pendingConfirmActive := false
    pendingConfirmSession := ""
    pendingConfirmDirection := ""
    pendingConfirmStop := na
    pendingConfirmOrbHigh := na
    pendingConfirmOrbLow := na
    pendingConfirmBreakoutHigh := na
    pendingConfirmBreakoutLow := na
    pendingConfirmBreakoutClose := na
    pendingConfirmBarIndex := na
    pendingConfirmSessionCloseTs := na

    pendingRetestActive := false
    pendingRetestSession := ""
    pendingRetestDirection := ""
    pendingRetestStop := na
    pendingRetestLevel := na
    pendingRetestOrbHigh := na
    pendingRetestOrbLow := na
    pendingRetestBarIndex := na
    pendingRetestSessionCloseTs := na

    lastDay := curDay

// =========================
// Breakout state management
// =========================
nyLongPathActive   = nyTradeWindowActive   and not nyLongDead   and ((nyLongTradeCount == 0 and not nyTraded)   or (allowSecondBreak and nyLongTradeCount == 1 and nyLongRetryEligible))
nyShortPathActive  = nyTradeWindowActive   and not nyShortDead  and ((nyShortTradeCount == 0 and not nyTraded)  or (allowSecondBreak and nyShortTradeCount == 1 and nyShortRetryEligible))
ldnLongPathActive  = ldnTradeWindowActive  and not ldnLongDead  and ((ldnLongTradeCount == 0 and not ldnTraded) or (allowSecondBreak and ldnLongTradeCount == 1 and ldnLongRetryEligible))
ldnShortPathActive = ldnTradeWindowActive  and not ldnShortDead and ((ldnShortTradeCount == 0 and not ldnTraded) or (allowSecondBreak and ldnShortTradeCount == 1 and ldnShortRetryEligible))
asiaLongPathActive = asiaTradeWindowActive and not asiaLongDead and ((asiaLongTradeCount == 0 and not asiaTraded) or (allowSecondBreak and asiaLongTradeCount == 1 and asiaLongRetryEligible))
asiaShortPathActive = asiaTradeWindowActive and not asiaShortDead and ((asiaShortTradeCount == 0 and not asiaTraded) or (allowSecondBreak and asiaShortTradeCount == 1 and asiaShortRetryEligible))

if strategy.position_size == 0 and not pendingConfirmActive and not pendingRetestActive
    if nyLongPathActive
        if closeInsideOrb(nyHigh, nyLow)
            nyLongNeedsReset := false
            nyLongOutsideCount := 0
            if allowSecondBreak and nyLongRetryEligible and nyLongTradeCount == 1
                nyLongRetryArmed := true
        else if closeAboveOrb(nyHigh)
            if nyLongNeedsReset
                nyLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and nyLongOutsideCount > 1
                    nyLongDead := true

    if nyShortPathActive
        if closeInsideOrb(nyHigh, nyLow)
            nyShortNeedsReset := false
            nyShortOutsideCount := 0
            if allowSecondBreak and nyShortRetryEligible and nyShortTradeCount == 1
                nyShortRetryArmed := true
        else if closeBelowOrb(nyLow)
            if nyShortNeedsReset
                nyShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and nyShortOutsideCount > 1
                    nyShortDead := true

    if ldnLongPathActive
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnLongNeedsReset := false
            ldnLongOutsideCount := 0
            if allowSecondBreak and ldnLongRetryEligible and ldnLongTradeCount == 1
                ldnLongRetryArmed := true
        else if closeAboveOrb(ldnHigh)
            if ldnLongNeedsReset
                ldnLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and ldnLongOutsideCount > 1
                    ldnLongDead := true

    if ldnShortPathActive
        if closeInsideOrb(ldnHigh, ldnLow)
            ldnShortNeedsReset := false
            ldnShortOutsideCount := 0
            if allowSecondBreak and ldnShortRetryEligible and ldnShortTradeCount == 1
                ldnShortRetryArmed := true
        else if closeBelowOrb(ldnLow)
            if ldnShortNeedsReset
                ldnShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and ldnShortOutsideCount > 1
                    ldnShortDead := true

    if asiaLongPathActive
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaLongNeedsReset := false
            asiaLongOutsideCount := 0
            if allowSecondBreak and asiaLongRetryEligible and asiaLongTradeCount == 1
                asiaLongRetryArmed := true
        else if closeAboveOrb(asiaHigh)
            if asiaLongNeedsReset
                asiaLongOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and asiaLongOutsideCount > 1
                    asiaLongDead := true

    if asiaShortPathActive
        if closeInsideOrb(asiaHigh, asiaLow)
            asiaShortNeedsReset := false
            asiaShortOutsideCount := 0
            if allowSecondBreak and asiaShortRetryEligible and asiaShortTradeCount == 1
                asiaShortRetryArmed := true
        else if closeBelowOrb(asiaLow)
            if asiaShortNeedsReset
                asiaShortOutsideCount += 1
                if breakoutMode == "One-Bar Grace Then Reset" and asiaShortOutsideCount > 1
                    asiaShortDead := true

// =========================
// Entry permission logic by mode
// =========================
canConsiderLong(ready, traded, dead, needsReset, orbHigh, tradeCount, retryArmed) =>
    bool firstTradeAllowed  = tradeCount == 0 and not traded
    bool secondTradeAllowed = allowSecondBreak and tradeCount == 1 and retryArmed
    ready and strategy.position_size == 0 and not dead and (firstTradeAllowed or secondTradeAllowed) and (
         breakoutMode == "Current Behavior" ? closeAboveOrb(orbHigh) :
         breakoutMode == "First Qualified Close Only" ? closeAboveOrb(orbHigh) and not needsReset :
         breakoutMode == "Reset Inside Then Requalify" ? closeAboveOrb(orbHigh) and not needsReset :
         breakoutMode == "One-Bar Grace Then Reset" ? closeAboveOrb(orbHigh) :
         false)

canConsiderShort(ready, traded, dead, needsReset, orbLow, tradeCount, retryArmed) =>
    bool firstTradeAllowed  = tradeCount == 0 and not traded
    bool secondTradeAllowed = allowSecondBreak and tradeCount == 1 and retryArmed
    ready and strategy.position_size == 0 and not dead and (firstTradeAllowed or secondTradeAllowed) and (
         breakoutMode == "Current Behavior" ? closeBelowOrb(orbLow) :
         breakoutMode == "First Qualified Close Only" ? closeBelowOrb(orbLow) and not needsReset :
         breakoutMode == "Reset Inside Then Requalify" ? closeBelowOrb(orbLow) and not needsReset :
         breakoutMode == "One-Bar Grace Then Reset" ? closeBelowOrb(orbLow) :
         false)

// =========================
// Entry Logic
// =========================
float tick = syminfo.mintick
float buf  = useBufferTicks ? bufferTicks * tick : 0.0

var string activeORB = ""
var string pendingORB = ""
bool longSignal = false
bool shortSignal = false
float intendedStop = na
var int pendingSessionCloseTs = na

bool nyEntryTimeOk   = sessionEntryAllowed("NY")
bool ldnEntryTimeOk  = sessionEntryAllowed("London")
bool asiaEntryTimeOk = sessionEntryAllowed("Asia")

bool prevDayCompressionPass = prevDayCompressionOk(prevDayRange, dailyAtrValue)
bool prevDayTrendLongPass = prevDayTrendLongOk(prevDayOpen, prevDayClose)
bool prevDayTrendShortPass = prevDayTrendShortOk(prevDayOpen, prevDayClose)

nyLongCandidate   = nyEntryTimeOk and prevDayCompressionPass and prevDayTrendLongPass and nyTradeWindowActive and orbAtrOk(nyOrbSize, dailyAtrValue) and overnightAtrOk(nyOvernightSize, dailyAtrValue) and canConsiderLong(nyReady, nyTraded, nyLongDead, nyLongNeedsReset, nyHigh, nyLongTradeCount, nyLongRetryArmed)
nyShortCandidate  = nyEntryTimeOk and prevDayCompressionPass and prevDayTrendShortPass and nyTradeWindowActive and orbAtrOk(nyOrbSize, dailyAtrValue) and overnightAtrOk(nyOvernightSize, dailyAtrValue) and canConsiderShort(nyReady, nyTraded, nyShortDead, nyShortNeedsReset, nyLow, nyShortTradeCount, nyShortRetryArmed)
ldnLongCandidate  = ldnEntryTimeOk and prevDayCompressionPass and prevDayTrendLongPass and ldnTradeWindowActive and orbAtrOk(ldnOrbSize, dailyAtrValue) and canConsiderLong(ldnReady, ldnTraded, ldnLongDead, ldnLongNeedsReset, ldnHigh, ldnLongTradeCount, ldnLongRetryArmed)
ldnShortCandidate = ldnEntryTimeOk and prevDayCompressionPass and prevDayTrendShortPass and ldnTradeWindowActive and orbAtrOk(ldnOrbSize, dailyAtrValue) and canConsiderShort(ldnReady, ldnTraded, ldnShortDead, ldnShortNeedsReset, ldnLow, ldnShortTradeCount, ldnShortRetryArmed)
asiaLongCandidate = asiaEntryTimeOk and prevDayCompressionPass and prevDayTrendLongPass and asiaTradeWindowActive and orbAtrOk(asiaOrbSize, dailyAtrValue) and canConsiderLong(asiaReady, asiaTraded, asiaLongDead, asiaLongNeedsReset, asiaHigh, asiaLongTradeCount, asiaLongRetryArmed)
asiaShortCandidate = asiaEntryTimeOk and prevDayCompressionPass and prevDayTrendShortPass and asiaTradeWindowActive and orbAtrOk(asiaOrbSize, dailyAtrValue) and canConsiderShort(asiaReady, asiaTraded, asiaShortDead, asiaShortNeedsReset, asiaLow, asiaShortTradeCount, asiaShortRetryArmed)

// Raw breakout events on the breakout bar
nyLongBreakout   = nyLongCandidate and entryLongOk(nyHigh)
nyShortBreakout  = nyShortCandidate and entryShortOk(nyLow)
ldnLongBreakout  = ldnLongCandidate and entryLongOk(ldnHigh)
ldnShortBreakout = ldnShortCandidate and entryShortOk(ldnLow)
asiaLongBreakout = asiaLongCandidate and entryLongOk(asiaHigh)
asiaShortBreakout = asiaShortCandidate and entryShortOk(asiaLow)

// Mark failed breakout attempts based on mode
if strategy.position_size == 0 and not pendingConfirmActive and not pendingRetestActive
    if nyLongCandidate and not entryLongOk(nyHigh)
        if breakoutMode == "First Qualified Close Only"
            nyLongDead := true
            nyLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            nyLongNeedsReset := true
            nyLongOutsideCount := 0

    if nyShortCandidate and not entryShortOk(nyLow)
        if breakoutMode == "First Qualified Close Only"
            nyShortDead := true
            nyShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            nyShortNeedsReset := true
            nyShortOutsideCount := 0

    if ldnLongCandidate and not entryLongOk(ldnHigh)
        if breakoutMode == "First Qualified Close Only"
            ldnLongDead := true
            ldnLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            ldnLongNeedsReset := true
            ldnLongOutsideCount := 0

    if ldnShortCandidate and not entryShortOk(ldnLow)
        if breakoutMode == "First Qualified Close Only"
            ldnShortDead := true
            ldnShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            ldnShortNeedsReset := true
            ldnShortOutsideCount := 0

    if asiaLongCandidate and not entryLongOk(asiaHigh)
        if breakoutMode == "First Qualified Close Only"
            asiaLongDead := true
            asiaLongNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            asiaLongNeedsReset := true
            asiaLongOutsideCount := 0

    if asiaShortCandidate and not entryShortOk(asiaLow)
        if breakoutMode == "First Qualified Close Only"
            asiaShortDead := true
            asiaShortNeedsReset := true
        else if breakoutMode == "Reset Inside Then Requalify"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0
        else if breakoutMode == "One-Bar Grace Then Reset"
            asiaShortNeedsReset := true
            asiaShortOutsideCount := 0

// Determine breakout size for routing
float breakoutCandleRange = high - low

// FIX 1: large breakout detection now uses chart-timeframe ATR, not daily ATR
bool nyLongLargeBreakout   = nyLongBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)
bool nyShortLargeBreakout  = nyShortBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)
bool ldnLongLargeBreakout  = ldnLongBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)
bool ldnShortLargeBreakout = ldnShortBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)
bool asiaLongLargeBreakout = asiaLongBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)
bool asiaShortLargeBreakout = asiaShortBreakout and breakoutIsLarge(breakoutCandleRange, breakoutAtrLocal)

// =========================
// Pending retest evaluation
// =========================
if pendingRetestActive and strategy.position_size == 0
    bool retestExpired = not na(pendingRetestBarIndex) and bar_index > pendingRetestBarIndex + maxRetestBars
    bool retestSameBarBlocked = not na(pendingRetestBarIndex) and bar_index <= pendingRetestBarIndex
    bool retestStoppedOut = pendingRetestDirection == "Long" ? low <= pendingRetestStop : high >= pendingRetestStop
    bool retestEntryTimeOk = sessionEntryAllowed(pendingRetestSession)

    if retestExpired or retestStoppedOut
        pendingRetestActive := false
        pendingRetestSession := ""
        pendingRetestDirection := ""
        pendingRetestStop := na
        pendingRetestLevel := na
        pendingRetestOrbHigh := na
        pendingRetestOrbLow := na
        pendingRetestBarIndex := na
        pendingRetestSessionCloseTs := na
    else if not retestSameBarBlocked and retestEntryTimeOk
        // FIX 2: require candle color agreement on retest confirmation
        bool longRetestHit =
             pendingRetestDirection == "Long" and
             low <= pendingRetestLevel and
             close > pendingRetestLevel and
             close > open

        bool shortRetestHit =
             pendingRetestDirection == "Short" and
             high >= pendingRetestLevel and
             close < pendingRetestLevel and
             close < open

        if longRetestHit
            longSignal := true
            activeORB := pendingRetestSession
            pendingORB := pendingRetestSession
            pendingSessionCloseTs := pendingRetestSessionCloseTs
            intendedStop := pendingRetestStop

            if pendingRetestSession == "NY"
                nyTraded := true
                nyLongTradeCount += 1
                nyLongRetryEligible := false
                nyLongRetryArmed := false
                nyLongNeedsReset := false
                nyLongDead := true
            else if pendingRetestSession == "London"
                ldnTraded := true
                ldnLongTradeCount += 1
                ldnLongRetryEligible := false
                ldnLongRetryArmed := false
                ldnLongNeedsReset := false
                ldnLongDead := true
            else if pendingRetestSession == "Asia"
                asiaTraded := true
                asiaLongTradeCount += 1
                asiaLongRetryEligible := false
                asiaLongRetryArmed := false
                asiaLongNeedsReset := false
                asiaLongDead := true

            pendingRetestActive := false
            pendingRetestSession := ""
            pendingRetestDirection := ""
            pendingRetestStop := na
            pendingRetestLevel := na
            pendingRetestOrbHigh := na
            pendingRetestOrbLow := na
            pendingRetestBarIndex := na
            pendingRetestSessionCloseTs := na

        else if shortRetestHit
            shortSignal := true
            activeORB := pendingRetestSession
            pendingORB := pendingRetestSession
            pendingSessionCloseTs := pendingRetestSessionCloseTs
            intendedStop := pendingRetestStop

            if pendingRetestSession == "NY"
                nyTraded := true
                nyShortTradeCount += 1
                nyShortRetryEligible := false
                nyShortRetryArmed := false
                nyShortNeedsReset := false
                nyShortDead := true
            else if pendingRetestSession == "London"
                ldnTraded := true
                ldnShortTradeCount += 1
                ldnShortRetryEligible := false
                ldnShortRetryArmed := false
                ldnShortNeedsReset := false
                ldnShortDead := true
            else if pendingRetestSession == "Asia"
                asiaTraded := true
                asiaShortTradeCount += 1
                asiaShortRetryEligible := false
                asiaShortRetryArmed := false
                asiaShortNeedsReset := false
                asiaShortDead := true

            pendingRetestActive := false
            pendingRetestSession := ""
            pendingRetestDirection := ""
            pendingRetestStop := na
            pendingRetestLevel := na
            pendingRetestOrbHigh := na
            pendingRetestOrbLow := na
            pendingRetestBarIndex := na
            pendingRetestSessionCloseTs := na

// =========================
// Pending follow-through evaluation
// =========================
if pendingConfirmActive and strategy.position_size == 0 and not longSignal and not shortSignal
    bool confirmEntryTimeOk = sessionEntryAllowed(pendingConfirmSession)
    if not na(pendingConfirmBarIndex) and bar_index == pendingConfirmBarIndex + 1 and confirmEntryTimeOk
        bool confirmLong = pendingConfirmDirection == "Long" and followThroughLongOk(pendingConfirmOrbHigh, pendingConfirmBreakoutHigh, pendingConfirmBreakoutClose)
        bool confirmShort = pendingConfirmDirection == "Short" and followThroughShortOk(pendingConfirmOrbLow, pendingConfirmBreakoutLow, pendingConfirmBreakoutClose)

        if confirmLong
            longSignal := true
            activeORB := pendingConfirmSession
            pendingORB := pendingConfirmSession
            pendingSessionCloseTs := pendingConfirmSessionCloseTs
            intendedStop := pendingConfirmStop

            if pendingConfirmSession == "NY"
                nyTraded := true
                nyLongTradeCount += 1
                nyLongRetryEligible := false
                nyLongRetryArmed := false
                nyLongNeedsReset := false
                nyLongDead := true
            else if pendingConfirmSession == "London"
                ldnTraded := true
                ldnLongTradeCount += 1
                ldnLongRetryEligible := false
                ldnLongRetryArmed := false
                ldnLongNeedsReset := false
                ldnLongDead := true
            else if pendingConfirmSession == "Asia"
                asiaTraded := true
                asiaLongTradeCount += 1
                asiaLongRetryEligible := false
                asiaLongRetryArmed := false
                asiaLongNeedsReset := false
                asiaLongDead := true

        else if confirmShort
            shortSignal := true
            activeORB := pendingConfirmSession
            pendingORB := pendingConfirmSession
            pendingSessionCloseTs := pendingConfirmSessionCloseTs
            intendedStop := pendingConfirmStop

            if pendingConfirmSession == "NY"
                nyTraded := true
                nyShortTradeCount += 1
                nyShortRetryEligible := false
                nyShortRetryArmed := false
                nyShortNeedsReset := false
                nyShortDead := true
            else if pendingConfirmSession == "London"
                ldnTraded := true
                ldnShortTradeCount += 1
                ldnShortRetryEligible := false
                ldnShortRetryArmed := false
                ldnShortNeedsReset := false
                ldnShortDead := true
            else if pendingConfirmSession == "Asia"
                asiaTraded := true
                asiaShortTradeCount += 1
                asiaShortRetryEligible := false
                asiaShortRetryArmed := false
                asiaShortNeedsReset := false
                asiaShortDead := true
        else
            if pendingConfirmSession == "NY" and pendingConfirmDirection == "Long"
                if breakoutMode == "First Qualified Close Only"
                    nyLongDead := true
                    nyLongNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    nyLongNeedsReset := true
                    nyLongOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    nyLongNeedsReset := true
                    nyLongOutsideCount := 0

            if pendingConfirmSession == "NY" and pendingConfirmDirection == "Short"
                if breakoutMode == "First Qualified Close Only"
                    nyShortDead := true
                    nyShortNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    nyShortNeedsReset := true
                    nyShortOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    nyShortNeedsReset := true
                    nyShortOutsideCount := 0

            if pendingConfirmSession == "London" and pendingConfirmDirection == "Long"
                if breakoutMode == "First Qualified Close Only"
                    ldnLongDead := true
                    ldnLongNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    ldnLongNeedsReset := true
                    ldnLongOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    ldnLongNeedsReset := true
                    ldnLongOutsideCount := 0

            if pendingConfirmSession == "London" and pendingConfirmDirection == "Short"
                if breakoutMode == "First Qualified Close Only"
                    ldnShortDead := true
                    ldnShortNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    ldnShortNeedsReset := true
                    ldnShortOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    ldnShortNeedsReset := true
                    ldnShortOutsideCount := 0

            if pendingConfirmSession == "Asia" and pendingConfirmDirection == "Long"
                if breakoutMode == "First Qualified Close Only"
                    asiaLongDead := true
                    asiaLongNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    asiaLongNeedsReset := true
                    asiaLongOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    asiaLongNeedsReset := true
                    asiaLongOutsideCount := 0

            if pendingConfirmSession == "Asia" and pendingConfirmDirection == "Short"
                if breakoutMode == "First Qualified Close Only"
                    asiaShortDead := true
                    asiaShortNeedsReset := true
                else if breakoutMode == "Reset Inside Then Requalify"
                    asiaShortNeedsReset := true
                    asiaShortOutsideCount := 0
                else if breakoutMode == "One-Bar Grace Then Reset"
                    asiaShortNeedsReset := true
                    asiaShortOutsideCount := 0

        pendingConfirmActive := false
        pendingConfirmSession := ""
        pendingConfirmDirection := ""
        pendingConfirmStop := na
        pendingConfirmOrbHigh := na
        pendingConfirmOrbLow := na
        pendingConfirmBreakoutHigh := na
        pendingConfirmBreakoutLow := na
        pendingConfirmBreakoutClose := na
        pendingConfirmBarIndex := na
        pendingConfirmSessionCloseTs := na

// =========================
// New breakout routing
// Priority:
// 1) Large breakout retest
// 2) Follow-through confirmation
// 3) Immediate entry
// =========================
if strategy.position_size == 0 and not pendingRetestActive and not pendingConfirmActive and not longSignal and not shortSignal
    // 1) Large breakout retest path
    if useLargeBreakoutRetest
        if nyLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "NY"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel(true, nyHigh, nyLow, high, low)
            pendingRetestOrbHigh := nyHigh
            pendingRetestOrbLow := nyLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("NY")
        else if nyShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "NY"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel(false, nyHigh, nyLow, high, low)
            pendingRetestOrbHigh := nyHigh
            pendingRetestOrbLow := nyLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("NY")
        else if ldnLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "London"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel(true, ldnHigh, ldnLow, high, low)
            pendingRetestOrbHigh := ldnHigh
            pendingRetestOrbLow := ldnLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("London")
        else if ldnShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "London"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel(false, ldnHigh, ldnLow, high, low)
            pendingRetestOrbHigh := ldnHigh
            pendingRetestOrbLow := ldnLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("London")
        else if asiaLongLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "Asia"
            pendingRetestDirection := "Long"
            pendingRetestStop := low - buf
            pendingRetestLevel := calcRetestLevel(true, asiaHigh, asiaLow, high, low)
            pendingRetestOrbHigh := asiaHigh
            pendingRetestOrbLow := asiaLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("Asia")
        else if asiaShortLargeBreakout
            pendingRetestActive := true
            pendingRetestSession := "Asia"
            pendingRetestDirection := "Short"
            pendingRetestStop := high + buf
            pendingRetestLevel := calcRetestLevel(false, asiaHigh, asiaLow, high, low)
            pendingRetestOrbHigh := asiaHigh
            pendingRetestOrbLow := asiaLow
            pendingRetestBarIndex := bar_index
            pendingRetestSessionCloseTs := getSessionCloseTs("Asia")

    // 2) Follow-through confirmation path for non-large breakouts
    if not pendingRetestActive and useFollowThroughConfirmation
        if nyLongBreakout and not nyLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "NY"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := nyHigh
            pendingConfirmOrbLow := nyLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("NY")
        else if nyShortBreakout and not nyShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "NY"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := nyHigh
            pendingConfirmOrbLow := nyLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("NY")
        else if ldnLongBreakout and not ldnLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "London"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := ldnHigh
            pendingConfirmOrbLow := ldnLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("London")
        else if ldnShortBreakout and not ldnShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "London"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := ldnHigh
            pendingConfirmOrbLow := ldnLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("London")
        else if asiaLongBreakout and not asiaLongLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "Asia"
            pendingConfirmDirection := "Long"
            pendingConfirmStop := low - buf
            pendingConfirmOrbHigh := asiaHigh
            pendingConfirmOrbLow := asiaLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("Asia")
        else if asiaShortBreakout and not asiaShortLargeBreakout
            pendingConfirmActive := true
            pendingConfirmSession := "Asia"
            pendingConfirmDirection := "Short"
            pendingConfirmStop := high + buf
            pendingConfirmOrbHigh := asiaHigh
            pendingConfirmOrbLow := asiaLow
            pendingConfirmBreakoutHigh := high
            pendingConfirmBreakoutLow := low
            pendingConfirmBreakoutClose := close
            pendingConfirmBarIndex := bar_index
            pendingConfirmSessionCloseTs := getSessionCloseTs("Asia")

    // 3) Immediate entry path
    if not pendingRetestActive and not pendingConfirmActive
        bool allowImmediateNyLong = nyLongBreakout and not nyLongLargeBreakout
        bool allowImmediateNyShort = nyShortBreakout and not nyShortLargeBreakout
        bool allowImmediateLdnLong = ldnLongBreakout and not ldnLongLargeBreakout
        bool allowImmediateLdnShort = ldnShortBreakout and not ldnShortLargeBreakout
        bool allowImmediateAsiaLong = asiaLongBreakout and not asiaLongLargeBreakout
        bool allowImmediateAsiaShort = asiaShortBreakout and not asiaShortLargeBreakout

        if allowImmediateNyLong
            longSignal := true
            activeORB := "NY"
            pendingORB := "NY"
            pendingSessionCloseTs := getSessionCloseTs("NY")
            intendedStop := low - buf
            nyTraded := true
            nyLongTradeCount += 1
            nyLongRetryEligible := false
            nyLongRetryArmed := false
            nyLongNeedsReset := false
            nyLongDead := true
        else if allowImmediateNyShort
            shortSignal := true
            activeORB := "NY"
            pendingORB := "NY"
            pendingSessionCloseTs := getSessionCloseTs("NY")
            intendedStop := high + buf
            nyTraded := true
            nyShortTradeCount += 1
            nyShortRetryEligible := false
            nyShortRetryArmed := false
            nyShortNeedsReset := false
            nyShortDead := true
        else if allowImmediateLdnLong
            longSignal := true
            activeORB := "London"
            pendingORB := "London"
            pendingSessionCloseTs := getSessionCloseTs("London")
            intendedStop := low - buf
            ldnTraded := true
            ldnLongTradeCount += 1
            ldnLongRetryEligible := false
            ldnLongRetryArmed := false
            ldnLongNeedsReset := false
            ldnLongDead := true
        else if allowImmediateLdnShort
            shortSignal := true
            activeORB := "London"
            pendingORB := "London"
            pendingSessionCloseTs := getSessionCloseTs("London")
            intendedStop := high + buf
            ldnTraded := true
            ldnShortTradeCount += 1
            ldnShortRetryEligible := false
            ldnShortRetryArmed := false
            ldnShortNeedsReset := false
            ldnShortDead := true
        else if allowImmediateAsiaLong
            longSignal := true
            activeORB := "Asia"
            pendingORB := "Asia"
            pendingSessionCloseTs := getSessionCloseTs("Asia")
            intendedStop := low - buf
            asiaTraded := true
            asiaLongTradeCount += 1
            asiaLongRetryEligible := false
            asiaLongRetryArmed := false
            asiaLongNeedsReset := false
            asiaLongDead := true
        else if allowImmediateAsiaShort
            shortSignal := true
            activeORB := "Asia"
            pendingORB := "Asia"
            pendingSessionCloseTs := getSessionCloseTs("Asia")
            intendedStop := high + buf
            asiaTraded := true
            asiaShortTradeCount += 1
            asiaShortRetryEligible := false
            asiaShortRetryArmed := false
            asiaShortNeedsReset := false
            asiaShortDead := true

if longSignal
    strategy.entry("Long", strategy.long)
    if showLabels
        label.new(bar_index, low, activeORB + " Long", style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 0))

if shortSignal
    strategy.entry("Short", strategy.short)
    if showLabels
        label.new(bar_index, high, activeORB + " Short", style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0))

// =========================
// Freeze entry/stop/risk on actual fill bar
// =========================
var float posStopRef = na
var float posEntry   = na
var float posRisk    = na
var float posBaseRisk = na
var float posTrailRisk = na
var float highestSinceEntry = na
var float lowestSinceEntry  = na
var int   entryBarIndex = na
var int   activeSessionCloseTs = na
var int   timeExitStartBarIndex = na
var int   lastTrailStepCount = 0
var string openTradeSession = ""
var string openTradeDirection = ""

if longSignal or shortSignal
    posStopRef := intendedStop

newLong  = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
flatNow  = strategy.position_size == 0 and strategy.position_size[1] != 0

if flatNow
    closedTradePnl = strategy.netprofit - nz(strategy.netprofit[1])
    if allowSecondBreak and closedTradePnl < 0
        if openTradeSession == "NY" and openTradeDirection == "Long" and nyLongTradeCount == 1
            nyLongRetryEligible := true
            nyLongRetryArmed := false
            nyLongDead := false
            nyLongNeedsReset := false
            nyLongOutsideCount := 0
        else if openTradeSession == "NY" and openTradeDirection == "Short" and nyShortTradeCount == 1
            nyShortRetryEligible := true
            nyShortRetryArmed := false
            nyShortDead := false
            nyShortNeedsReset := false
            nyShortOutsideCount := 0
        else if openTradeSession == "London" and openTradeDirection == "Long" and ldnLongTradeCount == 1
            ldnLongRetryEligible := true
            ldnLongRetryArmed := false
            ldnLongDead := false
            ldnLongNeedsReset := false
            ldnLongOutsideCount := 0
        else if openTradeSession == "London" and openTradeDirection == "Short" and ldnShortTradeCount == 1
            ldnShortRetryEligible := true
            ldnShortRetryArmed := false
            ldnShortDead := false
            ldnShortNeedsReset := false
            ldnShortOutsideCount := 0
        else if openTradeSession == "Asia" and openTradeDirection == "Long" and asiaLongTradeCount == 1
            asiaLongRetryEligible := true
            asiaLongRetryArmed := false
            asiaLongDead := false
            asiaLongNeedsReset := false
            asiaLongOutsideCount := 0
        else if openTradeSession == "Asia" and openTradeDirection == "Short" and asiaShortTradeCount == 1
            asiaShortRetryEligible := true
            asiaShortRetryArmed := false
            asiaShortDead := false
            asiaShortNeedsReset := false
            asiaShortOutsideCount := 0

    posEntry := na
    posRisk := na
    posBaseRisk := na
    posTrailRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na
    activeORB := ""
    pendingORB := ""
    activeSessionCloseTs := na
    pendingSessionCloseTs := na
    timeExitStartBarIndex := na
    lastTrailStepCount := 0
    openTradeSession := ""
    openTradeDirection := ""
else if strategy.position_size == 0
    posEntry := na
    posRisk := na
    posBaseRisk := na
    posTrailRisk := na
    highestSinceEntry := na
    lowestSinceEntry := na
    entryBarIndex := na
    activeORB := ""
    activeSessionCloseTs := na
    timeExitStartBarIndex := na
    lastTrailStepCount := 0

if newLong
    posEntry := strategy.position_avg_price
    posBaseRisk := posEntry - posStopRef
    posRisk := useStopAdjustment ? posBaseRisk * stopMultiplier : posBaseRisk
    posTrailRisk := tradeMode == "1R Step Trail" and useStopAdjustment and trailRiskBasis == "Original Breakout Risk" ? posBaseRisk : posRisk
    posStopRef := posEntry - posRisk
    highestSinceEntry := high
    entryBarIndex := bar_index
    activeORB := pendingORB
    activeSessionCloseTs := pendingSessionCloseTs
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := 0
    openTradeSession := pendingORB
    openTradeDirection := "Long"

if newShort
    posEntry := strategy.position_avg_price
    posBaseRisk := posStopRef - posEntry
    posRisk := useStopAdjustment ? posBaseRisk * stopMultiplier : posBaseRisk
    posTrailRisk := tradeMode == "1R Step Trail" and useStopAdjustment and trailRiskBasis == "Original Breakout Risk" ? posBaseRisk : posRisk
    posStopRef := posEntry + posRisk
    lowestSinceEntry := low
    entryBarIndex := bar_index
    activeORB := pendingORB
    activeSessionCloseTs := pendingSessionCloseTs
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := 0
    openTradeSession := pendingORB
    openTradeDirection := "Short"

if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)

if strategy.position_size < 0
    lowestSinceEntry := na(lowestSinceEntry) ? low : math.min(lowestSinceEntry, low)

validLong  = strategy.position_size > 0 and not na(posEntry) and not na(posRisk) and not na(posTrailRisk) and posRisk > 0 and posTrailRisk > 0 and not na(posStopRef)
validShort = strategy.position_size < 0 and not na(posEntry) and not na(posRisk) and not na(posTrailRisk) and posRisk > 0 and posTrailRisk > 0 and not na(posStopRef)

// =========================
// Helper state for trail activation
// =========================
longRunupR  = validLong ? math.floor((highestSinceEntry - posEntry) / posTrailRisk) : na
shortRunupR = validShort ? math.floor((posEntry - lowestSinceEntry) / posTrailRisk) : na

trailActiveLong  = validLong and tradeMode == "1R Step Trail" and longRunupR >= 1
trailActiveShort = validShort and tradeMode == "1R Step Trail" and shortRunupR >= 1

if validLong and resetTimeExitOnTrailStep and tradeMode == "1R Step Trail" and longRunupR >= 1 and longRunupR > lastTrailStepCount
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := longRunupR

if validShort and resetTimeExitOnTrailStep and tradeMode == "1R Step Trail" and shortRunupR >= 1 and shortRunupR > lastTrailStepCount
    timeExitStartBarIndex := bar_index
    lastTrailStepCount := shortRunupR

// =========================
// Time Exit Logic
// =========================
barsInTrade = not na(entryBarIndex) ? (bar_index - entryBarIndex) : na
barsSinceTimeExitReset = not na(timeExitStartBarIndex) ? (bar_index - timeExitStartBarIndex) : na
timeExitBars = resetTimeExitOnTrailStep and tradeMode == "1R Step Trail" ? barsSinceTimeExitReset : barsInTrade
longInProfit  = validLong and close > posEntry
shortInProfit = validShort and close < posEntry

timeExitEligibleLong = true
timeExitEligibleShort = true

timeExitLong = useTimeExit and validLong and timeExitEligibleLong and not na(timeExitBars) and timeExitBars >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and longInProfit))
timeExitShort = useTimeExit and validShort and timeExitEligibleShort and not na(timeExitBars) and timeExitBars >= maxBarsInTrade and (timeExitMode == "Any" or (timeExitMode == "Only In Profit" and shortInProfit))

// =========================
// Session-specific forced close logic
// =========================
sessionCloseNow = useEodClose and strategy.position_size != 0 and not na(activeSessionCloseTs) and time_close >= activeSessionCloseTs

// =========================
// Visible active stop / target levels
// =========================
float activeLongStop   = na
float activeShortStop  = na
float activeLongTarget = na
float activeShortTarget = na

if validLong
    if tradeMode == "Fixed RR"
        activeLongStop   := posStopRef
        activeLongTarget := posEntry + posRisk * rrMultiple
    else
        activeLongStop := longRunupR < 1 ? posStopRef : posEntry + (longRunupR - 1) * posTrailRisk

if validShort
    if tradeMode == "Fixed RR"
        activeShortStop   := posStopRef
        activeShortTarget := posEntry - posRisk * rrMultiple
    else
        activeShortStop := shortRunupR < 1 ? posStopRef : posEntry - (shortRunupR - 1) * posTrailRisk

// =========================
// Exit Logic
// =========================
if validLong
    strategy.exit("Long Exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if validShort
    strategy.exit("Short Exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

if timeExitLong
    strategy.close("Long", comment="Time Exit")

if timeExitShort
    strategy.close("Short", comment="Time Exit")

if sessionCloseNow and strategy.position_size > 0
    strategy.close("Long", comment="Session Close")

if sessionCloseNow and strategy.position_size < 0
    strategy.close("Short", comment="Session Close")

// =========================
// Plot ORB levels
// =========================
plot(showORBLevels and tradeDayAllowed and useNY and (not showORBOnlyDuringTradeWindow or nyTradeWindowActive) ? nyHigh : na, "NY ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useNY and (not showORBOnlyDuringTradeWindow or nyTradeWindowActive) ? nyLow  : na, "NY ORB Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useLondon and (not showORBOnlyDuringTradeWindow or ldnTradeWindowActive) ? ldnHigh : na, "London ORB High", color=color.new(color.teal, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useLondon and (not showORBOnlyDuringTradeWindow or ldnTradeWindowActive) ? ldnLow  : na, "London ORB Low", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useAsia and (not showORBOnlyDuringTradeWindow or asiaTradeWindowActive) ? asiaHigh : na, "Asia ORB High", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_linebr)
plot(showORBLevels and tradeDayAllowed and useAsia and (not showORBOnlyDuringTradeWindow or asiaTradeWindowActive) ? asiaLow  : na, "Asia ORB Low", color=color.new(color.purple, 0), linewidth=2, style=plot.style_linebr)

// Pending visuals
plot(pendingRetestActive and pendingRetestDirection == "Long" ? pendingRetestLevel : na, "Pending Long Retest", color=color.new(color.green, 40), linewidth=2, style=plot.style_linebr)
plot(pendingRetestActive and pendingRetestDirection == "Short" ? pendingRetestLevel : na, "Pending Short Retest", color=color.new(color.red, 40), linewidth=2, style=plot.style_linebr)

// =========================
// Plot active stop / target
// =========================
plot(showActiveStop and validLong ? activeLongStop : na, "Long Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)
plot(showActiveStop and validShort ? activeShortStop : na, "Short Active Stop", color=color.new(color.blue, 0), linewidth=3, style=plot.style_circles)
plot(showActiveTarget and tradeMode == "Fixed RR" and validLong ? activeLongTarget : na, "Long Target", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(showActiveTarget and tradeMode == "Fixed RR" and validShort ? activeShortTarget : na, "Short Target", color=color.new(color.maroon, 0), linewidth=2, style=plot.style_linebr)